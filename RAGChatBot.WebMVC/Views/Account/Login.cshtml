@model RAGChatBot.Application.DTOs.LoginRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - RAG ChatBot</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #bae6fd 100%);
            --card-bg: rgba(255, 255, 255, 0.85);
            --border-color: rgba(14, 165, 233, 0.2);
            --primary-color: #0ea5e9;
            --primary-hover: #0284c7;
            --text-main: #0f172a;
            --text-sub: #334155;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-gradient);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow-x: hidden;
        }

        .login-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            transition: all 0.3s ease;
        }

        .login-card:hover {
            border-color: rgba(14, 165, 233, 0.4);
            box-shadow: 0 20px 40px rgba(14, 165, 233, 0.15);
        }

        .brand-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .brand-logo h1 {
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(to right, #0ea5e9, #0284c7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }

        .brand-logo p {
            color: var(--text-sub);
            font-size: 0.95rem;
            margin-top: 8px;
        }

        .form-label {
            color: var(--text-sub);
            font-weight: 500;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .form-control {
            background: rgba(255, 255, 255, 0.9);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            color: var(--text-main) !important;
            padding: 12px 16px;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            background: #ffffff;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.2);
            outline: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color) 0%, #0284c7 100%);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            color: white;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(14, 165, 233, 0.4);
            color: white;
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .alert-custom {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            color: #fca5a5;
            padding: 12px;
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .register-link {
            text-align: center;
            margin-top: 15px;
            font-size: 0.9rem;
            color: var(--text-sub);
        }
        
        .register-link a {
            color: #0284c7;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }
        
        .register-link a:hover {
            color: #0369a1;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="brand-logo">
                <h1>RAG ChatBot</h1>
                <p>Hệ thống Quản trị & Trợ lý Tri thức AI</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-custom">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div class="mb-3">
                    <label for="Username" class="form-label">Tên tài khoản</label>
                    <input type="text" class="form-control" id="Username" name="Username" placeholder="Nhập tài khoản giảng viên..." required autofocus />
                </div>
                <div class="mb-4">
                    <label for="Password" class="form-label">Mật khẩu</label>
                    <input type="password" class="form-control" id="Password" name="Password" placeholder="Nhập mật khẩu..." required />
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-3">Đăng Nhập</button>
            </form>

            <div class="d-flex align-items-center mb-3">
                <hr class="flex-grow-1" style="border-top: 1px solid var(--border-color);">
                <span class="px-3 text-muted" style="font-size: 0.85rem;">Hoặc</span>
                <hr class="flex-grow-1" style="border-top: 1px solid var(--border-color);">
            </div>

            <form asp-action="ExternalLogin" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <button type="submit" class="btn w-100 py-2 d-flex align-items-center justify-content-center gap-2" style="background: white; border: 1px solid var(--border-color); border-radius: 12px; color: var(--text-main); font-weight: 500; transition: all 0.2s ease;">
                    <img src="https://www.google.com/favicon.ico" alt="Google" width="20" height="20">
                    Đăng nhập bằng Google
                </button>
            </form>
        </div>
    </div>
</body>
</html>
