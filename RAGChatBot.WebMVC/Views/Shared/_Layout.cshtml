<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG ChatBot</title>
    <!-- We removed Bootstrap from main elements but keep CDN for any hidden modals or base resets -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Minimalist Layout overrides */
        body {
            padding: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .zen-header {
            padding: 40px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
        }

        .zen-brand {
            font-family: var(--font-serif);
            font-size: 1.5rem;
            font-weight: 500;
            color: var(--text-sumi);
            text-decoration: none;
            display: flex;
            align-items: center;
            letter-spacing: 0.05em;
        }

        .zen-menu-trigger {
            background: transparent;
            border: none;
            font-family: var(--font-sans);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--text-sumi);
            cursor: pointer;
            padding: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .zen-menu-trigger::before {
            content: '';
            width: 30px;
            height: 1px;
            background-color: var(--text-sumi);
            transition: width 0.3s ease;
        }

        .zen-menu-trigger:hover::before {
            width: 50px;
        }

        .zen-main {
            flex: 1;
            padding: 0 60px 60px 60px;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        .overlay-close {
            position: absolute;
            top: 40px;
            right: 60px;
            background: transparent;
            border: none;
            font-size: 2rem;
            color: var(--text-sumi);
            cursor: pointer;
            font-family: var(--font-sans);
            font-weight: 300;
        }

        @@media (max-width: 768px) {
            .zen-header, .zen-main {
                padding: 20px;
            }
            .overlay-close {
                top: 20px;
                right: 20px;
            }
            .zen-menu-item {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>
    <!-- Top Header -->
    <header class="zen-header gsap-fade-up" id="headerFade">
        <a href="/" class="zen-brand">
            <span class="hanko-seal">印</span>
            RAG ChatBot
        </a>
        <button class="zen-menu-trigger" id="openMenuBtn">
            Menu
        </button>
    </header>

    <!-- Main Content -->
    <main class="zen-main" id="main-content">
        @RenderBody()
    </main>

    <!-- Full-screen Overlay Menu -->
    <div class="zen-overlay" id="zenOverlay">
        <button class="overlay-close" id="closeMenuBtn">&times;</button>
        
        @if (User.Identity?.IsAuthenticated == true)
        {
            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
            var tier = User.FindFirst("SubscriptionTier")?.Value ?? "Free";
            
            <div style="position: absolute; top: 40px; left: 60px; font-family: var(--font-sans); font-size: 0.9rem; color: var(--text-muted);">
                Xin chào, <span style="color: var(--text-sumi);">@User.Identity.Name</span><br>
                @role &bull; @tier
            </div>

            if (role == "Admin")
            {
                <a asp-controller="Admin" asp-action="Index" class="zen-menu-item">Tài Khoản</a>
                <a asp-controller="Admin" asp-action="Whitelist" class="zen-menu-item">Whitelist</a>
            }
            else
            {
                <a asp-controller="Home" asp-action="Index" class="zen-menu-item">Trò Chuyện</a>
            }
            
            <a asp-controller="Course" asp-action="Index" class="zen-menu-item">Học Liệu</a>
            
            @if (role != "Admin" && tier == "Free")
            {
                <a asp-controller="Subscription" asp-action="Index" class="zen-menu-item" style="color: var(--accent-shu);">Nâng cấp Premium</a>
            }
            
            <a asp-controller="Account" asp-action="Logout" class="zen-menu-item" style="font-size: 1.5rem; margin-top: 40px; color: var(--text-muted);">Đăng xuất</a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="zen-menu-item">Trang chủ</a>
            <a asp-controller="Account" asp-action="Login" class="zen-menu-item" style="font-size: 2rem; margin-top: 40px;">Đăng nhập</a>
        }
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initial fade up for header
            gsap.to("#headerFade", { y: 0, opacity: 1, duration: 1.5, ease: "power3.out" });

            const overlay = document.getElementById('zenOverlay');
            const openBtn = document.getElementById('openMenuBtn');
            const closeBtn = document.getElementById('closeMenuBtn');
            const menuItems = document.querySelectorAll('.zen-menu-item');
            
            let tl = gsap.timeline({ paused: true });
            
            // Overlay fades in
            tl.to(overlay, { autoAlpha: 1, duration: 0.6, ease: "power2.inOut" });
            // Menu items stagger reveal
            tl.to(menuItems, { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: "power3.out" }, "-=0.2");

            openBtn.addEventListener('click', () => {
                overlay.classList.add('active');
                tl.play();
                document.body.style.overflow = 'hidden';
            });

            closeBtn.addEventListener('click', () => {
                tl.reverse().then(() => {
                    overlay.classList.remove('active');
                    document.body.style.overflow = '';
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
