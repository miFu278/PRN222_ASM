@model RAGChatBot.Application.DTOs.CourseDto
@{
    ViewData["Title"] = "Thêm Môn Học Mới";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-3" style="width: 60px; height: 60px;">
                            <i class="fa-solid fa-layer-group fa-2x"></i>
                        </div>
                        <h3 class="fw-bold text-dark">Thêm Môn Học Mới</h3>
                        <p class="text-muted">Nhập thông tin môn học để tạo mới.</p>
                    </div>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Code" class="form-label fw-semibold">Mã môn học <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" placeholder="Ví dụ: CS101" required style="border-radius: 8px; padding: 10px 15px;" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Tên môn học <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Ví dụ: Cơ sở lập trình" required style="border-radius: 8px; padding: 10px 15px;" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SubjectLeaderId" class="form-label fw-semibold">Trưởng bộ môn (Subject Leader) <span class="text-danger">*</span></label>
                            <select asp-for="SubjectLeaderId" class="form-select" style="border-radius: 8px; padding: 10px 15px;" required>
                                <option value="">-- Chọn Trưởng bộ môn --</option>
                                @if (ViewBag.Lecturers != null)
                                {
                                    foreach (var lecturer in (IEnumerable<RAGChatBot.Application.DTOs.UserDto>)ViewBag.Lecturers)
                                    {
                                        <option value="@lecturer.Id">@(string.IsNullOrEmpty(lecturer.FullName) ? lecturer.Username : lecturer.FullName) (@(lecturer.Role == "Admin" ? "Admin" : "Giảng viên"))</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="SubjectLeaderId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold">Mô tả chi tiết</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả môn học..." style="border-radius: 8px; padding: 10px 15px;"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-2 fw-semibold" style="border-radius: 8px; font-size: 1.1rem;">
                                <i class="fa-solid fa-check me-2"></i> Tạo Môn Học
                            </button>
                            <a asp-action="Index" class="btn btn-light py-2 fw-semibold" style="border-radius: 8px; color: var(--text-sub);">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
