@model IEnumerable<RAGChatBot.Application.DTOs.UserDto>
@{
    ViewData["Title"] = "Quản trị Hệ thống";
}

<div class="row">
    <div class="col-lg-12 mb-4">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div>
                <h2 class="fw-bold" style="background: linear-gradient(to right, #6366f1, #4f46e5); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    <i class="fa-solid fa-users-gear me-2"></i>Quản Lý Tài Khoản Người Dùng
                </h2>
                <p class="text-muted mb-0">Quản trị viên có thể tạo mới, nâng cấp gói cước và xóa tài khoản của giảng viên/sinh viên.</p>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-success-custom py-2 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#importUsersModal">
                    <i class="fa-solid fa-file-excel me-1"></i> Import Excel
                </button>
                <button type="button" class="btn btn-primary-custom py-2 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#createAccountModal">
                    <i class="fa-solid fa-user-plus me-1"></i> Tạo tài khoản mới
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Hiển thị thông báo trạng thái -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 mb-4 animate-fade-in" role="alert" style="background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3) !important; color: #86efac;">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 mb-4 animate-fade-in" role="alert" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3) !important; color: #fca5a5;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card-custom">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-dark mb-0">
            <i class="fa-solid fa-users text-indigo me-2"></i>Danh sách Tài khoản Hệ thống
        </h4>
        <span class="badge bg-secondary rounded-pill px-3 py-2" style="background: rgba(0,0,0,0.05) !important; border: 1px solid var(--border-color); color: var(--text-main);">
            @Model.Count() người dùng
        </span>
    </div>

    <div class="table-responsive">
        <table class="table table-custom align-middle">
            <thead>
                <tr>
                    <th>Tên Tài Khoản (Username)</th>
                    <th>Vai Trò (Role)</th>
                    <th>Gói Cước (Subscription Tier)</th>
                    <th class="text-end">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="user-avatar-sm" style="width: 32px; height: 32px; border-radius: 50%; background: @(user.Role == "Admin" ? "#4f46e5" : user.Role == "Lecturer" ? "#ca8a04" : "#0284c7"); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.85rem;">
                                    @(string.IsNullOrEmpty(user.FullName) ? user.Username.Substring(0, 1).ToUpper() : user.FullName.Substring(0, 1).ToUpper())
                                </div>
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold text-dark">@(string.IsNullOrEmpty(user.FullName) ? "Chưa cập nhật" : user.FullName)</span>
                                    <small class="text-muted" style="font-size: 0.8rem;">@user.Username</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-indigo text-white px-3 py-1">Quản trị viên</span>
                            }
                            else if (user.Role == "Lecturer")
                            {
                                <span class="badge bg-warning text-dark px-3 py-1">Giảng viên</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-white px-3 py-1">Sinh viên</span>
                            }
                        </td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-2">
                                    @if (user.SubscriptionTier == "Premium")
                                    {
                                        <span class="status-badge status-processed">
                                            <i class="fa-solid fa-crown me-1 text-yellow-400"></i> Premium
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-failed px-3 py-1 text-dark">
                                           <i class="fa-solid me-1"></i> Free
                                        </span>
                                    }

                                    <form asp-action="ToggleTier" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-xs btn-outline-secondary py-1 px-2 rounded-3" style="font-size: 0.75rem;" title="Chuyển đổi gói cước">
                                            <i class="fa-solid fa-arrows-rotate"></i> Đổi
                                        </button>
                                    </form>
                                </div>
                            }
                        </td>
                        <td class="text-end">
                            @if (user.Role == "Admin")
                            {
                                <span class="text-muted" style="font-size: 0.85rem; font-style: italic;">Mặc định hệ thống</span>
                            }
                            else
                            {
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài khoản này vĩnh viễn không? Mọi dữ liệu liên quan sẽ bị xóa sạch.');" style="display:inline;">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-action-delete" title="Xóa tài khoản">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Tạo tài khoản mới -->
<div class="modal fade" id="createAccountModal" tabindex="-1" aria-labelledby="createAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: #ffffff; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark" id="createAccountModalLabel">
                    <i class="fa-solid fa-user-plus text-indigo me-2"></i>Tạo Tài Khoản Mới
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-action="Create" method="post">
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label for="fullNameInput" class="form-label">Họ và Tên</label>
                        <input type="text" class="form-control form-control-custom" id="fullNameInput" name="fullName" placeholder="Ví dụ: Nguyễn Văn A" required />
                    </div>

                    <div class="mb-3">
                        <label for="usernameInput" class="form-label">Tên tài khoản (Username hoặc Email)</label>
                        <input type="text" class="form-control form-control-custom" id="usernameInput" name="username" placeholder="Ví dụ: nguyenvanA hoặc vanA@school.edu.vn" required />
                    </div>
                    
                    <div class="mb-3">
                        <label for="passwordInput" class="form-label">Mật khẩu</label>
                        <input type="password" class="form-control form-control-custom" id="passwordInput" name="password" placeholder="Nhập mật khẩu ban đầu..." required />
                    </div>
                    
                    <div class="mb-3">
                        <label for="roleInput" class="form-label">Vai trò hệ thống</label>
                        <select class="form-select form-control-custom" id="roleInput" name="role" required>
                            <option value="Student">Sinh viên (Student)</option>
                            <option value="Lecturer">Giảng viên (Lecturer)</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="tierInput" class="form-label">Gói sử dụng</label>
                        <select class="form-select form-control-custom" id="tierInput" name="subscriptionTier" required>
                            <option value="Free">Gói Miễn phí (Free)</option>
                            <option value="Premium">Gói Trả phí (Premium)</option>
                        </select>
                    </div>
                </div>
                
                <div class="modal-footer border-top-0 pb-4 px-4 gap-2">
                    <button type="button" class="btn btn-outline-secondary py-2 px-3 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary-custom py-2 px-4 shadow-sm">
                        <i class="fa-solid fa-circle-check me-1"></i> Xác Nhận Tạo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-primary-custom {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 12px;
        transition: all 0.2s ease;
    }
    
    .btn-primary-custom:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(79, 70, 229, 0.3);
        color: white;
    }

    .btn-success-custom {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 12px;
        transition: all 0.2s ease;
    }
    .btn-success-custom:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(22, 163, 74, 0.3);
        color: white;
    }
</style>

<!-- Modal Import Excel tài khoản -->
<div class="modal fade" id="importUsersModal" tabindex="-1" aria-labelledby="importUsersModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4" style="background: #ffffff; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark" id="importUsersModalLabel">
                    <i class="fa-solid fa-file-excel text-success me-2"></i>Import Tài Khoản Từ File Excel
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="ImportUsers" method="post" enctype="multipart/form-data">
                <div class="modal-body px-4 py-3">
                    <!-- Hướng dẫn định dạng -->
                    <div class="alert alert-info border-0 rounded-3 mb-4" style="background: rgba(6,182,212,0.08); border-left: 4px solid #06b6d4 !important; border: none;">
                        <p class="fw-semibold mb-2"><i class="fa-solid fa-circle-info me-1"></i> Định dạng file Excel mẫu:</p>
                        <ul class="mb-2 ps-3" style="font-size:0.9rem;">
                            <li>File Excel <strong>.xlsx</strong> hoặc <strong>.xls</strong></li>
                            <li>Bắt buộc có cột <strong>"Email"</strong> (dùng làm tên đăng nhập)</li>
                            <li>Tùy chọn: cột <strong>"Họ và Tên"</strong>, <strong>"Vai Trò"</strong> (Student/Lecturer), <strong>"Gói"</strong> (Free/Premium)</li>
                            <li>Giá trị cột Vai Trò: <code>Student</code> / <code>Sinh viên</code> / <code>SV</code> hoặc <code>Lecturer</code> / <code>Giảng viên</code> / <code>GV</code></li>
                        </ul>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0" style="font-size:0.85rem; background:white;">
                                <thead class="table-light">
                                    <tr><th>Họ và Tên</th><th>Email</th><th>Vai Trò</th><th>Gói</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Nguyễn Văn A</td><td>vanA@@gmail.com</td><td>Student</td><td>Free</td></tr>
                                    <tr><td>Trần Thị B</td><td>thib@@gmail.com</td><td>Lecturer</td><td>Premium</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Mật khẩu mặc định -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu mặc định <span class="text-muted fw-normal">(áp dụng cho tất cả tài khoản trong file)</span></label>
                        <input type="text" class="form-control form-control-custom" name="defaultPassword" value="Welcome@2026" placeholder="Mật khẩu mặc định..." />
                        <div class="form-text"><i class="fa-solid fa-lock me-1"></i>Mật khẩu này sẽ được gửi kèm trong email thông báo đến từng người dùng.</div>
                    </div>

                    <!-- Chọn file -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn file Excel</label>
                        <div id="importDropZone" class="border-2 border-dashed rounded-3 p-4 text-center"
                             style="border-color: #22c55e; background: rgba(34,197,94,0.04); cursor:pointer; transition: all 0.2s;"
                             onclick="document.getElementById('importFileInput').click()">
                            <i class="fa-solid fa-cloud-arrow-up fa-2x text-success mb-2 d-block"></i>
                            <p class="mb-1 fw-semibold" id="importFileLabel">Nhấp để chọn file hoặc kéo thả vào đây</p>
                            <small class="text-muted">Chấp nhận file .xlsx hoặc .xls</small>
                        </div>
                        <input type="file" id="importFileInput" name="file" accept=".xlsx,.xls" class="d-none" required />
                    </div>
                </div>

                <div class="modal-footer border-top-0 pb-4 px-4 gap-2">
                    <button type="button" class="btn btn-outline-secondary py-2 px-3 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success-custom py-2 px-4 shadow-sm">
                        <i class="fa-solid fa-cloud-arrow-up me-1"></i> Bắt đầu Import & Gửi Mail
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Hiển thị tên file đã chọn
    document.getElementById('importFileInput').addEventListener('change', function () {
        const label = document.getElementById('importFileLabel');
        const zone = document.getElementById('importDropZone');
        if (this.files.length > 0) {
            label.textContent = this.files[0].name;
            zone.style.borderColor = '#16a34a';
            zone.style.background = 'rgba(34,197,94,0.1)';
        }
    });

    // Drag & drop
    const dropZone = document.getElementById('importDropZone');
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.background = 'rgba(34,197,94,0.12)'; });
    dropZone.addEventListener('dragleave', () => { dropZone.style.background = 'rgba(34,197,94,0.04)'; });
    dropZone.addEventListener('drop', e => {
        e.preventDefault();
        const file = e.dataTransfer.files[0];
        if (file) {
            document.getElementById('importFileInput').files = e.dataTransfer.files;
            document.getElementById('importFileLabel').textContent = file.name;
            dropZone.style.borderColor = '#16a34a';
            dropZone.style.background = 'rgba(34,197,94,0.1)';
        }
    });
</script>
