@model IEnumerable<RAGChatBot.Application.DTOs.WhitelistEmailDto>
@{
    ViewData["Title"] = "Quản lý Whitelist Email";
}

<div class="row">
    <div class="col-lg-12 mb-4">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div>
                <h2 class="fw-bold" style="background: linear-gradient(to right, #4f46e5, #0ea5e9); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    <i class="fa-solid fa-user-shield me-2"></i>Quản Lý Danh Sách Trắng Email
                </h2>
                <p class="text-muted mb-0">Phê duyệt trước email cá nhân (Gmail/Outlook) cho sinh viên khóa mới đăng ký hệ thống.</p>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary-custom py-2 px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#importExcelModal">
                    <i class="fa-solid fa-file-excel me-1"></i> Import Excel
                </button>
                <button type="button" class="btn btn-primary-custom py-2 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addEmailModal">
                    <i class="fa-solid fa-plus me-1"></i> Thêm email
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Hiển thị thông báo trạng thái -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 mb-4 animate-fade-in" role="alert" style="background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3) !important; color: #15803d; font-weight: 500;">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 mb-4 animate-fade-in" role="alert" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3) !important; color: #b91c1c; font-weight: 500;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card-custom mb-4" style="background: #ffffff; border-radius: 16px; border: 1px solid #e2e8f0; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.025);">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4">
        <div class="d-flex align-items-center gap-2">
            <h4 class="fw-bold text-dark mb-0">
                <i class="fa-solid fa-list-check text-indigo me-2"></i>Danh sách Email được duyệt
            </h4>
            <span class="badge rounded-pill px-3 py-2" style="background: #e0e7ff; color: #4338ca; font-weight: 600;">
                @Model.Count() tài khoản
            </span>
        </div>
        <div class="position-relative" style="max-width: 300px; width: 100%;">
            <input type="text" id="searchInput" class="form-control form-control-custom" placeholder="Tìm kiếm email, MSSV..." style="border-radius: 10px; padding-left: 45px !important;" />
            <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 16px; top: 50%; transform: translateY(-50%);"></i>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle" id="whitelistTable">
            <thead>
                <tr style="border-bottom: 2px solid #f1f5f9; color: #475569; font-weight: 600;">
                    <th class="pb-3">Họ và Tên</th>
                    <th class="pb-3">Mã Số Sinh Viên (MSSV)</th>
                    <th class="pb-3">Email được duyệt</th>
                    <th class="pb-3">Ngày thêm</th>
                    <th class="pb-3 text-end">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-user-slash fa-2x mb-3 text-slate-300"></i>
                            <p class="mb-0">Chưa có email nào trong whitelist. Vui lòng thêm thủ công hoặc import từ Excel.</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9;">
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="user-avatar-sm" style="width: 32px; height: 32px; border-radius: 50%; background: #e0f2fe; color: #0284c7; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.85rem;">
                                        @(string.IsNullOrEmpty(item.FullName) ? "N/A" : item.FullName.Substring(0, 1).ToUpper())
                                    </div>
                                    <span class="fw-semibold text-dark">@(string.IsNullOrEmpty(item.FullName) ? "Chưa cập nhật" : item.FullName)</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark px-2.5 py-1.5 border" style="font-weight: 500;">
                                    @(string.IsNullOrEmpty(item.StudentId) ? "N/A" : item.StudentId)
                                </span>
                            </td>
                            <td>
                                <span class="fw-semibold text-slate-700">@item.Email</span>
                            </td>
                            <td class="text-muted" style="font-size: 0.9rem;">
                                @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="text-end">
                                <form asp-action="DeleteFromWhitelist" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa email này khỏi whitelist? Người dùng này sẽ không thể đăng nhập nữa.');" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-action-delete" title="Xóa khỏi whitelist">
                                        <i class="fa-solid fa-user-minus"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm email thủ công -->
<div class="modal fade" id="addEmailModal" tabindex="-1" aria-labelledby="addEmailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: #ffffff; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark" id="addEmailModalLabel">
                    <i class="fa-solid fa-user-shield text-indigo me-2"></i>Thêm Email vào Whitelist
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-action="AddToWhitelist" method="post">
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label for="emailInput" class="form-label fw-semibold">Địa chỉ Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control form-control-custom" id="emailInput" name="email" placeholder="Ví dụ: sinhvienA@gmail.com" required />
                        <div class="form-text">Chỉ áp dụng cho các email cá nhân ngoài hệ thống fptedu (Gmail, Yahoo, Outlook cá nhân...)</div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="fullNameInput" class="form-label fw-semibold">Họ và Tên</label>
                        <input type="text" class="form-control form-control-custom" id="fullNameInput" name="fullName" placeholder="Ví dụ: Nguyễn Văn A" />
                    </div>
                    
                    <div class="mb-3">
                        <label for="studentIdInput" class="form-label fw-semibold">Mã Số Sinh Viên (MSSV)</label>
                        <input type="text" class="form-control form-control-custom" id="studentIdInput" name="studentId" placeholder="Ví dụ: HE181234" />
                    </div>
                </div>
                
                <div class="modal-footer border-top-0 pb-4 px-4 gap-2">
                    <button type="button" class="btn btn-outline-secondary py-2 px-3 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary-custom py-2 px-4 shadow-sm">
                        <i class="fa-solid fa-circle-check me-1"></i> Thêm Vào Danh Sách
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Import Excel -->
<div class="modal fade" id="importExcelModal" tabindex="-1" aria-labelledby="importExcelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: #ffffff; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark" id="importExcelModalLabel">
                    <i class="fa-solid fa-file-excel text-success me-2"></i>Import Whitelist Từ File Excel
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <form asp-action="ImportWhitelist" method="post" enctype="multipart/form-data">
                <div class="modal-body px-4 py-3">
                    <div class="mb-4 text-slate-600" style="font-size: 0.92rem; line-height: 1.6;">
                        <p class="fw-semibold mb-2 text-dark"><i class="fa-solid fa-circle-info text-primary me-1"></i> Định dạng file Excel mẫu:</p>
                        <ul class="ps-3 mb-3">
                            <li>File Excel (.xlsx hoặc .xls).</li>
                            <li>Bắt buộc phải có cột chứa tiêu đề <strong>"Email"</strong>.</li>
                            <li>Có thể bổ sung cột <strong>"Họ và tên"</strong> (FullName) và <strong>"MSSV"</strong> (StudentId).</li>
                            <li>Tên cột có thể dùng cả tiếng Anh lẫn tiếng Việt (không phân biệt hoa thường).</li>
                        </ul>
                        
                        <div class="p-3 bg-light rounded-3 border mb-3">
                            <table class="table table-sm table-bordered text-center mb-0" style="font-size: 0.8rem;">
                                <thead>
                                    <tr class="table-secondary">
                                        <th>Họ và tên</th>
                                        <th>MSSV</th>
                                        <th>Email</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Nguyễn Văn A</td>
                                        <td>HE180001</td>
                                        <td>anvhe180001@gmail.com</td>
                                    </tr>
                                    <tr>
                                        <td>Trần Thị B</td>
                                        <td>HE180002</td>
                                        <td>btthe180002@gmail.com</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="excelFile" class="form-label fw-semibold">Chọn file Excel</label>
                        <div class="upload-dropzone p-4 border-dashed rounded-3 text-center" style="border: 2px dashed #cbd5e1; background: #fafafa; cursor: pointer;">
                            <input type="file" id="excelFile" name="file" accept=".xlsx, .xls" class="d-none" required />
                            <div class="upload-icon mb-2">
                                <i class="fa-solid fa-cloud-arrow-up fa-2x text-muted"></i>
                            </div>
                            <p class="mb-1 fw-semibold text-dark" id="fileNameDisplay">Nhấp để chọn file hoặc kéo thả vào đây</p>
                            <p class="text-muted mb-0" style="font-size: 0.8rem;">Chấp nhận file .xlsx hoặc .xls</p>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer border-top-0 pb-4 px-4 gap-2">
                    <button type="button" class="btn btn-outline-secondary py-2 px-3 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success py-2 px-4 shadow-sm" style="background: #16a34a; border: none; font-weight: 600; border-radius: 10px;">
                        <i class="fa-solid fa-cloud-arrow-up me-1"></i> Bắt đầu Tải Lên
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-primary-custom {
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        border: none;
        color: white;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.2s ease;
    }
    
    .btn-primary-custom:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(79, 70, 229, 0.25);
        color: white;
    }

    .btn-outline-primary-custom {
        border: 1.5px solid #4f46e5;
        background: transparent;
        color: #4f46e5;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.2s ease;
    }

    .btn-outline-primary-custom:hover {
        background: #e0e7ff;
        color: #4338ca;
        border-color: #4338ca;
    }
    
    .form-control-custom {
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        padding: 10px 16px;
        font-size: 0.95rem;
        transition: all 0.2s;
    }

    .form-control-custom:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        outline: none;
    }

    .border-dashed:hover {
        border-color: #6366f1 !important;
        background: #f5f3ff !important;
    }

    .upload-dropzone:hover .upload-icon i {
        color: #6366f1 !important;
    }

    .btn-action-delete {
        background: #fef2f2;
        border: 1px solid #fee2e2;
        color: #ef4444;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .btn-action-delete:hover {
        background: #dc2626;
        color: white;
        border-color: #dc2626;
        transform: scale(1.05);
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Thiết lập tìm kiếm trực quan trên client
            const searchInput = document.getElementById('searchInput');
            const whitelistTable = document.getElementById('whitelistTable');
            const tableRows = whitelistTable.querySelectorAll('tbody tr');

            searchInput.addEventListener('input', function() {
                const query = this.value.trim().toLowerCase();

                tableRows.forEach(row => {
                    if (row.cells.length < 3) return; // Bỏ qua tr rỗng khi không có email nào

                    const fullName = row.cells[0].textContent.toLowerCase();
                    const studentId = row.cells[1].textContent.toLowerCase();
                    const email = row.cells[2].textContent.toLowerCase();

                    if (fullName.includes(query) || studentId.includes(query) || email.includes(query)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });

            // Giao diện Drag and Drop cho việc tải file
            const dropzone = document.querySelector('.upload-dropzone');
            const fileInput = document.getElementById('excelFile');
            const display = document.getElementById('fileNameDisplay');

            dropzone.addEventListener('click', () => fileInput.click());

            fileInput.addEventListener('change', function() {
                if (this.files.length > 0) {
                    display.textContent = this.files[0].name;
                    display.classList.add('text-indigo');
                }
            });

            // Ngăn chặn hành vi mặc định kéo thả ngoài trình duyệt
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                dropzone.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            // Hiển thị trạng thái kéo thả file
            ['dragenter', 'dragover'].forEach(eventName => {
                dropzone.addEventListener(eventName, () => {
                    dropzone.style.borderColor = '#6366f1';
                    dropzone.style.backgroundColor = '#f5f3ff';
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                dropzone.addEventListener(eventName, () => {
                    dropzone.style.borderColor = '#cbd5e1';
                    dropzone.style.backgroundColor = '#fafafa';
                }, false);
            });

            // Xử lý khi thả file vào vùng dropzone
            dropzone.addEventListener('drop', function(e) {
                const dt = e.dataTransfer;
                const files = dt.files;

                if (files.length > 0) {
                    fileInput.files = files;
                    display.textContent = files[0].name;
                    display.classList.add('text-indigo');
                }
            });
        });
    </script>
}
