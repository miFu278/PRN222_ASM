@{
    ViewData["Title"] = "Thanh toán mô phỏng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fa-solid fa-credit-card fa-3x mb-3" style="color: #8b5cf6;"></i>
                        <h3 class="fw-bold">Thanh Toán An Toàn</h3>
                        <p class="text-muted">Bạn đang nâng cấp lên gói <b>Premium (199.000đ/tháng)</b></p>
                    </div>

                    <div class="alert alert-warning text-center rounded-3 border-0" style="background: rgba(245, 158, 11, 0.1); color: #b45309;">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i> Đây là môi trường thử nghiệm. Bạn có thể nhập số thẻ bất kỳ để thanh toán.
                    </div>

                    <form asp-action="ProcessPayment" method="post">
                        <div class="mb-4 mt-4">
                            <label class="form-label fw-semibold">Tên in trên thẻ</label>
                            <input type="text" class="form-control px-3 py-2" placeholder="NGUYEN VAN A" required style="border-radius: 10px;" />
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Số thẻ tín dụng</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px;">
                                    <i class="fa-brands fa-cc-visa text-muted fs-5"></i>
                                </span>
                                <input type="text" class="form-control border-start-0 px-2 py-2" placeholder="4123 4567 8901 2345" required pattern="\d{4}\s?\d{4}\s?\d{4}\s?\d{4}" title="Vui lòng nhập 16 số thẻ" style="border-radius: 0 10px 10px 0;" />
                            </div>
                        </div>
                        
                        <div class="row mb-5">
                            <div class="col-6">
                                <label class="form-label fw-semibold">Ngày hết hạn</label>
                                <input type="text" class="form-control px-3 py-2" placeholder="MM/YY" required pattern="\d{2}/\d{2}" style="border-radius: 10px;" />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold">CVV/CVC</label>
                                <input type="password" class="form-control px-3 py-2" placeholder="123" required pattern="\d{3,4}" style="border-radius: 10px;" />
                            </div>
                        </div>

                        <button type="submit" class="btn w-100 py-3 fw-bold text-white fs-5" style="background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%); border-radius: 12px; transition: transform 0.2s;">
                            <i class="fa-solid fa-lock me-2"></i> Xác nhận thanh toán 199.000đ
                        </button>
                        
                        <div class="text-center mt-3">
                            <a asp-action="Index" class="text-muted text-decoration-none"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại bảng giá</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
