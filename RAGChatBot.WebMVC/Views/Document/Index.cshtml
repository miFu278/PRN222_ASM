@model IEnumerable<RAGChatBot.Application.DTOs.DocumentDto>
@{
    ViewData["Title"] = "Quản lý Tài liệu thô";
    var activeCourse = ViewBag.CourseCode as string ?? "CS101";
    var userTier = User.FindFirst("SubscriptionTier")?.Value ?? "Free";
    var maxUploadSize = userTier == "Premium" ? "50 MB" : "5 MB";
    var isLecturerOrAdmin = User.IsInRole("Lecturer") || User.IsInRole("Admin");
    var isLecturer = User.IsInRole("Lecturer");
    var canUpload = ViewBag.IsSubjectLeader == true;
}

<div class="row">
    <div class="col-lg-12 mb-4">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div>
                <h2 class="fw-bold" style="background: linear-gradient(to right, #0ea5e9, #0284c7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    <i class="fa-solid fa-folder-open me-2"></i>Quản Lý Tài Liệu Thô
                </h2>
                <p class="text-muted mb-0">Tải lên các tài liệu giảng dạy thô để cung cấp làm tài liệu tham khảo cho hệ thống RAG.</p>
            </div>
            
            <!-- Course name can be displayed here later if passed -->
            <div>
                <a asp-controller="Course" asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-3">
                    <i class="fa-solid fa-arrow-left me-1"></i> Quay lại Môn học
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Hiển thị thông báo trạng thái -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 mb-4 animate-fade-in" role="alert" style="background: rgba(34, 197, 94, 0.15); border: 1px solid rgba(34, 197, 94, 0.3) !important; color: #86efac;">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 mb-4 animate-fade-in" role="alert" style="background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3) !important; color: #fca5a5;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    @if (canUpload)
    {
        <!-- Cột bên trái: Form Tải lên tài liệu -->
        <div class="col-xl-4 col-lg-5">
            <div class="card-custom">
                <h4 class="fw-bold mb-4 text-dark">
                    <i class="fa-solid fa-cloud-arrow-up me-2 text-indigo"></i>Tải Lên Tài Liệu
                </h4>
                
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="courseCodeInput" class="form-label">Mã Môn Học</label>
                        <input type="text" class="form-control form-control-custom" id="courseCodeInput" name="courseCode" value="@activeCourse" readonly />
                    </div>
                    
                    <div class="mb-3">
                        <label for="chapterInput" class="form-label">Chương / Bài học</label>
                        <input type="text" class="form-control form-control-custom" id="chapterInput" name="chapter" placeholder="Ví dụ: Chương 1, Tuần 2..." required />
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label">Tệp tin tài liệu (.pdf, .docx)</label>
                        <div class="file-upload-wrapper text-center">
                            <input type="file" id="file" name="file" class="file-upload-input" accept=".pdf,.docx" required />
                            <div class="file-upload-design py-4">
                                <i class="fa-regular fa-file-pdf fa-3x mb-3 text-indigo"></i>
                                <div class="fw-bold text-dark">Bấm vào đây để chọn tệp tin</div>
                                <small class="text-muted d-block mt-1">Chấp nhận tối đa @maxUploadSize</small>
                                <span class="file-chosen text-indigo mt-2 d-block fw-semibold" style="display:none !important;">Chưa có file nào được chọn</span>
                            </div>
                        </div>
                    </div>

                    <div class="tier-info-card p-3 mb-4 rounded-3 d-flex align-items-center justify-content-between">
                        <div>
                            <span class="d-block fw-bold text-dark" style="font-size: 0.95rem;">Gói của bạn: @userTier</span>
                            <span class="text-muted" style="font-size: 0.8rem;">Hạn mức tải lên file</span>
                        </div>
                        <div class="text-end">
                            <span class="badge rounded-pill bg-indigo text-white mb-1 d-inline-block px-3 py-1">@userTier</span>
                            <span class="d-block fw-bold text-indigo fs-5">Tối đa @maxUploadSize</span>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary-custom w-100 py-3">
                        <i class="fa-solid fa-circle-arrow-up me-2"></i> Bắt đầu Tải Lên
                    </button>
                </form>
            </div>
        </div>
    }
    
    <!-- Cột bên phải: Danh sách tài liệu hiện có -->
    <div class="@(canUpload ? "col-xl-8 col-lg-7" : "col-12")">
        <div class="card-custom">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold text-dark mb-0">
                    <i class="fa-solid fa-list-check me-2 text-indigo"></i>Danh sách Tài liệu
                </h4>
                <span class="badge bg-secondary rounded-pill px-3 py-2" style="background: rgba(255,255,255,0.05) !important; border: 1px solid var(--border-color);">
                    @Model.Count() tệp tin
                </span>
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-box-open fa-3x text-muted mb-3" style="color: #4b5563 !important;"></i>
                    <h5 class="text-dark">Chưa có tài liệu nào cho môn học này!</h5>
                    <p class="text-muted">Chọn môn học khác trên thanh bộ lọc hoặc tải lên file mới ở bảng bên trái.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Tên Tài Liệu</th>
                                <th>Chương</th>
                                <th>Dung Lượng</th>
                                <th>Thời Gian</th>
                                <th>AI Trạng Thái</th>
                                <th class="text-end">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Model)
                            {
                                var sizeFormatted = doc.FileSize > 1024 * 1024
                                    ? $"{(doc.FileSize / 1024.0 / 1024.0):F2} MB"
                                    : $"{(doc.FileSize / 1024.0):F1} KB";
                                    
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            @if (doc.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <i class="fa-solid fa-file-pdf text-danger fs-5"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-file-word text-primary fs-5"></i>
                                            }
                                            <div class="d-flex flex-column">
                                                <span class="fw-semibold text-dark text-truncate d-inline-block" style="max-width: 250px;" title="@doc.FileName">
                                                    @doc.FileName
                                                </span>
                                                <small class="text-muted" style="font-size: 0.75rem;">
                                                    <i class="fa-regular fa-user me-0.5"></i> @(string.IsNullOrEmpty(doc.UploaderName) ? "Hệ thống" : doc.UploaderName)
                                                </small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge border border-secondary text-secondary px-2 py-1" style="background: rgba(0,0,0,0.05) !important;">
                                            @doc.Chapter
                                        </span>
                                    </td>
                                    <td class="text-muted">@sizeFormatted</td>
                                    <td class="text-muted" style="font-size:0.85rem">
                                        @doc.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="status-cell" data-id="@doc.Id" data-processed="@doc.IsProcessed.ToString().ToLower()" data-approved="@doc.IsApproved.ToString().ToLower()">
                                        @if (!doc.IsApproved)
                                        {
                                            <span class="status-badge bg-warning-subtle text-warning border border-warning-subtle" style="padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 500;">
                                                <i class="fa-solid fa-clock me-1"></i> Chờ duyệt
                                            </span>
                                        }
                                        else if (doc.IsProcessed)
                                        {
                                            <span class="status-badge status-processed">
                                                <i class="fa-solid fa-circle-check me-1"></i> Đã xử lý
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-pending">
                                                <i class="fa-solid fa-spinner fa-spin me-1"></i> Đang xử lý AI
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2 align-items-center">
                                            @if (!doc.IsApproved && ViewBag.IsSubjectLeader == true)
                                            {
                                                <form asp-action="Approve" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                    <input type="hidden" name="courseCode" value="@doc.CourseCode" />
                                                    <button type="submit" class="btn btn-action-approve" title="Phê duyệt tài liệu" style="background: #ecfdf5; border: 1px solid #d1fae5; color: #10b981; width: 32px; height: 32px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; transition: all 0.2s;">
                                                        <i class="fa-solid fa-check"></i>
                                                    </button>
                                                </form>
                                            }
                                            @if (doc.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a href="@doc.StoragePath" target="_blank" class="btn btn-action-view" title="Xem trực tiếp (PDF)">
                                                    <i class="fa-regular fa-eye"></i>
                                                </a>
                                            }
                                            else if (doc.FileName.EndsWith(".docx", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <a href="https://view.officeapps.live.com/op/view.aspx?src=@Uri.EscapeDataString(doc.StoragePath)" target="_blank" class="btn btn-action-view" title="Xem trực tiếp (Word)">
                                                    <i class="fa-regular fa-eye"></i>
                                                </a>
                                            }
                                            <button type="button" class="btn btn-action-view btn-view-chunks" data-id="@doc.Id" data-filename="@doc.FileName" title="Xem các phân đoạn AI (Chunks)" style="@(doc.IsProcessed ? "" : "display: none !important;")">
                                                <i class="fa-solid fa-puzzle-piece"></i>
                                            </button>
                                            <a href="@doc.StoragePath" target="_blank" class="btn btn-action-view ms-1" title="Tải về">
                                                <i class="fa-solid fa-download"></i>
                                            </a>
                                            @if (ViewBag.IsSubjectLeader == true)
                                            {
                                                <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tài liệu này vĩnh viễn khỏi hệ thống không?');">
                                                    <input type="hidden" name="id" value="@doc.Id" />
                                                    <input type="hidden" name="courseCode" value="@doc.CourseCode" />
                                                    <button type="submit" class="btn btn-action-delete" title="Xóa tài liệu">
                                                        <i class="fa-solid fa-trash-can"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

</div>

<!-- Modal Xem Chunks -->
<div class="modal fade" id="viewChunksModal" tabindex="-1" aria-labelledby="viewChunksModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4" style="background: #ffffff; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-dark" id="viewChunksModalLabel">
                    <i class="fa-solid fa-puzzle-piece text-indigo me-2"></i>Phân Đoạn Tài Liệu (AI Chunks)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <div class="mb-3 text-muted" style="font-size: 0.9rem;">
                    Tài liệu: <strong class="text-indigo modal-filename-display"></strong>
                </div>
                <div class="chunks-container d-flex flex-column gap-3" style="max-height: 50vh; overflow-y: auto; padding-right: 5px;">
                    <!-- Dữ liệu Chunks sẽ được render động ở đây -->
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-spinner fa-spin fa-2x mb-2 text-indigo"></i>
                        <div>Đang tải dữ liệu chunks...</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pb-4 px-4">
                <button type="button" class="btn btn-secondary py-2 px-4 rounded-3" data-bs-dismiss="modal" style="background: #64748b; border: none; font-weight: 500;">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('file').addEventListener('change', function(e) {
            var fileName = e.target.files[0] ? e.target.files[0].name : "Chưa có file nào được chọn";
            var textSpan = document.querySelector('.file-chosen');
            textSpan.textContent = fileName;
            textSpan.style.display = 'block';
            textSpan.style.setProperty('display', 'block', 'important');
        });

        // Xử lý sự kiện xem Chunks
        document.addEventListener('DOMContentLoaded', function() {
            var chunksModalElement = document.getElementById('viewChunksModal');
            var chunksModal = new bootstrap.Modal(chunksModalElement);
            var container = chunksModalElement.querySelector('.chunks-container');
            var filenameDisplay = chunksModalElement.querySelector('.modal-filename-display');

            document.addEventListener('click', function(e) {
                var btn = e.target.closest('.btn-view-chunks');
                if (btn) {
                    var docId = btn.getAttribute('data-id');
                    var filename = btn.getAttribute('data-filename');

                    filenameDisplay.textContent = filename;
                    container.innerHTML = `
                        <div class="text-center py-4 text-muted">
                            <i class="fa-solid fa-spinner fa-spin fa-2x mb-2 text-indigo"></i>
                            <div>Đang tải dữ liệu chunks...</div>
                        </div>
                    `;
                    chunksModal.show();

                    fetch('/Document/GetChunks?id=' + docId)
                        .then(response => {
                            if (!response.ok) throw new Error("Không thể tải dữ liệu chunks.");
                            return response.json();
                        })
                        .then(data => {
                            if (data.length === 0) {
                                container.innerHTML = `<div class="text-center py-4 text-muted">Tài liệu chưa được chia nhỏ hoặc dữ liệu rỗng.</div>`;
                                return;
                            }

                            container.innerHTML = '';
                            data.forEach(function(chunk) {
                                var card = document.createElement('div');
                                card.className = 'card p-3 border-0 rounded-3 shadow-sm';
                                card.style.background = '#f8fafc';
                                card.style.borderLeft = '4px solid #4f46e5';

                                card.innerHTML = `
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="fw-bold text-indigo" style="font-size: 0.9rem;">Phân đoạn #${chunk.chunkIndex + 1}</span>
                                        ${chunk.hasEmbedding ? `
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2 py-1" style="font-size: 0.75rem;">
                                                <i class="fa-solid fa-circle-check me-1"></i> Đã nhúng Vector
                                            </span>
                                        ` : `
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-2 py-1" style="font-size: 0.75rem;">
                                                Chưa có Vector
                                            </span>
                                        `}
                                    </div>
                                    <div class="text-dark" style="font-size: 0.9rem; line-height: 1.6; white-space: pre-wrap; font-family: system-ui, -apple-system, sans-serif;">${chunk.content}</div>
                                `;
                                container.appendChild(card);
                            });
                        })
                        .catch(err => {
                            container.innerHTML = `<div class="text-center py-4 text-danger"><i class="fa-solid fa-circle-exclamation me-1"></i> Lỗi: ${err.message}</div>`;
                        });
                }
            });
        });

        // Tự động cập nhật trạng thái xử lý file (AJAX Polling)
        (function() {
            var activeCourse = '@activeCourse';
            var pollInterval = null;

            function checkFileStatuses() {
                var pendingCells = document.querySelectorAll('.status-cell[data-processed="false"]');
                if (pendingCells.length === 0) {
                    clearInterval(pollInterval);
                    pollInterval = null;
                    return;
                }

                fetch('/Document/GetStatus?courseCode=' + encodeURIComponent(activeCourse))
                    .then(response => response.json())
                    .then(data => {
                        data.forEach(item => {
                            var cell = document.querySelector('.status-cell[data-id="' + item.id + '"]');
                            if (cell && cell.getAttribute('data-processed') === 'false' && item.isProcessed) {
                                // Thay đổi giao diện sang trạng thái "Đã xử lý"
                                cell.setAttribute('data-processed', 'true');
                                cell.innerHTML = `
                                    <span class="status-badge status-processed">
                                        <i class="fa-solid fa-circle-check me-1"></i> Đã xử lý
                                    </span>
                                `;

                                // Đồng thời hiển thị nút xem chunks
                                var chunkBtn = document.querySelector('.btn-view-chunks[data-id="' + item.id + '"]');
                                if (chunkBtn) {
                                    chunkBtn.style.setProperty('display', 'inline-flex', 'important');
                                }
                            }
                        });

                        // Nếu không còn file nào chờ xử lý thì tắt interval
                        var remainingPending = document.querySelectorAll('.status-cell[data-processed="false"]');
                        if (remainingPending.length === 0) {
                            clearInterval(pollInterval);
                            pollInterval = null;
                        }
                    })
                    .catch(err => console.error("Lỗi cập nhật trạng thái tài liệu: ", err));
            }

            // Kích hoạt Polling sau mỗi 3 giây nếu có file đang chờ xử lý
            var hasPending = document.querySelectorAll('.status-cell[data-processed="false"]').length > 0;
            if (hasPending) {
                pollInterval = setInterval(checkFileStatuses, 3000);
            }
        })();
    </script>
}
