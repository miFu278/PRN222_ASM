@{
    ViewData["Title"] = "Trợ Lý";
}

<style>
    .zen-chat-container {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 150px);
        justify-content: center;
        max-width: 1000px;
        margin: 0 auto;
        padding-top: 50px;
    }

    .zen-hero {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        margin-bottom: 80px;
        gap: 40px;
    }

    .zen-hero-title {
        flex: 1;
        min-width: 300px;
        font-size: 4.5rem;
        font-weight: 300;
        line-height: 1.1;
        letter-spacing: -0.02em;
        position: relative;
    }

    .zen-hero-title span {
        display: block;
    }
    
    .zen-hero-title .text-accent {
        font-size: 1rem;
        font-family: var(--font-sans);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .zen-hero-desc {
        flex: 1;
        min-width: 300px;
        padding-top: 20px;
        font-size: 1.1rem;
        color: var(--text-muted) !important;
        position: relative;
    }

    .zen-hero-desc::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 40px;
        height: 1px;
        background-color: var(--text-sumi);
    }

    .zen-input-area {
        position: relative;
        margin-bottom: 60px;
    }

    .zen-input-wrapper {
        display: flex;
        align-items: flex-end;
        gap: 20px;
    }

    .zen-send-btn {
        background: transparent;
        border: none;
        color: var(--text-sumi);
        font-size: 1.2rem;
        cursor: not-allowed;
        padding-bottom: 12px;
        opacity: 0.5;
        transition: opacity 0.3s;
    }
    .zen-send-btn:hover { opacity: 1; }

    .zen-suggestions {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .zen-suggestion-item {
        font-size: 0.95rem;
        color: var(--text-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: color 0.4s ease;
        cursor: not-allowed;
    }

    .zen-suggestion-item::before {
        content: '';
        display: inline-block;
        width: 15px;
        height: 1px;
        background-color: var(--border-light);
        margin-right: 15px;
        transition: width 0.4s ease, background-color 0.4s ease;
    }

    .zen-suggestion-item:hover {
        color: var(--text-sumi);
    }
    .zen-suggestion-item:hover::before {
        width: 30px;
        background-color: var(--accent-shu);
    }

    .gsap-reveal-text {
        clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
    }
    .gsap-reveal-inner {
        transform: translateY(100%);
        display: inline-block;
    }
</style>

<div class="zen-chat-container">
    <div class="zen-hero">
        <div class="zen-hero-title">
            <div class="text-accent gsap-fade-up">Giai đoạn thử nghiệm</div>
            <h1 class="font-serif m-0">
                <span class="gsap-reveal-text"><span class="gsap-reveal-inner">Trợ lý</span></span>
                <span class="gsap-reveal-text"><span class="gsap-reveal-inner">Học thuật</span></span>
            </h1>
        </div>
        <div class="zen-hero-desc gsap-fade-up" style="animation-delay: 0.2s;">
            <p>
                RAG ChatBot sử dụng dữ liệu từ kho học liệu để hỗ trợ bạn tóm tắt, giải thích khái niệm và tạo đề cương ôn tập. 
                Sự tĩnh lặng tạo nên sức mạnh của trí tuệ.
            </p>
        </div>
    </div>

    <div class="zen-input-area gsap-fade-up" style="animation-delay: 0.4s;">
        <div class="zen-input-wrapper">
            <input type="text" class="input-zen" placeholder="Viết câu hỏi của bạn tại đây..." disabled>
            <button class="zen-send-btn" disabled><i class="fa-solid fa-arrow-right"></i></button>
        </div>
        <div class="mt-3 text-muted" style="font-size: 0.8rem; font-weight: 300;">
            Tính năng Chat đang được bảo trì để đạt sự hoàn hảo.
        </div>
    </div>

    <div class="zen-suggestions gsap-fade-up" style="animation-delay: 0.6s;">
        <span class="text-muted mb-2" style="font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">Gợi ý câu hỏi</span>
        <a href="#" class="zen-suggestion-item">Tóm tắt nội dung bài giảng Chương 1</a>
        <a href="#" class="zen-suggestion-item">Giải thích khái niệm đa hình trong OOP</a>
        <a href="#" class="zen-suggestion-item">Tạo đề cương ôn tập môn học</a>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Elegant slow reveals
            gsap.to(".gsap-reveal-inner", {
                y: "0%",
                duration: 1.5,
                stagger: 0.2,
                ease: "power4.out",
                delay: 0.2
            });

            gsap.to(".gsap-fade-up", {
                y: 0,
                opacity: 1,
                duration: 1.5,
                stagger: 0.2,
                ease: "power3.out",
                delay: 0.5
            });
        });
    </script>
}
