@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<!-- Top Header -->
<header class="zen-header">
    <a href="/" class="zen-brand">
        <span class="hanko-seal">印</span>
        RAG ChatBot
    </a>
    <button class="zen-menu-trigger" @onclick="ToggleMenu">
        Menu
    </button>
</header>

<!-- Main Content -->
<main class="zen-main">
    @Body
</main>

<!-- Full-screen Overlay Menu -->
<div class="zen-overlay @(isMenuOpen ? "active" : "")">
    <button class="overlay-close" @onclick="ToggleMenu">&times;</button>
    
    <AuthorizeView>
        <Authorized>
            @{
                var userClaims = context.User;
                var name = userClaims.Identity?.Name ?? "User";
                var role = userClaims.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Student";
                var tier = userClaims.FindFirst("SubscriptionTier")?.Value ?? "Free";
            }
            <div style="position: absolute; top: 40px; left: 60px; font-family: var(--font-sans); font-size: 0.9rem; color: var(--text-muted); text-align: left;">
                Xin chào, <span style="color: var(--text-sumi); font-weight: 500;">@name</span><br>
                <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">@role &bull; @tier</span>
            </div>

            @if (role == "Admin")
            {
                <a href="/admin/users" class="zen-menu-item" @onclick="CloseMenu">Tài Khoản</a>
                <a href="/admin/whitelist" class="zen-menu-item" @onclick="CloseMenu">Whitelist</a>
            }
            else
            {
                <a href="/" class="zen-menu-item" @onclick="CloseMenu">Trò Chuyện</a>
            }
            
            <a href="/courses" class="zen-menu-item" @onclick="CloseMenu">Học Liệu</a>
            
            @if (role != "Admin" && tier == "Free")
            {
                <a href="/subscription" class="zen-menu-item" style="color: var(--accent-shu);" @onclick="CloseMenu">Nâng cấp Premium</a>
            }
            
            <form action="Account/Logout" method="post" style="margin-top: 40px;">
                <AntiforgeryToken />
                <button type="submit" class="btn-zen" style="font-size: 1.1rem; cursor: pointer;">
                    Đăng xuất
                </button>
            </form>
        </Authorized>
        <NotAuthorized>
            <a href="/" class="zen-menu-item" @onclick="CloseMenu">Trang chủ</a>
            <a href="/Account/Login" class="zen-menu-item" style="font-size: 2rem; margin-top: 40px;" @onclick="CloseMenu">Đăng nhập</a>
        </NotAuthorized>
    </AuthorizeView>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Đã xảy ra lỗi không mong muốn.
    <a href="." class="reload">Tải lại</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool isMenuOpen = false;

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }
}
