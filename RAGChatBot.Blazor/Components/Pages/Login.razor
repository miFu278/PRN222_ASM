@page "/Account/Login"
@layout Layout.MainLayout
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Đăng nhập - RAG ChatBot</PageTitle>

<div class="row justify-content-center align-items-center gsap-fade-up" style="min-height: calc(100vh - 180px);">
    <div class="col-md-5 col-sm-8 px-4" style="background: transparent;">
        <div class="text-center mb-5">
            <span class="hanko-seal" style="width: 48px; height: 48px; font-size: 1.5rem; margin-right: 0; box-shadow: none;">印</span>
            <h2 class="font-serif mt-4 mb-2" style="font-size: 2.5rem; font-weight: 300;">RAG ChatBot</h2>
            <p class="text-muted small" style="letter-spacing: 0.15em; text-transform: uppercase; font-size: 0.75rem;">Hệ thống trợ lý tĩnh lặng</p>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="text-center mb-4" style="color: var(--accent-shu); font-size: 0.9rem;">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> @Error
            </div>
        }

        <!-- Traditional HTML form posting directly to Controller to handle cookies -->
        <form action="Account/PerformLogin?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "")" method="post" class="mb-5">
            <AntiforgeryToken />
            
            <div class="mb-4">
                <input type="text" id="username" name="Username" class="input-zen text-center" placeholder="Nhập email hoặc tên tài khoản" required autocomplete="username" style="font-size: 1.2rem;" />
            </div>

            <div class="mb-5">
                <input type="password" id="password" name="Password" class="input-zen text-center" placeholder="Mật khẩu" required autocomplete="current-password" style="font-size: 1.2rem;" />
            </div>

            <div class="text-center">
                <button type="submit" class="btn-zen magnetic-btn px-5 py-3" style="width: 100%; max-width: 300px;">
                    Đăng nhập
                </button>
            </div>
        </form>

        <div class="position-relative mb-5 text-center">
            <hr style="border-top: 1px solid var(--border-light); margin: 0;" />
            <span class="bg-washi px-3 text-muted small" style="position: absolute; top: -10px; left: 50%; transform: translateX(-50%); font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.75rem;">Hoặc</span>
        </div>

        <!-- Google OAuth Authentication -->
        <form action="Account/ExternalLogin?returnUrl=@Uri.EscapeDataString(ReturnUrl ?? "")" method="post" class="text-center">
            <AntiforgeryToken />
            <button type="submit" class="btn-zen danger magnetic-btn" style="width: 100%; max-width: 300px; border: none; border-bottom: 1px solid var(--accent-shu);">
                Đăng nhập bằng Google
            </button>
        </form>

        <div class="text-center mt-5 text-muted small" style="font-weight: 300; opacity: 0.6;">
            Chỉ dành cho cán bộ giảng viên và sinh viên có trong whitelist.
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(ReturnUrl))
        {
            ReturnUrl = "/";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");
        }
    }
}
