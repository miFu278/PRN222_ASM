@page "/admin/whitelist"
@attribute [Authorize(Roles = "Admin")]
@inject IWhitelistService WhitelistService
@inject IJSRuntime JS
@inject ILogger<Whitelist> Logger

<PageTitle>Whitelist Emails - Admin</PageTitle>

<div class="zen-container py-4 gsap-fade-up">
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Hệ thống quản trị</div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">Danh sách Whitelist</h2>
        </div>
        <div class="zen-hero-desc">
            <p class="text-muted m-0" style="font-size: 1.1rem; line-height: 1.8;">
                Các email nằm trong danh sách này sẽ được phép đăng ký và truy cập vào hệ thống khi sử dụng phương thức đăng nhập bằng Google OAuth.
            </p>
        </div>
    </div>

    <div class="row mt-5">
        <!-- Add / Import Panels (Unboxed, Zen) -->
        <div class="col-lg-4 mb-5 pe-lg-5 zen-list-item">
            <!-- Manual Add Form -->
            <div class="mb-5">
                <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Thêm thủ công</h4>
                <div class="mb-3 mt-2">
                    <input type="email" class="form-inline-zen w-100" @bind="newEmail" placeholder="Địa chỉ Email (*)" required />
                </div>
                <div class="mb-3">
                    <input type="text" class="form-inline-zen w-100" @bind="newFullName" placeholder="Họ và tên (Tùy chọn)" />
                </div>
                <div class="mb-4">
                    <input type="text" class="form-inline-zen w-100" @bind="newStudentId" placeholder="Mã số sinh viên (Tùy chọn)" />
                </div>
                <button class="btn-zen magnetic-btn w-100" @onclick="AddEmail" disabled="@(string.IsNullOrWhiteSpace(newEmail))">
                    Thêm vào danh sách
                </button>
            </div>

            <!-- Excel Import Form -->
            <div>
                <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Nhập từ Excel</h4>
                <div class="mb-4 mt-2">
                    <label class="form-label text-muted small text-uppercase tracking-wider">Chọn tệp (.xlsx):</label>
                    <InputFile OnChange="HandleExcelFileSelected" class="form-inline-zen w-100" accept=".xlsx" style="padding: 0 !important; cursor: pointer;" />
                </div>
                <button class="btn-zen danger magnetic-btn w-100" @onclick="ImportExcel" disabled="@(excelFile == null || isImporting)">
                    @if (isImporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Đang xử lý...</span>
                    }
                    else
                    {
                        <span>Tải danh sách Excel</span>
                    }
                </button>
            </div>
        </div>

        <!-- Whitelist Table -->
        <div class="col-lg-8 mb-5 zen-list-item">
            <!-- Search & Count Bar -->
            <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
                <div style="flex: 1; max-width: 400px;">
                    <input type="text" class="form-inline-zen w-100" style="font-size: 1.1rem;" placeholder="Tìm kiếm theo email hoặc MSSV..." @bind="searchKeyword" @bind:event="oninput" @onkeyup="FilterWhitelist" />
                </div>
                <div class="text-muted small" style="letter-spacing: 0.1em; text-transform: uppercase;">
                    Số lượng: <strong>@(filteredEmails?.Count() ?? 0)</strong>
                </div>
            </div>

            <div class="table-responsive mt-2">
                <table class="table-zen">
                    <thead>
                        <tr>
                            <th style="width: 40%;">Tài khoản (Email)</th>
                            <th style="width: 25%;">Họ và tên</th>
                            <th style="width: 20%;">MSSV</th>
                            <th style="width: 15%; text-align: right;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredEmails == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                </td>
                            </tr>
                        }
                        else if (!filteredEmails.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <span class="hanko-seal mb-2" style="opacity: 0.5;">無</span>
                                    <div>Trống rỗng.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in filteredEmails)
                            {
                                <tr>
                                    <td class="fw-bold" style="font-size: 1.05rem;">@item.Email</td>
                                    <td class="text-muted">@(item.FullName ?? "-")</td>
                                    <td class="text-muted">@(item.StudentId ?? "-")</td>
                                    <td style="text-align: right;">
                                        <button class="zen-action-link danger" @onclick="() => DeleteEmail(item)" title="Xóa">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private IEnumerable<WhitelistEmailDto>? allEmails;
    private IEnumerable<WhitelistEmailDto>? filteredEmails;
    private string searchKeyword = "";

    // Manual Form Inputs
    private string newEmail = "";
    private string newFullName = "";
    private string newStudentId = "";

    // Excel Upload
    private IBrowserFile? excelFile;
    private bool isImporting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");
        }
    }

    private async Task ShowToast(string message, string type)
    {
        await JS.InvokeVoidAsync("zenInteract.showToast", message, type);
    }

    private async Task LoadData()
    {
        try
        {
            allEmails = await WhitelistService.GetAllAsync();
            filteredEmails = allEmails;
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi tải Whitelist: {ex.Message}", "error");
        }
    }

    private void FilterWhitelist()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            filteredEmails = allEmails;
        }
        else
        {
            var kw = searchKeyword.Trim().ToLower();
            filteredEmails = allEmails?.Where(e => 
                e.Email.ToLower().Contains(kw) || 
                (e.FullName != null && e.FullName.ToLower().Contains(kw)) ||
                (e.StudentId != null && e.StudentId.ToLower().Contains(kw))
            ).ToList();
        }
    }

    private async Task AddEmail()
    {
        if (string.IsNullOrWhiteSpace(newEmail)) return;

        try
        {
            await WhitelistService.AddAsync(newEmail.Trim(), newFullName.Trim(), newStudentId.Trim());
            await ShowToast($"Đã cấp quyền truy cập cho {newEmail}", "success");
            
            newEmail = "";
            newFullName = "";
            newStudentId = "";
            
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }

    private void HandleExcelFileSelected(InputFileChangeEventArgs e)
    {
        excelFile = e.File;
    }

    private async Task ImportExcel()
    {
        if (excelFile == null) return;

        isImporting = true;
        StateHasChanged();

        try
        {
            using var fileStream = excelFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new System.IO.MemoryStream();
            await fileStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            int count = await WhitelistService.ImportFromExcelAsync(memoryStream);
            await ShowToast($"Đã nhập {count} tài khoản từ Excel", "success");
            
            excelFile = null;
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi nhập Excel: {ex.Message}", "error");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private async Task DeleteEmail(WhitelistEmailDto item)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Thu hồi quyền truy cập của '{item.Email}'?");
        if (!confirmed) return;

        try
        {
            await WhitelistService.DeleteAsync(item.Id);
            await ShowToast($"Đã xóa '{item.Email}' khỏi danh sách", "success");
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi xóa: {ex.Message}", "error");
        }
    }
}
