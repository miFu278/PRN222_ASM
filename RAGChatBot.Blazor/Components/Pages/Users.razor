@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject IAuthService AuthService
@inject IJSRuntime JS
@inject ILogger<Users> Logger

<PageTitle>Quản Lý Tài Khoản - Admin</PageTitle>

<div class="zen-container py-4">
    <div class="zen-hero mb-4">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Hệ thống quản trị</div>
            <h2 class="font-serif m-0">Danh sách Tài Khoản</h2>
        </div>
        <div class="zen-hero-desc">
            <p class="text-muted m-0">
                Xem và quản lý thông tin các tài khoản trong hệ thống bao gồm Giảng viên, Sinh viên và Quản trị viên. Bạn có thể cấp quyền nhanh, đổi gói dịch vụ hoặc xóa tài khoản.
            </p>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 0; font-size: 0.95rem; background-color: rgba(40, 167, 69, 0.05); border-color: rgba(40, 167, 69, 0.2); color: #28a745;">
            <i class="fa-solid fa-circle-check me-2"></i> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 0; font-size: 0.95rem; background-color: rgba(191, 42, 35, 0.05); border-color: rgba(191, 42, 35, 0.2); color: var(--accent-shu);">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="row">
        <!-- Create Account Panels -->
        <div class="col-lg-4 mb-4">
            <!-- Manual Create Form -->
            <div class="p-4 border border-light mb-4" style="background-color: rgba(255, 255, 255, 0.8);">
                <h4 class="font-serif mb-3">Tạo tài khoản mới</h4>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Địa chỉ Email:</label>
                    <input type="email" class="form-control" @bind="newUsername" placeholder="Tên tài khoản (Email)..." required />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Họ và tên:</label>
                    <input type="text" class="form-control" @bind="newFullName" placeholder="Nhập họ và tên..." required />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Mật khẩu:</label>
                    <input type="password" class="form-control" @bind="newPassword" placeholder="Nhập mật khẩu ban đầu..." required />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Vai trò:</label>
                    <select class="form-select" @bind="newRole">
                        <option value="Student">Student (Sinh viên)</option>
                        <option value="Lecturer">Lecturer (Giảng viên)</option>
                        <option value="Admin">Admin (Quản trị viên)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Gói dịch vụ:</label>
                    <select class="form-select" @bind="newTier">
                        <option value="Free">Free (Mặc định)</option>
                        <option value="Premium">Premium</option>
                    </select>
                </div>
                <button class="btn-zen w-100 mt-2" @onclick="CreateUser" disabled="@(string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(newFullName))">
                    <i class="fa-solid fa-plus me-1"></i> Đăng ký tài khoản
                </button>
            </div>

            <!-- Import Users Form -->
            <div class="p-4 border border-light" style="background-color: rgba(255, 255, 255, 0.8);">
                <h4 class="font-serif mb-3">Nhập danh sách từ Excel</h4>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Mật khẩu mặc định:</label>
                    <input type="text" class="form-control" @bind="defaultPassword" placeholder="Mật khẩu nếu file trống..." />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small text-uppercase fw-bold">Chọn tệp Excel:</label>
                    <InputFile OnChange="HandleExcelFileSelected" class="form-control" accept=".xlsx,.xls" />
                </div>
                <button class="btn-zen w-100 mt-2 danger" @onclick="ImportUsers" disabled="@(excelFile == null || isImporting)">
                    @if (isImporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Đang nhập dữ liệu...</span>
                    }
                    else
                    {
                        <span><i class="fa-solid fa-file-import me-1"></i> Nhập từ Excel</span>
                    }
                </button>
            </div>
        </div>

        <!-- Users Table -->
        <div class="col-lg-8 mb-4">
            <!-- Search & Count Bar -->
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                <div style="flex: 1; max-width: 350px;">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0 border-bottom border-light" style="border-radius: 0;"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" class="form-control border-0 border-bottom border-light" style="border-radius: 0; box-shadow: none;" placeholder="Tìm theo tên hoặc email..." @bind="searchKeyword" @bind:event="oninput" @onkeyup="FilterUsers" />
                    </div>
                </div>
                <div class="text-muted small">
                    Tổng số: <strong>@(filteredUsers?.Count() ?? 0)</strong> tài khoản
                </div>
            </div>

            <div class="table-responsive">
                <table class="table-zen">
                    <thead>
                        <tr>
                            <th style="width: 35%;">Họ Tên / Email</th>
                            <th style="width: 20%;">Vai trò</th>
                            <th style="width: 25%;">Gói dịch vụ</th>
                            <th style="width: 20%; text-align: right; padding-right: 10px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredUsers == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                    <p class="text-muted mt-2 small">Đang tải danh sách người dùng...</p>
                                </td>
                            </tr>
                        }
                        else if (!filteredUsers.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    Không có tài khoản nào khớp với tìm kiếm.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in filteredUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@user.FullName</div>
                                        <div class="text-muted small" style="font-weight: 300;">@user.Username</div>
                                    </td>
                                    <td>
                                        <span class="badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Lecturer" ? "bg-primary" : "bg-secondary")">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge @(user.SubscriptionTier == "Premium" ? "bg-success" : "bg-light text-dark border")">
                                                @user.SubscriptionTier
                                            </span>
                                            <button class="btn btn-sm btn-link text-accent p-0 small" style="text-decoration: underline; font-size: 0.8rem;" @onclick="() => ToggleTier(user)">
                                                Đổi gói
                                            </button>
                                        </div>
                                    </td>
                                    <td style="text-align: right; padding-right: 10px;">
                                        @if (user.Role != "Admin")
                                        {
                                            <button class="btn-zen danger" style="padding: 6px 12px; font-size: 0.8rem; text-transform: none;" @onclick="() => DeleteUser(user)">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small" style="font-style: italic;">Hệ thống</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private IEnumerable<UserDto>? allUsers;
    private IEnumerable<UserDto>? filteredUsers;
    private string searchKeyword = "";

    // Manual Creation Form
    private string newUsername = "";
    private string newFullName = "";
    private string newPassword = "";
    private string newRole = "Student";
    private string newTier = "Free";

    // Excel Upload
    private IBrowserFile? excelFile;
    private string defaultPassword = "Welcome@2026";
    private bool isImporting = false;

    // Notifications
    private string? successMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            allUsers = await AuthService.GetAllUsersAsync();
            filteredUsers = allUsers;
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải danh sách tài khoản: {ex.Message}";
        }
    }

    private void FilterUsers()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            filteredUsers = allUsers;
        }
        else
        {
            var kw = searchKeyword.Trim().ToLower();
            filteredUsers = allUsers?.Where(u => 
                u.Username.ToLower().Contains(kw) || 
                u.FullName.ToLower().Contains(kw) ||
                u.Role.ToLower().Contains(kw)
            ).ToList();
        }
    }

    private async Task CreateUser()
    {
        successMessage = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(newFullName))
            return;

        try
        {
            await AuthService.RegisterAsync(newUsername.Trim(), newPassword, newRole, newTier, newFullName.Trim());
            successMessage = $"Đã tạo thành công tài khoản '{newFullName}' với vai trò {newRole}!";
            
            // Reset fields
            newUsername = "";
            newFullName = "";
            newPassword = "";
            newRole = "Student";
            newTier = "Free";

            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tạo tài khoản: {ex.Message}";
        }
    }

    private void HandleExcelFileSelected(InputFileChangeEventArgs e)
    {
        excelFile = e.File;
        successMessage = null;
        errorMessage = null;
    }

    private async Task ImportUsers()
    {
        if (excelFile == null) return;

        isImporting = true;
        successMessage = null;
        errorMessage = null;
        StateHasChanged();

        try
        {
            using var fileStream = excelFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new System.IO.MemoryStream();
            await fileStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var result = await AuthService.ImportUsersFromExcelAsync(memoryStream, defaultPassword.Trim());
            successMessage = $"Nhập tài khoản từ Excel thành công! Đã tạo {result.Success} tài khoản mới (Bỏ qua {result.Skipped} tài khoản đã tồn tại).";
            excelFile = null;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi nhập tài khoản từ file Excel: {ex.Message}";
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private async Task ToggleTier(UserDto user)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            var success = await AuthService.ToggleSubscriptionTierAsync(user.Id);
            if (success)
            {
                successMessage = $"Đã thay đổi gói dịch vụ của '{user.FullName}' thành công!";
                await LoadData();
            }
            else
            {
                errorMessage = "Không tìm thấy người dùng hoặc thay đổi thất bại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi đổi gói cước: {ex.Message}";
        }
    }

    private async Task DeleteUser(UserDto user)
    {
        successMessage = null;
        errorMessage = null;

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc chắn muốn xóa tài khoản '{user.FullName}' ({user.Username}) không?");
        if (!confirmed) return;

        try
        {
            await AuthService.DeleteUserAsync(user.Id);
            successMessage = $"Đã xóa tài khoản '{user.FullName}' thành công!";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi xóa tài khoản: {ex.Message}";
        }
    }
}
