@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject IAuthService AuthService
@inject IJSRuntime JS
@inject ILogger<Users> Logger

<PageTitle>Quản Lý Tài Khoản - Admin</PageTitle>

<div class="zen-container py-4 gsap-fade-up">
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Hệ thống quản trị</div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">Danh sách Tài Khoản</h2>
        </div>
        <div class="zen-hero-desc">
            <p class="text-muted m-0" style="font-size: 1.1rem; line-height: 1.8;">
                Xem và quản lý thông tin các tài khoản trong hệ thống bao gồm Giảng viên, Sinh viên và Quản trị viên.
            </p>
        </div>
    </div>

    <div class="row mt-5">
        <!-- Create Account Panels (Unboxed, Zen) -->
        <div class="col-lg-4 mb-5 pe-lg-5 zen-list-item">
            <!-- Manual Create Form -->
            <div class="mb-5">
                <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Khởi tạo cá nhân</h4>
                
                <div class="mb-3 mt-2">
                    <input type="email" class="form-inline-zen w-100" @bind="newUsername" placeholder="Địa chỉ Email (*)" required />
                </div>
                <div class="mb-3">
                    <input type="text" class="form-inline-zen w-100" @bind="newFullName" placeholder="Họ và tên (*)" required />
                </div>
                <div class="mb-3">
                    <input type="password" class="form-inline-zen w-100" @bind="newPassword" placeholder="Mật khẩu khởi tạo (*)" required />
                </div>
                
                <div class="d-flex gap-3 mb-4 mt-4">
                    <div style="flex: 1;">
                        <label class="text-muted small text-uppercase tracking-wider mb-1">Vai trò</label>
                        <select class="form-inline-zen w-100" @bind="newRole" style="cursor: pointer;">
                            <option value="Student">Sinh viên</option>
                            <option value="Lecturer">Giảng viên</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div style="flex: 1;">
                        <label class="text-muted small text-uppercase tracking-wider mb-1">Gói cước</label>
                        <select class="form-inline-zen w-100" @bind="newTier" style="cursor: pointer;">
                            <option value="Free">Free</option>
                            <option value="Premium">Premium</option>
                        </select>
                    </div>
                </div>

                <button class="btn-zen magnetic-btn w-100" @onclick="CreateUser" disabled="@(string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(newFullName))">
                    Xác nhận tạo
                </button>
            </div>

            <!-- Import Users Form -->
            <div>
                <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Nhập hàng loạt</h4>
                <div class="mb-3 mt-2">
                    <input type="text" class="form-inline-zen w-100" @bind="defaultPassword" placeholder="Mật khẩu mặc định (Tùy chọn)" />
                </div>
                <div class="mb-4">
                    <label class="text-muted small text-uppercase tracking-wider mb-1">Dữ liệu Excel (.xlsx):</label>
                    <InputFile OnChange="HandleExcelFileSelected" class="form-inline-zen w-100" accept=".xlsx,.xls" style="padding: 0 !important; cursor: pointer;" />
                </div>
                <button class="btn-zen danger magnetic-btn w-100" @onclick="ImportUsers" disabled="@(excelFile == null || isImporting)">
                    @if (isImporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Đang xử lý...</span>
                    }
                    else
                    {
                        <span>Thực thi tải lên</span>
                    }
                </button>
            </div>
        </div>

        <!-- Users Table -->
        <div class="col-lg-8 mb-5 zen-list-item">
            <!-- Search & Count Bar -->
            <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
                <div style="flex: 1; max-width: 400px;">
                    <input type="text" class="form-inline-zen w-100" style="font-size: 1.1rem;" placeholder="Tìm kiếm theo tên, email, vai trò..." @bind="searchKeyword" @bind:event="oninput" @onkeyup="FilterUsers" />
                </div>
                <div class="text-muted small" style="letter-spacing: 0.1em; text-transform: uppercase;">
                    Số lượng: <strong>@(filteredUsers?.Count() ?? 0)</strong>
                </div>
            </div>

            <div class="table-responsive mt-2">
                <table class="table-zen">
                    <thead>
                        <tr>
                            <th style="width: 35%;">Tài khoản</th>
                            <th style="width: 20%;">Phân quyền</th>
                            <th style="width: 25%;">Dịch vụ</th>
                            <th style="width: 20%; text-align: right;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredUsers == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                </td>
                            </tr>
                        }
                        else if (!filteredUsers.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <span class="hanko-seal mb-2" style="opacity: 0.5;">無</span>
                                    <div>Không có kết quả.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in filteredUsers)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold" style="font-size: 1.05rem;">@user.FullName</div>
                                        <div class="text-muted small mt-1" style="font-weight: 300;">@user.Username</div>
                                    </td>
                                    <td>
                                        <span class="status-badge @(user.Role == "Admin" ? "status-processed text-accent" : "status-pending")">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="text-muted" style="font-size: 0.9rem;">
                                                @if(user.SubscriptionTier == "Premium")
                                                {
                                                    <strong class="text-sumi">Premium</strong>
                                                }
                                                else
                                                {
                                                    <span>Free</span>
                                                }
                                            </span>
                                            <button class="zen-action-link" style="font-size: 0.75rem; color: var(--accent-shu);" @onclick="() => ToggleTier(user)">
                                                Đổi
                                            </button>
                                        </div>
                                    </td>
                                    <td style="text-align: right;">
                                        @if (user.Role != "Admin")
                                        {
                                            <button class="zen-action-link danger" @onclick="() => DeleteUser(user)" title="Xóa">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small" style="font-style: italic; opacity: 0.5;">Lõi</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private IEnumerable<UserDto>? allUsers;
    private IEnumerable<UserDto>? filteredUsers;
    private string searchKeyword = "";

    // Manual Creation Form
    private string newUsername = "";
    private string newFullName = "";
    private string newPassword = "";
    private string newRole = "Student";
    private string newTier = "Free";

    // Excel Upload
    private IBrowserFile? excelFile;
    private string defaultPassword = "Welcome@2026";
    private bool isImporting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");
        }
    }

    private async Task ShowToast(string message, string type)
    {
        await JS.InvokeVoidAsync("zenInteract.showToast", message, type);
    }

    private async Task LoadData()
    {
        try
        {
            allUsers = await AuthService.GetAllUsersAsync();
            filteredUsers = allUsers;
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi tải dữ liệu: {ex.Message}", "error");
        }
    }

    private void FilterUsers()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            filteredUsers = allUsers;
        }
        else
        {
            var kw = searchKeyword.Trim().ToLower();
            filteredUsers = allUsers?.Where(u => 
                u.Username.ToLower().Contains(kw) || 
                u.FullName.ToLower().Contains(kw) ||
                u.Role.ToLower().Contains(kw)
            ).ToList();
        }
    }

    private async Task CreateUser()
    {
        if (string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(newFullName))
            return;

        try
        {
            await AuthService.RegisterAsync(newUsername.Trim(), newPassword, newRole, newTier, newFullName.Trim());
            await ShowToast($"Đã tạo tài khoản {newFullName}", "success");
            
            // Reset fields
            newUsername = "";
            newFullName = "";
            newPassword = "";
            newRole = "Student";
            newTier = "Free";

            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }

    private void HandleExcelFileSelected(InputFileChangeEventArgs e)
    {
        excelFile = e.File;
    }

    private async Task ImportUsers()
    {
        if (excelFile == null) return;

        isImporting = true;
        StateHasChanged();

        try
        {
            using var fileStream = excelFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new System.IO.MemoryStream();
            await fileStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            var result = await AuthService.ImportUsersFromExcelAsync(memoryStream, defaultPassword.Trim());
            await ShowToast($"Đã tạo {result.Success} tài khoản mới (Bỏ qua {result.Skipped})", "success");
            
            excelFile = null;
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi tải lên: {ex.Message}", "error");
        }
        finally
        {
            isImporting = false;
            StateHasChanged();
        }
    }

    private async Task ToggleTier(UserDto user)
    {
        try
        {
            var success = await AuthService.ToggleSubscriptionTierAsync(user.Id);
            if (success)
            {
                await ShowToast($"Đã đổi gói cước cho {user.FullName}", "success");
                await LoadData();
            }
            else
            {
                await ShowToast("Thay đổi thất bại", "error");
            }
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }

    private async Task DeleteUser(UserDto user)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Xóa tài khoản '{user.FullName}'?");
        if (!confirmed) return;

        try
        {
            await AuthService.DeleteUserAsync(user.Id);
            await ShowToast($"Đã xóa '{user.FullName}'", "success");
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi xóa: {ex.Message}", "error");
        }
    }
}
