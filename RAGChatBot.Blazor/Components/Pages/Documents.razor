@page "/courses/{CourseCode}/documents"
@attribute [Authorize]
@implements IDisposable
@using RAGChatBot.Blazor.Services
@inject DocumentEventService EventService
@inject IDocumentService DocumentService
@inject ICourseService CourseService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject ILogger<Documents> Logger

<PageTitle>Quản Lý Tài Liệu - @CourseCode</PageTitle>

<div class="zen-container py-4 gsap-fade-up">
    <!-- Back to Courses -->
    <div class="mb-4">
        <a href="/courses" class="zen-action-link text-muted small"><i class="fa-solid fa-arrow-left me-2"></i> Trở về</a>
    </div>

    <!-- Hero Header -->
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Quản lý tài liệu</div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">@CourseCode - @courseName</h2>
        </div>
        <div class="zen-hero-desc">
            @if (courseDescription != null)
            {
                <p class="text-muted m-0 mb-2">@courseDescription</p>
            }
            <div class="text-muted small" style="letter-spacing: 0.1em; text-transform: uppercase;">
                Giám sát: @(subjectLeaderName ?? "Chưa phân công")
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <!-- Document Upload (Lecturer/Admin) - Unboxed, Inline -->
        <AuthorizeView Roles="Lecturer,Admin">
            <div class="col-lg-4 mb-5 pe-lg-5 zen-list-item">
                <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Tải lên tài liệu</h4>
                
                <div class="mb-4 mt-2">
                    <input type="text" class="form-inline-zen w-100" @bind="chapter" placeholder="Tên chương/phần tài liệu" required />
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small text-uppercase tracking-wider">Tệp đính kèm (.pdf, .docx):</label>
                    <InputFile OnChange="HandleFileSelected" class="form-inline-zen w-100" accept=".pdf,.docx" style="padding: 0 !important; cursor: pointer;" />
                    <div class="mt-2 small text-muted" style="font-weight: 300;">
                        Giới hạn: @(currentSubscriptionTier == "Premium" ? "50 MB (Premium)" : "5 MB (Free)")
                    </div>
                </div>

                <button class="btn-zen magnetic-btn w-100 mt-2" @onclick="UploadFile" disabled="@(isUploading || uploadedFile == null || string.IsNullOrWhiteSpace(chapter))">
                    @if (isUploading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Đang xử lý...</span>
                    }
                    else
                    {
                        <span>Tải lên hệ thống</span>
                    }
                </button>
            </div>
        </AuthorizeView>

        <!-- Document List -->
        <div class="@(canUpload ? "col-lg-8" : "col-12") mb-5 zen-list-item">
            <div class="table-responsive">
                <table class="table-zen">
                    <thead>
                        <tr>
                            <th style="width: 40%;">Tài liệu</th>
                            <th style="width: 25%;">Chương</th>
                            <th style="width: 20%;">Trạng thái</th>
                            <th style="width: 15%; text-align: right;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (documents == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                </td>
                            </tr>
                        }
                        else if (!documents.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <span class="hanko-seal mb-2" style="opacity: 0.5;">無</span>
                                    <div>Chưa có tài liệu.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var doc in documents)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight: 500; font-size: 1.05rem;">@doc.FileName</div>
                                        <div class="text-muted small mt-1" style="font-weight: 300;">
                                            @FormatSize(doc.FileSize) &bull; @doc.UploadedAt.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </td>
                                    <td>@doc.Chapter</td>
                                    <td>
                                        <div class="mb-1">
                                            @if (doc.IsProcessed)
                                            {
                                                <span class="status-badge status-processed">Vectorized</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-pending">Processing...</span>
                                            }
                                        </div>
                                        <div>
                                            @if (doc.IsApproved)
                                            {
                                                <span class="status-badge status-processed text-accent">Approved</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-pending">Pending</span>
                                            }
                                        </div>
                                    </td>
                                    <td style="text-align: right;">
                                        <div class="d-flex justify-content-end gap-3">
                                            @if (doc.IsProcessed)
                                            {
                                                <button class="zen-action-link" @onclick="() => ToggleChunks(doc.Id)" title="Xem chunks">
                                                    <i class="fa-solid @(showChunksMap.GetValueOrDefault(doc.Id) ? "fa-eye-slash" : "fa-eye")"></i>
                                                </button>
                                            }
                                            
                                            @if (!doc.IsApproved && canApprove)
                                            {
                                                <button class="zen-action-link" style="color: #28a745;" @onclick="() => ApproveDocument(doc.Id)" title="Duyệt">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            }

                                            @if (canDelete)
                                            {
                                                <button class="zen-action-link danger" @onclick="() => DeleteDocument(doc.Id)" title="Xóa">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>

                                <!-- Expanded Chunks Section (Minimalist) -->
                                @if (showChunksMap.GetValueOrDefault(doc.Id))
                                {
                                    <tr>
                                        <td colspan="4" class="py-3 px-4" style="background-color: rgba(0,0,0,0.01);">
                                            <div style="border-left: 2px solid var(--text-sumi); padding-left: 20px;">
                                                <h6 class="font-serif text-muted mb-3">Dữ liệu Vector (Chunks)</h6>
                                                @if (documentChunks.TryGetValue(doc.Id, out var chunksList))
                                                {
                                                    @if (chunksList.Count == 0)
                                                    {
                                                        <p class="text-muted small">Không tìm thấy phân mảnh.</p>
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex flex-column gap-3">
                                                            @foreach (var chunk in chunksList)
                                                            {
                                                                <div>
                                                                    <span class="badge bg-secondary mb-1">#@chunk.ChunkIndex</span>
                                                                    <div class="text-muted small" style="white-space: pre-line; line-height: 1.6;">
                                                                        @chunk.Content
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="small text-muted"><span class="spinner-border spinner-border-sm text-secondary me-2"></span> Đang tải...</div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string CourseCode { get; set; } = string.Empty;

    private string courseName = "";
    private string? courseDescription;
    private string? subjectLeaderName;

    private IEnumerable<DocumentDto>? documents;
    private string chapter = "";
    private IBrowserFile? uploadedFile;
    private bool isUploading = false;

    // Permissions
    private bool canUpload = false;
    private bool canApprove = false;
    private bool canDelete = false;

    private Guid currentUserId;
    private string currentSubscriptionTier = "Free";

    // Expandable chunks
    private Dictionary<Guid, bool> showChunksMap = new();
    private Dictionary<Guid, List<ChunkDto>> documentChunks = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        Guid.TryParse(userIdStr, out currentUserId);
        currentSubscriptionTier = user.FindFirst("SubscriptionTier")?.Value ?? "Free";

        var isLecturer = user.IsInRole("Lecturer");
        var isAdmin = user.IsInRole("Admin");
        canUpload = isLecturer || isAdmin;

        await LoadCourseDetails();
        await LoadDocuments();

        EventService.OnDocumentChanged += HandleDocumentChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");
        }
    }

    private void HandleDocumentChanged(string courseCode)
    {
        if (courseCode.Equals(CourseCode, StringComparison.OrdinalIgnoreCase))
        {
            InvokeAsync(async () =>
            {
                await LoadDocuments();
                StateHasChanged();
            });
        }
    }

    private async Task LoadCourseDetails()
    {
        try
        {
            var courses = await CourseService.GetAllCoursesAsync();
            var course = courses.FirstOrDefault(c => c.Code.Equals(CourseCode, StringComparison.OrdinalIgnoreCase));
            if (course != null)
            {
                courseName = course.Name;
                courseDescription = course.Description;
                subjectLeaderName = course.SubjectLeaderName;

                var isLeader = course.SubjectLeaderId == currentUserId;
                var isAdmin = (await AuthStateProvider.GetAuthenticationStateAsync()).User.IsInRole("Admin");
                canApprove = isLeader || isAdmin;
                canDelete = isLeader;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi tải thông tin môn học {Course}", CourseCode);
        }
    }

    private async Task LoadDocuments()
    {
        try
        {
            documents = await DocumentService.GetDocumentsByCourseAsync(CourseCode);
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
    }

    private async Task UploadFile()
    {
        if (uploadedFile == null || string.IsNullOrWhiteSpace(chapter)) return;

        isUploading = true;
        StateHasChanged();

        try
        {
            long maxBytes = currentSubscriptionTier == "Premium"
                ? 50 * 1024 * 1024
                : 5 * 1024 * 1024;

            if (uploadedFile.Size > maxBytes)
            {
                var limitMb = maxBytes / (1024 * 1024);
                await ShowToast($"Tệp quá lớn. Giới hạn {limitMb} MB ({currentSubscriptionTier})!", "error");
                isUploading = false;
                return;
            }

            using var fileStream = uploadedFile.OpenReadStream(maxBytes);
            using var memoryStream = new System.IO.MemoryStream();
            await fileStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            await DocumentService.UploadDocumentAsync(
                memoryStream,
                uploadedFile.Name,
                uploadedFile.Size,
                CourseCode,
                chapter,
                currentUserId,
                currentSubscriptionTier
            );

            await ShowToast($"Đã tải lên: {uploadedFile.Name}", "success");
            chapter = "";
            uploadedFile = null;
            await LoadDocuments();

            EventService.NotifyDocumentChanged(CourseCode);
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi tải lên: {ex.Message}", "error");
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task ApproveDocument(Guid docId)
    {
        try
        {
            await DocumentService.ApproveDocumentAsync(docId, currentUserId);
            await ShowToast("Tài liệu đã được phê duyệt.", "success");
            await LoadDocuments();
            EventService.NotifyDocumentChanged(CourseCode);
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi duyệt: {ex.Message}", "error");
        }
    }

    private async Task DeleteDocument(Guid docId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Xác nhận xóa tài liệu và vector chunks liên quan?");
        if (!confirmed) return;

        try
        {
            await DocumentService.DeleteDocumentAsync(docId, currentUserId);
            await ShowToast("Tài liệu đã bị xóa.", "success");
            await LoadDocuments();
            EventService.NotifyDocumentChanged(CourseCode);
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi xóa: {ex.Message}", "error");
        }
    }

    private async Task ToggleChunks(Guid docId)
    {
        if (showChunksMap.GetValueOrDefault(docId))
        {
            showChunksMap[docId] = false;
        }
        else
        {
            if (!documentChunks.ContainsKey(docId))
            {
                var chunksList = await DocumentService.GetDocumentChunksAsync(docId);
                documentChunks[docId] = chunksList.ToList();
            }
            showChunksMap[docId] = true;
        }
    }

    private string FormatSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
        {
            return $"{(bytes / 1024.0 / 1024.0):F2} MB";
        }
        return $"{(bytes / 1024.0):F2} KB";
    }

    private async Task ShowToast(string message, string type)
    {
        await JS.InvokeVoidAsync("zenInteract.showToast", message, type);
    }

    public void Dispose()
    {
        EventService.OnDocumentChanged -= HandleDocumentChanged;
    }
}
