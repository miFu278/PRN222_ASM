@page "/courses/{CourseCode}/documents"
@attribute [Authorize]
@inject IDocumentService DocumentService
@inject ICourseService CourseService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject ILogger<Documents> Logger

<PageTitle>Quản Lý Tài Liệu - @CourseCode</PageTitle>

<div class="zen-container py-4">
    <!-- Back to Courses -->
    <div class="mb-3">
        <a href="/courses" class="text-muted small"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách môn học</a>
    </div>

    <!-- Hero Header -->
    <div class="zen-hero mb-4">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Quản lý tài liệu</div>
            <h2 class="font-serif m-0">@CourseCode - @courseName</h2>
        </div>
        <div class="zen-hero-desc">
            @if (courseDescription != null)
            {
                <p class="text-muted m-0">@courseDescription</p>
            }
            <div class="mt-2 text-muted small">
                <strong>Trưởng bộ môn:</strong> @(subjectLeaderName ?? "Chưa phân công")
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 0; font-size: 0.95rem; background-color: rgba(40, 167, 69, 0.05); border-color: rgba(40, 167, 69, 0.2); color: #28a745;">
            <i class="fa-solid fa-circle-check me-2"></i> @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 0; font-size: 0.95rem; background-color: rgba(191, 42, 35, 0.05); border-color: rgba(191, 42, 35, 0.2); color: var(--accent-shu);">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <div class="row">
        <!-- Document Upload Box (Lecturer/Admin) -->
        <AuthorizeView Roles="Lecturer,Admin">
            <div class="col-lg-4 mb-4">
                <div class="p-4 border border-light" style="background-color: rgba(255, 255, 255, 0.8);">
                    <h4 class="font-serif mb-3">Tải lên tài liệu mới</h4>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Chương/Phần tài liệu:</label>
                        <input type="text" class="form-control" @bind="chapter" placeholder="Ví dụ: Chương 1 - Tổng quan" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase fw-bold">Chọn tệp (.pdf, .docx):</label>
                        <InputFile OnChange="HandleFileSelected" class="form-control" accept=".pdf,.docx" />
                        <div class="form-text small text-muted">
                            Giới hạn dung lượng: @(currentSubscriptionTier == "Premium" ? "50 MB (Premium)" : "5 MB (Free)")
                        </div>
                    </div>

                    <button class="btn-zen w-100 mt-2" @onclick="UploadFile" disabled="@(isUploading || uploadedFile == null || string.IsNullOrWhiteSpace(chapter))">
                        @if (isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Đang tải lên...</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-cloud-arrow-up me-1"></i> Tải lên tài liệu</span>
                        }
                    </button>
                </div>
            </div>
        </AuthorizeView>

        <!-- Document List -->
        <div class="@(canUpload ? "col-lg-8" : "col-12") mb-4">
            <div class="table-responsive">
                <table class="table-zen">
                    <thead>
                        <tr>
                            <th style="width: 35%;">Tên Tài Liệu</th>
                            <th style="width: 20%;">Chương/Phần</th>
                            <th style="width: 25%;">Trạng thái</th>
                            <th style="width: 20%; text-align: right; padding-right: 10px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (documents == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="spinner-border text-secondary" role="status"></div>
                                    <p class="text-muted mt-2 small">Đang tải danh sách tài liệu...</p>
                                </td>
                            </tr>
                        }
                        else if (!documents.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    Môn học này chưa có tài liệu nào được tải lên.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var doc in documents)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@doc.FileName</div>
                                        <div class="text-muted small" style="font-weight: 300;">
                                            @FormatSize(doc.FileSize) &bull; Tải lên bởi: @doc.UploaderName &bull; @doc.UploadedAt.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </td>
                                    <td>@doc.Chapter</td>
                                    <td>
                                        <div class="mb-1">
                                            @if (doc.IsProcessed)
                                            {
                                                <span class="badge bg-success small"><i class="fa-solid fa-circle-check me-1"></i> Đã nhúng Vector</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark small"><i class="fa-solid fa-spinner fa-spin me-1"></i> Đang nhúng...</span>
                                            }
                                        </div>
                                        <div>
                                            @if (doc.IsApproved)
                                            {
                                                <span class="badge bg-info text-white small"><i class="fa-solid fa-shield-check me-1"></i> Đã duyệt</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary text-white small"><i class="fa-solid fa-circle-question me-1"></i> Chờ duyệt</span>
                                            }
                                        </div>
                                    </td>
                                    <td style="text-align: right; padding-right: 10px;">
                                        <div class="d-flex justify-content-end gap-2">
                                            @if (doc.IsProcessed)
                                            {
                                                <button class="btn-zen" style="padding: 6px 12px; font-size: 0.8rem; text-transform: none;" @onclick="() => ToggleChunks(doc.Id)">
                                                    <i class="fa-solid @(showChunksMap.GetValueOrDefault(doc.Id) ? "fa-eye-slash" : "fa-eye") me-1"></i> Chunks
                                                </button>
                                            }
                                            
                                            @if (!doc.IsApproved && canApprove)
                                            {
                                                <button class="btn-zen" style="padding: 6px 12px; font-size: 0.8rem; text-transform: none; border-color: #28a745; color: #28a745;" @onclick="() => ApproveDocument(doc.Id)">
                                                    <i class="fa-solid fa-check me-1"></i> Duyệt
                                                </button>
                                            }

                                            @if (canDelete)
                                            {
                                                <button class="btn-zen danger" style="padding: 6px 12px; font-size: 0.8rem; text-transform: none;" @onclick="() => DeleteDocument(doc.Id)">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>

                                <!-- Expanded Chunks Section -->
                                @if (showChunksMap.GetValueOrDefault(doc.Id))
                                {
                                    <tr>
                                        <td colspan="4" class="p-3" style="background-color: rgba(0,0,0,0.01);">
                                            <div class="border border-light p-3" style="background-color: #ffffff;">
                                                <h5 class="font-serif mb-3 text-muted small text-uppercase fw-bold">Các đoạn tài liệu đã được phân tách (Chunks)</h5>
                                                @if (documentChunks.TryGetValue(doc.Id, out var chunksList))
                                                {
                                                    @if (chunksList.Count == 0)
                                                    {
                                                        <p class="text-muted small">Không tìm thấy phân mảnh nào.</p>
                                                    }
                                                    else
                                                    {
                                                        <div class="accordion" id="accordionChunks-@doc.Id">
                                                            @foreach (var chunk in chunksList)
                                                            {
                                                                <div class="accordion-item mb-2" style="border-radius: 0;">
                                                                    <h2 class="accordion-header">
                                                                        <button class="accordion-button collapsed py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-chunk-@doc.Id-@chunk.ChunkIndex">
                                                                            <span class="badge bg-secondary me-2">Chunk #@chunk.ChunkIndex</span>
                                                                            <span class="text-muted small text-truncate" style="max-width: 500px;">@chunk.Content</span>
                                                                        </button>
                                                                    </h2>
                                                                    <div id="collapse-chunk-@doc.Id-@chunk.ChunkIndex" class="accordion-collapse collapse" data-bs-parent="#accordionChunks-@doc.Id">
                                                                        <div class="accordion-body small text-muted" style="white-space: pre-line; line-height: 1.6;">
                                                                            @chunk.Content
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-center py-2"><span class="spinner-border spinner-border-sm text-secondary"></span> Đang tải...</div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string CourseCode { get; set; } = string.Empty;

    private string courseName = "";
    private string? courseDescription;
    private string? subjectLeaderName;

    private IEnumerable<DocumentDto>? documents;
    private string chapter = "";
    private IBrowserFile? uploadedFile;
    private bool isUploading = false;

    // Permissions
    private bool canUpload = false;
    private bool canApprove = false;
    private bool canDelete = false;

    private Guid currentUserId;
    private string currentSubscriptionTier = "Free";

    // Notifications
    private string? successMessage;
    private string? errorMessage;

    // Expandable chunks
    private Dictionary<Guid, bool> showChunksMap = new();
    private Dictionary<Guid, List<ChunkDto>> documentChunks = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        Guid.TryParse(userIdStr, out currentUserId);
        currentSubscriptionTier = user.FindFirst("SubscriptionTier")?.Value ?? "Free";

        var isLecturer = user.IsInRole("Lecturer");
        var isAdmin = user.IsInRole("Admin");
        canUpload = isLecturer || isAdmin;

        await LoadCourseDetails();
        await LoadDocuments();
    }

    private async Task LoadCourseDetails()
    {
        try
        {
            var courses = await CourseService.GetAllCoursesAsync();
            var course = courses.FirstOrDefault(c => c.Code.Equals(CourseCode, StringComparison.OrdinalIgnoreCase));
            if (course != null)
            {
                courseName = course.Name;
                courseDescription = course.Description;
                subjectLeaderName = course.SubjectLeaderName;

                var isLeader = course.SubjectLeaderId == currentUserId;
                var isAdmin = (await AuthStateProvider.GetAuthenticationStateAsync()).User.IsInRole("Admin");
                canApprove = isLeader || isAdmin;
                canDelete = isLeader;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi tải thông tin môn học {Course}", CourseCode);
        }
    }

    private async Task LoadDocuments()
    {
        try
        {
            documents = await DocumentService.GetDocumentsByCourseAsync(CourseCode);
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải danh sách tài liệu: {ex.Message}";
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        successMessage = null;
        errorMessage = null;
    }

    private async Task UploadFile()
    {
        if (uploadedFile == null || string.IsNullOrWhiteSpace(chapter)) return;

        isUploading = true;
        successMessage = null;
        errorMessage = null;
        StateHasChanged();

        try
        {
            // Xác thực kích thước file cục bộ trước khi upload
            long maxBytes = currentSubscriptionTier == "Premium"
                ? 50 * 1024 * 1024  // 50 MB
                : 5 * 1024 * 1024;   // 5 MB

            if (uploadedFile.Size > maxBytes)
            {
                var limitMb = maxBytes / (1024 * 1024);
                errorMessage = $"Kích thước tệp tin ({uploadedFile.Size / 1024.0 / 1024.0:F2} MB) vượt quá giới hạn cho phép ({limitMb} MB) của gói tài khoản {currentSubscriptionTier}!";
                isUploading = false;
                return;
            }

            // Chuyển đổi file sang stream để truyền tới Service
            using var fileStream = uploadedFile.OpenReadStream(maxBytes);
            
            // Do fileStream sẽ bị đóng khi ngoài khối lệnh, ta cần sao chép sang MemoryStream
            using var memoryStream = new System.IO.MemoryStream();
            await fileStream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            await DocumentService.UploadDocumentAsync(
                memoryStream,
                uploadedFile.Name,
                uploadedFile.Size,
                CourseCode,
                chapter,
                currentUserId,
                currentSubscriptionTier
            );

            successMessage = $"Tải lên tài liệu '{uploadedFile.Name}' thành công! Tài liệu đang xếp hàng chờ vector hóa.";
            chapter = "";
            uploadedFile = null;
            await LoadDocuments();
        }
        catch (Exception ex)
        {
            errorMessage = $"Có lỗi xảy ra khi tải lên tài liệu: {ex.Message}";
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task ApproveDocument(Guid docId)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            await DocumentService.ApproveDocumentAsync(docId, currentUserId);
            successMessage = "Duyệt tài liệu thành công!";
            await LoadDocuments();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể phê duyệt tài liệu: {ex.Message}";
        }
    }

    private async Task DeleteDocument(Guid docId)
    {
        successMessage = null;
        errorMessage = null;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa tài liệu này không? Hành động này sẽ xóa file vật lý và toàn bộ cơ sở tri thức (vector chunks) liên quan.");
        if (!confirmed) return;

        try
        {
            await DocumentService.DeleteDocumentAsync(docId, currentUserId);
            successMessage = "Xóa tài liệu học tập thành công!";
            await LoadDocuments();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể xóa tài liệu: {ex.Message}";
        }
    }

    private async Task ToggleChunks(Guid docId)
    {
        if (showChunksMap.GetValueOrDefault(docId))
        {
            showChunksMap[docId] = false;
        }
        else
        {
            if (!documentChunks.ContainsKey(docId))
            {
                var chunksList = await DocumentService.GetDocumentChunksAsync(docId);
                documentChunks[docId] = chunksList.ToList();
            }
            showChunksMap[docId] = true;
        }
    }

    private string FormatSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
        {
            return $"{(bytes / 1024.0 / 1024.0):F2} MB";
        }
        return $"{(bytes / 1024.0):F2} KB";
    }
}
