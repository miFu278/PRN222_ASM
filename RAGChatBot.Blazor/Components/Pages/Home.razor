@page "/"
@attribute [Authorize]
@inject ICourseService CourseService
@inject IChatService ChatService
@inject IJSRuntime JS
@inject ILogger<Home> Logger

<PageTitle>Trợ Lý Học Thuật AI</PageTitle>

<div class="zen-chat-container py-4 gsap-fade-up">
    <!-- Header/Hero section -->
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Trợ Lý Thông Minh</div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">Hỏi đáp Học liệu</h2>
        </div>
        <div class="zen-hero-desc">
            <p class="text-muted m-0" style="font-size: 1.1rem; line-height: 1.8;">
                Hãy lựa chọn môn học và bắt đầu đặt câu hỏi. Hệ thống sẽ phân tích các tài liệu giảng dạy đã được phê duyệt để cung cấp câu trả lời chính xác nhất.
            </p>
        </div>
    </div>

    <!-- Course Selector & Reset -->
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-4 mb-5">
        <div style="flex: 1; max-width: 600px;">
            <select class="form-inline-zen w-100" @bind="SelectedCourseCode" style="font-size: 1.1rem; cursor: pointer;">
                <option value="">-- Hỏi đáp tất cả môn học (Toàn hệ thống) --</option>
                @if (courses != null)
                {
                    @foreach (var course in courses)
                    {
                        <option value="@course.Code">@course.Code - @course.Name</option>
                    }
                }
            </select>
        </div>
        @if (chatMessages.Count > 0)
        {
            <div>
                <button class="zen-action-link danger" @onclick="ClearChat">Xóa lịch sử</button>
            </div>
        }
    </div>

    <div class="chat-history-box mb-5" style="min-height: 400px; max-height: 600px; overflow-y: auto;">
        @if (chatMessages.Count == 0)
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-5 text-center mt-5" style="opacity: 0.5;">
                <span class="hanko-seal mb-4" style="width: 64px; height: 64px; font-size: 2rem;">問</span>
                <h4 class="font-serif text-sumi" style="font-size: 1.5rem;">Trợ lý Học thuật tĩnh lặng</h4>
                <p class="text-muted small mt-2" style="font-weight: 300;">Trò chuyện để khám phá tri thức.</p>
            </div>
        }
        else
        {
            <div class="pe-3">
                @foreach (var msg in chatMessages)
                {
                    <div class="chat-message-row d-flex @(msg.Role == "User" ? "justify-content-end" : "justify-content-start") mb-4">
                        <div class="message-bubble p-4 @(msg.Role == "User" ? "message-user" : "message-bot")" style="max-width: 85%; font-size: 1.05rem;">
                            <div class="d-flex align-items-center mb-2">
                                @if (msg.Role == "User")
                                {
                                    <span class="text-muted small text-uppercase tracking-wider fw-bold me-3">Bạn</span>
                                }
                                else
                                {
                                    <span class="text-accent small text-uppercase tracking-wider fw-bold me-3">Trợ lý</span>
                                }
                                <span class="text-muted style-time">@msg.Timestamp.ToString("HH:mm")</span>
                            </div>
                            <div style="white-space: pre-line; line-height: 1.8;">
                                @msg.Content
                            </div>
                        </div>
                    </div>
                }

                @if (isSending)
                {
                    <div class="chat-message-row d-flex justify-content-start mb-4">
                        <div class="message-bubble p-4 message-bot" style="max-width: 85%;">
                            <div class="d-flex align-items-center mb-2">
                                <span class="text-accent small text-uppercase tracking-wider fw-bold me-3">Trợ lý</span>
                                <span class="text-muted style-time">Đang suy nghĩ...</span>
                            </div>
                            <div class="loading-dots text-sumi">
                                <span>.</span><span>.</span><span>.</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Input Box & Suggestions -->
    <div class="zen-input-area mt-auto">
        <div class="zen-input-wrapper">
            <input type="text" class="input-zen" placeholder="Viết câu hỏi của bạn tại đây..." 
                   @bind="question" @bind:event="oninput" @onkeypress="HandleKeyPress" disabled="@isSending" style="font-size: 1.2rem;" />
            <button class="zen-send-btn magnetic-btn" @onclick="SendMessage" disabled="@(isSending || string.IsNullOrWhiteSpace(question))">
                <i class="fa-solid fa-arrow-right" style="font-size: 1.5rem;"></i>
            </button>
        </div>
    </div>

    @if (chatMessages.Count == 0 && !isSending)
    {
        <div class="zen-suggestions mt-4 pt-3" style="border-top: 1px solid var(--border-light);">
            <div class="d-flex flex-wrap gap-4">
                <button class="zen-suggestion-btn" @onclick='() => SetSuggestion("Tóm tắt nội dung chính của môn học.")'>
                    Tóm tắt nội dung môn học.
                </button>
                <button class="zen-suggestion-btn" @onclick='() => SetSuggestion("Những khái niệm quan trọng nhất là gì?")'>
                    Các khái niệm quan trọng?
                </button>
                <button class="zen-suggestion-btn" @onclick='() => SetSuggestion("Tạo 5 câu hỏi ôn tập.")'>
                    Tạo câu hỏi ôn tập.
                </button>
            </div>
        </div>
    }
</div>

<style>
    .tracking-wider {
        letter-spacing: 0.1em;
    }
    
    .chat-history-box {
        transition: all 0.3s ease;
    }

    .message-bubble {
        border-radius: 0;
    }

    .message-user {
        background-color: rgba(0,0,0,0.03);
        color: var(--text-sumi);
        border: 1px solid var(--border-light);
    }

    .message-bot {
        background-color: var(--bg-washi);
        color: var(--text-sumi);
        border-left: 2px solid var(--accent-shu);
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .style-time {
        font-size: 0.8rem;
        font-weight: 300;
    }

    .zen-suggestion-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: 0.95rem;
        padding: 8px 0;
        transition: color 0.4s ease, padding-left 0.4s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        text-align: left;
    }

    .zen-suggestion-btn::before {
        content: '';
        display: inline-block;
        width: 15px;
        height: 1px;
        background-color: var(--border-light);
        margin-right: 15px;
        transition: width 0.4s ease, background-color 0.4s ease;
    }

    .zen-suggestion-btn:hover {
        color: var(--text-sumi);
        padding-left: 5px;
    }

    .zen-suggestion-btn:hover::before {
        width: 30px;
        background-color: var(--accent-shu);
    }

    .loading-dots span {
        font-size: 2rem;
        line-height: 0.5;
        animation: blink 1.4s infinite both;
        display: inline-block;
        margin: 0 2px;
    }

    .loading-dots span:nth-child(2) { animation-delay: .2s; }
    .loading-dots span:nth-child(3) { animation-delay: .4s; }

    @@keyframes blink {
        0% { opacity: .2; }
        20% { opacity: 1; }
        100% { opacity: .2; }
    }
</style>

@code {
    private IEnumerable<CourseDto>? courses;
    private string selectedCourseCode = "";
    private List<ChatMessage> chatMessages = new();
    private string question = "";
    private bool isSending = false;

    private string SelectedCourseCode
    {
        get => selectedCourseCode;
        set
        {
            if (selectedCourseCode != value)
            {
                selectedCourseCode = value;
                chatMessages.Clear(); 
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            courses = await CourseService.GetAllCoursesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi khi tải danh sách môn học.");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");
        }
    }

    private void SetSuggestion(string val)
    {
        question = val;
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(question) || isSending)
            return;

        var userQuestion = question.Trim();
        question = "";
        
        chatMessages.Add(new ChatMessage 
        { 
            Role = "User", 
            Content = userQuestion, 
            Timestamp = DateTime.Now 
        });
        
        isSending = true;
        StateHasChanged();

        // Cuộn xuống mỗi khi thêm tin nhắn mới có thể được handle bằng JS, nhưng tạm thời dựa vào overflow

        try
        {
            var reply = await ChatService.GetChatResponseAsync(userQuestion, SelectedCourseCode);
            chatMessages.Add(new ChatMessage 
            { 
                Role = "Bot", 
                Content = reply, 
                Timestamp = DateTime.Now 
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi khi gọi ChatService cho môn {Course}", SelectedCourseCode);
            chatMessages.Add(new ChatMessage 
            { 
                Role = "Bot", 
                Content = $"Đã xảy ra lỗi: {ex.Message}", 
                Timestamp = DateTime.Now 
            });
        }
        finally
        {
            isSending = false;
            StateHasChanged();
        }
    }

    private void ClearChat()
    {
        chatMessages.Clear();
    }

    private class ChatMessage
    {
        public string Role { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
