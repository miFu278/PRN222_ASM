@page "/subscription"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Gói Dịch Vụ - RAG ChatBot</PageTitle>

<div class="zen-container py-4 gsap-fade-up">
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Gói cước tài khoản</div>
            <h2 class="font-serif m-0" style="font-size: 3rem;">Nâng Cấp Premium</h2>
        </div>
        <div class="zen-hero-desc">
            <p class="text-muted m-0" style="font-size: 1.1rem; line-height: 1.8;">
                Nâng cấp hạn mức tải lên tài liệu học tập của bạn để hỗ trợ phân tích các tài liệu lớn, tài liệu tham khảo dài tập hoặc giáo trình đầy đủ chương trình học.
            </p>
        </div>
    </div>

    <!-- Pricing Comparison Grid (Zen style, no boxes) -->
    <div class="row justify-content-between gap-4 mb-5 mt-5">
        <!-- Free Tier -->
        <div class="col-md-5 zen-list-item" style="padding-right: 40px;">
            <div class="d-flex align-items-center gap-3 mb-4">
                <h3 class="font-serif m-0" style="font-size: 2rem;">Free</h3>
                @if (currentTier == "Free")
                {
                    <span class="text-muted small" style="letter-spacing: 0.1em; text-transform: uppercase;">&bull; Gói hiện tại</span>
                }
            </div>
            
            <h2 class="font-serif mb-4" style="font-size: 2.5rem;">0<span style="font-size: 1rem;">đ</span> <span class="fs-6 text-muted font-sans" style="font-weight: 300;">/ vĩnh viễn</span></h2>
            
            <hr class="mb-4" style="border-top: 1px solid var(--border-light);" />
            
            <ul class="list-unstyled mb-5" style="font-size: 1.05rem;">
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem;">✓</span> Tải lên tài liệu tối đa <strong>5 MB</strong></li>
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem;">✓</span> Trích xuất và phân tích văn bản AI (RAG)</li>
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem;">✓</span> Chatbot học thuật tương tác thời gian thực</li>
                <li class="mb-3 d-flex align-items-start text-muted" style="opacity: 0.5;"><span class="me-3" style="width: 20px; text-align: center;">-</span> Không hỗ trợ file giáo trình lớn</li>
            </ul>
        </div>

        <!-- Divider for larger screens -->
        <div class="col-md-1 d-none d-md-flex justify-content-center">
            <div style="width: 1px; height: 100%; background-color: var(--border-light);"></div>
        </div>

        <!-- Premium Tier -->
        <div class="col-md-5 zen-list-item">
            <div class="d-flex align-items-center gap-3 mb-4">
                <h3 class="font-serif m-0 text-accent" style="font-size: 2rem;">Premium</h3>
                @if (currentTier == "Premium")
                {
                    <span class="text-accent small" style="letter-spacing: 0.1em; text-transform: uppercase;">&bull; Gói hiện tại</span>
                }
            </div>
            
            <h2 class="font-serif mb-4" style="font-size: 2.5rem;">99.000<span style="font-size: 1rem;">đ</span> <span class="fs-6 text-muted font-sans" style="font-weight: 300;">/ tháng</span></h2>
            
            <hr class="mb-4" style="border-top: 1px solid var(--text-sumi);" />
            
            <ul class="list-unstyled mb-5" style="font-size: 1.05rem;">
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem; background-color: var(--text-sumi);">✓</span> Tải lên tài liệu lên tới <strong>50 MB</strong></li>
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem; background-color: var(--text-sumi);">✓</span> Hỗ trợ file giáo trình dày, nhiều chương</li>
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem; background-color: var(--text-sumi);">✓</span> Ưu tiên cao khi trích xuất vector hóa</li>
                <li class="mb-3 d-flex align-items-start"><span class="hanko-seal me-3" style="width: 20px; height: 20px; font-size: 0.6rem; background-color: var(--text-sumi);">✓</span> Đầy đủ tính năng gói Free</li>
            </ul>

            @if (currentTier == "Free")
            {
                <form action="Subscription/Upgrade" method="post">
                    <AntiforgeryToken />
                    <button type="submit" class="btn-zen danger magnetic-btn" style="padding: 15px 40px; font-size: 1rem;">
                        Nâng cấp lên Premium
                    </button>
                </form>
            }
            else
            {
                <div class="text-accent" style="font-family: var(--font-serif); font-size: 1.2rem; font-style: italic;">
                    Tuyệt vời! Bạn đang tận hưởng dịch vụ Premium.
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string currentTier = "Free";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentTier = user.FindFirst("SubscriptionTier")?.Value ?? "Free";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");

            if (!string.IsNullOrEmpty(Success))
            {
                await JS.InvokeVoidAsync("zenInteract.showToast", Success, "success");
            }
            
            if (!string.IsNullOrEmpty(Error))
            {
                await JS.InvokeVoidAsync("zenInteract.showToast", Error, "error");
            }
        }
    }
}
