@page "/courses"
@attribute [Authorize]
@inject ICourseService CourseService
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ILogger<Courses> Logger

<PageTitle>Quản Lý Học Liệu</PageTitle>

<div class="zen-container py-4 gsap-fade-up">
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Hệ thống học liệu</div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">Danh sách môn học</h2>
        </div>
        <div class="zen-hero-desc">
            <p class="text-muted m-0" style="font-size: 1.1rem; line-height: 1.8;">
                Xem và quản lý các môn học trong hệ thống. Giảng viên và Trưởng bộ môn có thể quản lý tài liệu học tập của từng môn học cụ thể.
            </p>
        </div>
    </div>

    <!-- Search & Action Bar -->
    <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-5 mt-4">
        <div style="flex: 1; min-width: 250px; max-width: 450px;">
            <input type="text" class="form-inline-zen w-100" style="font-size: 1.1rem;" placeholder="Tìm kiếm môn học theo mã hoặc tên..." @bind="searchKeyword" @bind:event="oninput" @onkeyup="FilterCourses" />
        </div>

        <AuthorizeView Roles="Lecturer,Admin">
            <button class="btn-zen magnetic-btn" @onclick="OpenCreateForm">
                Tạo môn học mới
            </button>
        </AuthorizeView>
    </div>

    <!-- Create/Edit Form (Inline Zen) -->
    @if (showCreateForm || showEditForm)
    {
        <div class="mb-5 pb-4" style="border-bottom: 1px solid var(--border-light);">
            <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">
                @(showCreateForm ? "Tạo môn học mới" : "Chỉnh sửa thông tin môn học")
            </h4>
            <div class="row mt-3">
                <div class="col-md-3 mb-4">
                    <input type="text" class="form-inline-zen w-100" @bind="courseModel.Code" placeholder="Mã môn học (*)" disabled="@showEditForm" required />
                </div>
                <div class="col-md-9 mb-4">
                    <input type="text" class="form-inline-zen w-100" @bind="courseModel.Name" placeholder="Tên môn học (*)" required />
                </div>
                <div class="col-12 mb-4">
                    <textarea class="form-inline-zen w-100" rows="1" @bind="courseModel.Description" placeholder="Mô tả chi tiết nội dung (Tùy chọn)"></textarea>
                </div>
            </div>
            <div class="d-flex gap-4 mt-2">
                <button class="zen-action-link" @onclick="CancelForm">Hủy bỏ</button>
                <button class="zen-action-link text-accent fw-bold" @onclick="SaveCourse">Xác nhận lưu</button>
            </div>
        </div>
    }

    <!-- Assign Leader Form (Inline Zen) -->
    @if (showAssignForm && selectedCourseForLeader != null)
    {
        <div class="mb-5 pb-4" style="border-bottom: 1px solid var(--border-light); max-width: 600px;">
            <h4 class="font-serif mb-3 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Phân công giám sát</h4>
            <p class="text-muted small mb-4" style="font-weight: 300;">Chọn Giảng viên làm Trưởng bộ môn cho <strong>@selectedCourseForLeader.Code</strong>.</p>
            <div class="mb-4">
                <select class="form-inline-zen w-100" @bind="selectedLeaderId" style="cursor: pointer;">
                    <option value="">-- Lựa chọn Giảng viên --</option>
                    @if (lecturers != null)
                    {
                        @foreach (var lec in lecturers)
                        {
                            <option value="@lec.Id.ToString()">@lec.FullName (@lec.Username)</option>
                        }
                    }
                </select>
            </div>
            <div class="d-flex gap-4 mt-2">
                <button class="zen-action-link" @onclick="CancelAssignForm">Hủy bỏ</button>
                <button class="zen-action-link text-accent fw-bold" @onclick="SaveLeaderAssignment">Lưu phân công</button>
            </div>
        </div>
    }

    <!-- Table of Courses -->
    <div class="table-responsive zen-list-item">
        <table class="table-zen">
            <thead>
                <tr>
                    <th style="width: 15%;">Mã Môn</th>
                    <th style="width: 35%;">Tên Môn Học</th>
                    <th style="width: 25%;">Giám sát (Leader)</th>
                    <th style="width: 25%; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (filteredCourses == null)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="spinner-border text-secondary" role="status"></div>
                        </td>
                    </tr>
                }
                else if (!filteredCourses.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <span class="hanko-seal mb-2" style="opacity: 0.5;">無</span>
                            <div>Không tìm thấy môn học.</div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var course in filteredCourses)
                    {
                        <tr>
                            <td class="fw-bold text-uppercase" style="font-size: 1.1rem;">@course.Code</td>
                            <td>
                                <div style="font-size: 1.05rem;">@course.Name</div>
                                @if (!string.IsNullOrEmpty(course.Description))
                                {
                                    <div class="text-muted mt-1" style="max-width: 400px; font-weight: 300; font-size: 0.85rem; line-height: 1.6;">@course.Description</div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(course.SubjectLeaderName))
                                {
                                    <span class="text-sumi">@course.SubjectLeaderName</span>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-style: italic; font-size: 0.9rem;">Chưa phân công</span>
                                }
                            </td>
                            <td style="text-align: right;">
                                <div class="d-flex justify-content-end gap-3">
                                    <a href="/courses/@course.Code/documents" class="zen-action-link" title="Tài liệu học tập">
                                        Vào học &rarr;
                                    </a>
                                    
                                    <AuthorizeView Roles="Admin">
                                        <Authorized>
                                            <button class="zen-action-link" style="color: var(--text-muted);" @onclick="() => OpenAssignForm(course)" title="Phân công">
                                                <i class="fa-solid fa-user-gear"></i>
                                            </button>
                                            <button class="zen-action-link" style="color: var(--text-muted);" @onclick="() => OpenEditForm(course)" title="Sửa">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>
                                            <button class="zen-action-link danger" @onclick="() => DeleteCourse(course)" title="Xóa">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private IEnumerable<CourseDto>? allCourses;
    private IEnumerable<CourseDto>? filteredCourses;
    private IEnumerable<UserDto>? lecturers;
    private string searchKeyword = "";

    // Modals/Forms State
    private bool showCreateForm = false;
    private bool showEditForm = false;
    private bool showAssignForm = false;

    private CourseDto courseModel = new();
    private CourseDto? selectedCourseForLeader;
    private string selectedLeaderId = "";
    private Guid currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        Guid.TryParse(userIdStr, out currentUserId);

        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("zenInteract.initPageReveal");
            await JS.InvokeVoidAsync("zenInteract.initMagneticButtons");
        }
    }

    private async Task ShowToast(string message, string type)
    {
        await JS.InvokeVoidAsync("zenInteract.showToast", message, type);
    }

    private async Task LoadData()
    {
        try
        {
            allCourses = await CourseService.GetAllCoursesAsync();
            filteredCourses = allCourses;

            var users = await AuthService.GetAllUsersAsync();
            lecturers = users.Where(u => u.Role == "Lecturer" || u.Role == "Admin").ToList();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }

    private void FilterCourses()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            filteredCourses = allCourses;
        }
        else
        {
            var kw = searchKeyword.Trim().ToLower();
            filteredCourses = allCourses?.Where(c => c.Code.ToLower().Contains(kw) || c.Name.ToLower().Contains(kw)).ToList();
        }
    }

    private void OpenCreateForm()
    {
        showEditForm = false;
        showAssignForm = false;
        courseModel = new CourseDto();
        showCreateForm = true;
    }

    private void OpenEditForm(CourseDto course)
    {
        showCreateForm = false;
        showAssignForm = false;
        courseModel = new CourseDto
        {
            Id = course.Id,
            Code = course.Code,
            Name = course.Name,
            Description = course.Description,
            SubjectLeaderId = course.SubjectLeaderId
        };
        showEditForm = true;
    }

    private void OpenAssignForm(CourseDto course)
    {
        showCreateForm = false;
        showEditForm = false;
        selectedCourseForLeader = course;
        selectedLeaderId = course.SubjectLeaderId?.ToString() ?? "";
        showAssignForm = true;
    }

    private void CancelForm()
    {
        showCreateForm = false;
        showEditForm = false;
    }

    private void CancelAssignForm()
    {
        showAssignForm = false;
        selectedCourseForLeader = null;
    }

    private async Task SaveCourse()
    {
        if (string.IsNullOrWhiteSpace(courseModel.Code) || string.IsNullOrWhiteSpace(courseModel.Name))
        {
            await ShowToast("Vui lòng điền đủ Mã và Tên môn học", "error");
            return;
        }

        try
        {
            if (showCreateForm)
            {
                await CourseService.CreateCourseAsync(courseModel, currentUserId);
                await ShowToast($"Tạo môn học {courseModel.Code} thành công", "success");
            }
            else if (showEditForm)
            {
                await CourseService.UpdateCourseAsync(courseModel);
                await ShowToast($"Cập nhật môn học {courseModel.Code} thành công", "success");
            }

            showCreateForm = false;
            showEditForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }

    private async Task SaveLeaderAssignment()
    {
        if (selectedCourseForLeader == null) return;

        try
        {
            if (Guid.TryParse(selectedLeaderId, out var leaderId))
            {
                await CourseService.UpdateSubjectLeaderAsync(selectedCourseForLeader.Id, leaderId);
                await ShowToast("Phân công giám sát thành công", "success");
            }
            else
            {
                await ShowToast("Vui lòng chọn giảng viên", "error");
                return;
            }

            showAssignForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi phân công: {ex.Message}", "error");
        }
    }

    private async Task DeleteCourse(CourseDto course)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Xác nhận xóa môn học {course.Code}?");
        if (!confirmed) return;

        try
        {
            await CourseService.DeleteCourseAsync(course.Id);
            await ShowToast("Xóa môn học thành công", "success");
            await LoadData();
        }
        catch (Exception ex)
        {
            await ShowToast($"Lỗi: {ex.Message}", "error");
        }
    }
}
