@model RAGChatBot.Application.DTOs.LoginRequest
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - RAG ChatBot</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #311042 100%);
            --card-bg: rgba(30, 41, 59, 0.7);
            --border-color: rgba(255, 255, 255, 0.08);
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --text-main: #f8fafc;
            --text-sub: #94a3b8;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-gradient);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow-x: hidden;
        }

        .login-container {
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        .login-card {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            transition: all 0.3s ease;
        }

        .login-card:hover {
            border-color: rgba(99, 102, 241, 0.3);
            box-shadow: 0 20px 40px rgba(99, 102, 241, 0.1);
        }

        .brand-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .brand-logo h1 {
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(to right, #818cf8, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }

        .brand-logo p {
            color: var(--text-sub);
            font-size: 0.95rem;
            margin-top: 8px;
        }

        .form-label {
            color: var(--text-sub);
            font-weight: 500;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .form-control {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            color: var(--text-main) !important;
            padding: 12px 16px;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            background: rgba(15, 23, 42, 0.8);
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
            outline: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color) 0%, #a855f7 100%);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99, 102, 241, 0.4);
            color: white;
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .alert-custom {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            color: #fca5a5;
            padding: 12px;
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .demo-accounts {
            margin-top: 25px;
            padding: 15px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            font-size: 0.85rem;
        }

        .demo-accounts table {
            width: 100%;
            margin-top: 8px;
            color: var(--text-sub);
        }

        .demo-accounts td {
            padding: 3px 0;
        }

        .demo-accounts strong {
            color: #c084fc;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="brand-logo">
                <h1>RAG ChatBot</h1>
                <p>Hệ thống Quản trị & Trợ lý Tri thức AI</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-custom">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div class="mb-3">
                    <label for="Username" class="form-label">Tên tài khoản</label>
                    <input type="text" class="form-control" id="Username" name="Username" placeholder="Nhập tài khoản giảng viên..." required autofocus />
                </div>
                <div class="mb-4">
                    <label for="Password" class="form-label">Mật khẩu</label>
                    <input type="password" class="form-control" id="Password" name="Password" placeholder="Nhập mật khẩu..." required />
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-3">Đăng Nhập</button>
            </form>

            <div class="demo-accounts">
                <div class="text-center" style="color: var(--text-main); font-weight: 600;">🔑 Tài khoản thử nghiệm (mật khẩu: password123)</div>
                <table>
                    <tr>
                        <td>Free (Giảng viên):</td>
                        <td><strong>lecturer_free</strong></td>
                    </tr>
                    <tr>
                        <td>Premium (Giảng viên):</td>
                        <td><strong>lecturer_premium</strong></td>
                    </tr>
                    <tr>
                        <td>Admin:</td>
                        <td><strong>admin</strong></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
