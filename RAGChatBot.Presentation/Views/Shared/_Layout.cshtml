<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG ChatBot</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --sidebar-bg: #f8f9fa;
            --sidebar-border: #e9ecef;
            --text-main: #0f172a;
            --text-sub: #475569;
            --primary: #0ea5e9;
            --hover-bg: #f1f5f9;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: #ffffff;
            color: var(--text-main);
            height: 100vh;
            margin: 0;
            display: flex;
            overflow: hidden;
        }

        /* Sidebar Styling */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--sidebar-border);
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
            z-index: 1000;
        }
        
        .sidebar.collapsed {
            transform: translateX(-260px);
            margin-right: -260px;
        }

        .sidebar-header {
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--sidebar-border);
        }

        .sidebar-brand {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--text-main);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand i {
            color: var(--primary);
        }

        .sidebar-content {
            flex: 1;
            padding: 15px 10px;
            overflow-y: auto;
        }

        .nav-item-custom {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 15px;
            color: var(--text-main);
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
            margin-bottom: 5px;
        }

        .nav-item-custom:hover, .nav-item-custom.active {
            background-color: var(--hover-bg);
            color: var(--primary);
        }

        .nav-item-custom i {
            width: 20px;
            text-align: center;
            color: var(--text-sub);
        }
        
        .nav-item-custom:hover i, .nav-item-custom.active i {
            color: var(--primary);
        }

        .sidebar-footer {
            padding: 15px;
            border-top: 1px solid var(--sidebar-border);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
            padding: 5px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .user-details {
            flex: 1;
            overflow: hidden;
        }

        .user-name {
            font-size: 0.9rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-sub);
        }

        /* Main Content */
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }
        
        .main-header {
            height: 60px;
            padding: 0 20px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--sidebar-border);
            background: white;
        }
        
        .toggle-sidebar-btn {
            background: transparent;
            border: none;
            font-size: 1.2rem;
            color: var(--text-sub);
            cursor: pointer;
            padding: 5px 10px;
            border-radius: 5px;
        }
        
        .toggle-sidebar-btn:hover {
            background: var(--hover-bg);
        }

        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: absolute;
                height: 100vh;
                transform: translateX(-100%);
            }
            .sidebar.show {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="/" class="sidebar-brand">
                <i class="fa-solid fa-brain"></i> RAG ChatBot
            </a>
            <button class="toggle-sidebar-btn d-md-none" id="closeSidebarBtn">
                <i class="fa-solid fa-times"></i>
            </button>
        </div>
        
        <div class="sidebar-content">
            <a asp-controller="Home" asp-action="Index" class="nav-item-custom @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="fa-regular fa-message"></i> Màn hình Chat
            </a>
            
            @if (User.Identity?.IsAuthenticated == true)
            {
                var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                var isActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "Course" || ViewContext.RouteData.Values["Controller"]?.ToString() == "Document";
                <a asp-controller="Course" asp-action="Index" class="nav-item-custom @(isActive ? "active" : "")">
                    <i class="fa-regular fa-folder-open"></i> 
                    Môn Học
                </a>
            }
        </div>

        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Lecturer";
                var tier = User.FindFirst("SubscriptionTier")?.Value ?? "Free";
                var initial = User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U";

                <div class="user-info">
                    <div class="user-avatar">@initial</div>
                    <div class="user-details">
                        <div class="user-name">@User.Identity.Name</div>
                        <div class="user-role">@role &bull; @tier</div>
                    </div>
                </div>
                
                @if (tier == "Free")
                {
                    <a asp-controller="Subscription" asp-action="Index" class="btn w-100 fw-bold text-white mt-2 mb-1" style="background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%); border-radius: 8px; font-size: 0.85rem; padding: 8px;">
                        <i class="fa-solid fa-crown me-1" style="color: #fde047;"></i> Nâng cấp Premium
                    </a>
                }
                <a asp-controller="Account" asp-action="Logout" class="nav-item-custom text-danger mt-2" style="padding: 8px 15px;">
                    <i class="fa-solid fa-right-from-bracket text-danger"></i> Đăng xuất
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="nav-item-custom">
                    <i class="fa-solid fa-right-to-bracket"></i> Đăng nhập
                </a>
            }
        </div>
    </aside>

    <!-- Main Wrapper -->
    <div class="main-wrapper">
        <header class="main-header">
            <button class="toggle-sidebar-btn" id="toggleSidebarBtn">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="ms-3 fw-bold" style="font-size: 1.1rem; color: var(--text-main);">
                @ViewData["Title"]
            </div>
        </header>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('toggleSidebarBtn');
            const closeBtn = document.getElementById('closeSidebarBtn');

            toggleBtn.addEventListener('click', function () {
                if (window.innerWidth <= 768) {
                    sidebar.classList.toggle('show');
                } else {
                    sidebar.classList.toggle('collapsed');
                }
            });

            if (closeBtn) {
                closeBtn.addEventListener('click', function () {
                    sidebar.classList.remove('show');
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
