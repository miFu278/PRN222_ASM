@page "/Admin/Payments"
@model RAGChatBot.Presentation.Pages.Admin.PaymentsModel
@{
    ViewData["Title"] = "Quản lý Giao Dịch";
}

<div class="zen-container py-5 gsap-fade-up">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <div class="text-accent mb-2" style="font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase;">
                Admin Dashboard
            </div>
            <h1 class="font-serif m-0" style="font-size: 3rem;">Giao Dịch</h1>
        </div>
        <div class="text-muted" style="font-weight: 300;">
            <i class="fa-solid fa-receipt me-1"></i> Tổng: @Model.Transactions.Count() giao dịch
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="table-responsive">
        <table class="table-zen w-100">
            <thead>
                <tr>
                    <th style="width: 15%;">Mã đơn hàng</th>
                    <th style="width: 20%;">Người dùng</th>
                    <th style="width: 15%;">Số tiền</th>
                    <th style="width: 12%;">Mã GD PayOS</th>
                    <th style="width: 10%;">Trạng thái</th>
                    <th style="width: 14%;">Ngày tạo</th>
                    <th style="width: 14%;">Ngày thanh toán</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Transactions.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: var(--text-muted); padding: 40px 0; font-weight: 300;">
                            Chưa có giao dịch nào trong hệ thống.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var tx in Model.Transactions)
                    {
                        <tr>
                            <td style="font-family: monospace; font-size: 0.85rem;">@tx.OrderId</td>
                            <td>
                                <div style="font-weight: 500;">@tx.FullName</div>
                                <div class="text-muted" style="font-size: 0.8rem;">@tx.Username</div>
                            </td>
                            <td style="font-weight: 500;">@tx.Amount.ToString("N0")đ</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@(tx.TransactionNo ?? "-")</td>
                            <td>
                                @if (tx.Status == "Success")
                                {
                                    <span class="badge" style="background: #10b981; font-weight: 500; padding: 6px 12px; border-radius: 4px;">
                                        Thành công
                                    </span>
                                }
                                else if (tx.Status == "Pending")
                                {
                                    <span class="badge" style="background: #f59e0b; font-weight: 500; padding: 6px 12px; border-radius: 4px;">
                                        Đang chờ
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background: var(--accent-shu); font-weight: 500; padding: 6px 12px; border-radius: 4px;">
                                        Thất bại
                                    </span>
                                }
                            </td>
                            <td class="text-muted" style="font-size: 0.85rem;">@tx.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@(tx.PaidAt.HasValue ? tx.PaidAt.Value.AddHours(7).ToString("dd/MM/yyyy HH:mm") : "-")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            gsap.to(".gsap-fade-up", { y: 0, opacity: 1, duration: 1.2, ease: "power3.out" });
        });
    </script>
}
