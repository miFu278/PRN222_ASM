@page "/Courses/{CourseCode}/Quiz"
@model RAGChatBot.Presentation.Pages.Courses.QuizModel
@{
    ViewData["Title"] = $"Ôn Tập Trắc Nghiệm - {Model.CourseCode}";
    var isLecturerOrAdmin = User.IsInRole("Lecturer") || User.IsInRole("Admin");
}

<div class="d-none">@Html.AntiForgeryToken()</div>

<style>
    .tab-btn {
        font-size: 0.95rem;
        transition: all 0.3s;
        border-bottom: 2px solid transparent !important;
        color: var(--text-muted);
        letter-spacing: 0.05em;
        font-family: var(--font-sans);
    }
    .tab-btn:hover {
        color: var(--text-sumi);
    }
    .tab-btn.active {
        color: var(--accent-shu) !important;
        border-color: var(--accent-shu) !important;
    }
    
    .correct-option-badge {
        background-color: rgba(16, 185, 129, 0.1) !important;
        border: 1px solid rgb(16, 185, 129) !important;
        color: rgb(4, 120, 87) !important;
        border-radius: 4px;
    }
</style>

<div class="zen-container py-4 gsap-fade-up">
    <!-- Back to Documents -->
    <div class="mb-4">
        <a href="/Courses/@Model.CourseCode/Documents" class="zen-action-link text-muted small"><i class="fa-solid fa-arrow-left me-2"></i> Trở về tài liệu</a>
    </div>

    <!-- Hero Header -->
    <div class="zen-hero mb-5" style="min-height: auto;">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">
                @(isLecturerOrAdmin ? "Quản Lý Trắc Nghiệm" : "Ôn Luyện Trắc Nghiệm")
            </div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">@Model.CourseCode</h2>
        </div>
        <div class="zen-hero-desc">
            @(isLecturerOrAdmin 
                ? "Giao diện quản lý ngân hàng câu hỏi trắc nghiệm, thiết lập đề thi và theo dõi kết quả làm bài của học viên." 
                : "Hệ thống hiển thị danh sách các bài trắc nghiệm do giảng viên thiết lập. Hãy làm bài để đánh giá mức độ hiểu bài của bạn.")
        </div>
    </div>

    @if (isLecturerOrAdmin)
    {
        <!-- Tabs for Lecturer/Admin -->
        <div class="d-flex border-bottom mb-5">
            <button class="tab-btn active me-4 pb-2 fw-bold border-0 bg-transparent" onclick="switchTab('questionBank')" id="tab-questionBank">
                Ngân Hàng Câu Hỏi
            </button>
            <button class="tab-btn me-4 pb-2 fw-bold border-0 bg-transparent" onclick="switchTab('quizBuilder')" id="tab-quizBuilder">
                Quản Lý Đề Thi
            </button>
            <button class="tab-btn pb-2 fw-bold border-0 bg-transparent" onclick="switchTab('studentAttempts')" id="tab-studentAttempts">
                Kết Quả Học Viên
            </button>
        </div>

        <!-- Question Bank Section -->
        <div id="questionBankSection">
            <!-- AI Generation Control Boxless -->
            <div class="zen-list-item mb-4" style="padding: 24px; border: 1px solid var(--border-light); background: var(--bg-washi);">
                <div>
                    <h5 class="font-serif mb-2" style="font-size: 1.1rem; color: var(--text-sumi);"><i class="fa-solid fa-wand-magic-sparkles text-accent me-2"></i>Sinh câu hỏi trắc nghiệm bằng AI</h5>
                    <p class="text-muted small mb-4">Hệ thống sẽ quét nội dung tài liệu đã chọn để tự động phân tích và tạo ngân hàng câu hỏi trắc nghiệm (lên tới 100 câu).</p>
                    
                    <div class="d-flex align-items-end gap-3 flex-wrap">
                        <div style="flex: 1; min-width: 250px;">
                            <label class="text-muted mb-2 small text-uppercase tracking-wider">Chọn tài liệu đã duyệt</label>
                            <select id="aiDocSelect" class="form-select" style="border-radius: 0; border: 1px solid var(--border-light); font-size: 0.9rem; background-color: transparent;">
                                <option value="">-- Đang tải tài liệu... --</option>
                            </select>
                        </div>
                        <button type="button" class="btn-zen primary" id="generateAiBtn" onclick="triggerAiGeneration()">
                            <span class="gen-text">Bắt đầu sinh câu hỏi</span>
                            <span class="gen-spinner d-none">
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                Đang sinh câu hỏi...
                            </span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="text-muted"><span id="qCount" class="fw-bold text-accent">0</span> câu hỏi trong ngân hàng</div>
                <div class="d-flex gap-3">
                    <button class="btn-zen" onclick="openAddQuestionModal()"><i class="fa-solid fa-plus me-2"></i>Thêm Câu Hỏi</button>
                    <input type="text" id="qSearch" class="input-zen" placeholder="Tìm kiếm câu hỏi..." style="max-width: 300px; font-size: 0.9rem;" onkeyup="filterQuestions()" />
                </div>
            </div>

            <div id="quizLoadingBank" class="text-center py-5">
                <span class="spinner-border spinner-border-sm text-secondary me-2"></span>
                <span class="text-muted" style="font-weight: 300;">Đang tải ngân hàng câu hỏi...</span>
            </div>

            <div id="quizEmptyBank" class="text-center py-5" style="display: none;">
                <span class="hanko-seal mb-3 d-block mx-auto" style="opacity: 0.4; width: 48px; height: 48px; font-size: 1.4rem;">無</span>
                <div style="font-weight: 300;" class="text-muted">Chưa có câu hỏi trắc nghiệm nào cho môn học này.<br>Vui lòng duyệt tài liệu để hệ thống sinh câu hỏi tự động.</div>
            </div>

            <div id="questionBankList" class="d-flex flex-column gap-4"></div>
            
            <!-- Question Bank Pagination -->
            <div id="questionBankPagination"></div>
        </div>

        <!-- Quiz Builder Section -->
        <div id="quizBuilderSection" style="display: none;">
            <!-- Create Quiz Boxless -->
            <div class="zen-list-item mb-4" style="padding: 24px; border: 1px solid var(--border-light); background: var(--bg-washi);">
                <form id="createQuizForm">
                    <h5 class="font-serif mb-4" style="font-size: 1.15rem; color: var(--text-sumi);"><i class="fa-solid fa-file-signature text-accent me-2"></i>Thiết lập bài trắc nghiệm mới</h5>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="text-muted mb-2 small text-uppercase tracking-wider">Tiêu đề bài trắc nghiệm</label>
                            <input type="text" id="quizTitleInput" class="input-zen" required placeholder="Ví dụ: Bài kiểm tra Chương 1, Thi giữa kỳ thử..." style="font-size: 0.95rem;" />
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted mb-2 small text-uppercase tracking-wider">Số lượng câu hỏi</label>
                            <input type="number" id="quizQuestionCountInput" class="input-zen" required min="5" max="100" value="20" style="font-size: 0.95rem;" />
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted mb-2 small text-uppercase tracking-wider">Phạm vi tài liệu</label>
                            <select id="quizDocSelect" class="form-select" style="border-radius: 0; border: 1px solid var(--border-light); font-size: 0.95rem; background-color: transparent;">
                                <option value="">Tất cả tài liệu môn học</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-4 mb-4">
                        <div class="col-md-2">
                            <label class="text-muted mb-2 small text-uppercase">Số lần làm tối đa</label>
                            <input type="number" id="quizMaxAttemptsInput" class="input-zen" min="1" max="100" value="1" required />
                        </div>
                        <div class="col-md-2">
                            <label class="text-muted mb-2 small text-uppercase">Thời gian (phút)</label>
                            <input type="number" id="quizDurationInput" class="input-zen" min="1" max="300" value="30" required />
                        </div>
                        <div class="col-md-2">
                            <label class="text-muted mb-2 small text-uppercase">Mật khẩu (không bắt buộc)</label>
                            <input type="password" id="quizPasswordInput" class="input-zen" autocomplete="new-password" />
                        </div>
                        <div class="col-md-3">
                            <label class="text-muted mb-2 small text-uppercase">Quyền xem lại</label>
                            <select id="quizReviewPolicyInput" class="form-select">
                                <option value="0">Chỉ xem điểm</option>
                                <option value="1">Xem câu đã làm</option>
                                <option value="2">Xem cả đáp án đúng</option>
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end gap-3 pb-2">
                            <label><input type="checkbox" id="quizShuffleQuestionsInput" checked /> Trộn câu hỏi</label>
                            <label><input type="checkbox" id="quizShuffleOptionsInput" checked /> Trộn đáp án</label>
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn-zen primary">Tạo Bài Trắc Nghiệm</button>
                    </div>
                </form>
            </div>

            <div class="mb-4 text-muted"><span id="quizCount" class="fw-bold text-accent">0</span> bài trắc nghiệm đã thiết lập</div>

            <div id="quizzesLoading" class="text-center py-5">
                <span class="spinner-border spinner-border-sm text-secondary me-2"></span>
                <span class="text-muted" style="font-weight: 300;">Đang tải danh sách bài trắc nghiệm...</span>
            </div>

            <div id="quizzesEmpty" class="text-center py-5" style="display: none;">
                <span class="hanko-seal mb-3 d-block mx-auto" style="opacity: 0.4; width: 48px; height: 48px; font-size: 1.4rem;">空</span>
                <div style="font-weight: 300;" class="text-muted">Chưa có bài trắc nghiệm nào được tạo. Hãy sử dụng form trên để tạo mới.</div>
            </div>

            <div id="quizzesTableWrapper" class="table-responsive" style="display: none;">
                <table class="table-zen w-100">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--border-light); font-size: 0.85rem; text-transform: uppercase; color: var(--text-muted);">
                            <th class="ps-4">Tiêu Đề</th>
                            <th>Số Câu Hỏi</th>
                            <th>Phạm Vi Tài Liệu</th>
                            <th>Ngày Tạo</th>
                            <th class="pe-4 text-end">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="quizzesList"></tbody>
                </table>
            </div>
            
            <!-- Quizzes Pagination -->
            <div id="quizPagination"></div>
        </div>

        <!-- Student Attempts Section -->
        <div id="studentAttemptsSection" style="display: none;">
            <div class="mb-4 text-muted"><span id="aCount" class="fw-bold text-accent">0</span> lượt làm bài của học viên</div>
            
            <div id="attemptsLoading" class="text-center py-5">
                <span class="spinner-border spinner-border-sm text-secondary me-2"></span>
                <span class="text-muted" style="font-weight: 300;">Đang tải kết quả...</span>
            </div>

            <div id="attemptsEmpty" class="text-center py-5" style="display: none;">
                <span class="hanko-seal mb-3 d-block mx-auto" style="opacity: 0.4; width: 48px; height: 48px; font-size: 1.4rem;">空</span>
                <div style="font-weight: 300;" class="text-muted">Chưa có sinh viên nào thực hiện bài trắc nghiệm môn này.</div>
            </div>

            <div id="attemptsTableWrapper" class="table-responsive" style="display: none;">
                <table class="table-zen w-100">
                    <thead>
                        <tr style="border-bottom: 2px solid var(--border-light); font-size: 0.85rem; text-transform: uppercase; color: var(--text-muted);">
                            <th class="ps-4">Học Viên</th>
                            <th>Mã Sinh Viên</th>
                            <th>Bài Trắc Nghiệm</th>
                            <th>Thời Gian</th>
                            <th>Số Câu Đúng</th>
                            <th>Tỷ Lệ Đúng</th>
                            <th class="pe-4 text-end">Đánh Giá</th>
                        </tr>
                    </thead>
                    <tbody id="attemptsList"></tbody>
                </table>
            </div>
            
            <!-- Attempts Pagination -->
            <div id="attemptsPagination"></div>
        </div>
    }
    else
    {
        <!-- Student Quiz View -->
        <!-- Quiz Selection List -->
        <div id="studentQuizListPanel">
            <h5 class="font-serif mb-4" style="font-size: 1.25rem;"><i class="fa-solid fa-list-check text-accent me-2"></i>Danh sách bài trắc nghiệm</h5>
            
            <div id="studentQuizzesLoading" class="text-center py-5">
                <span class="spinner-border spinner-border-sm text-secondary me-2"></span>
                <span class="text-muted" style="font-weight: 300;">Đang tải danh sách bài thi...</span>
            </div>

            <div id="studentQuizzesEmpty" class="text-center py-5" style="display: none;">
                <span class="hanko-seal mb-3 d-block mx-auto" style="opacity: 0.4; width: 48px; height: 48px; font-size: 1.4rem;">無</span>
                <div style="font-weight: 300;" class="text-muted">Hiện tại môn học chưa có bài trắc nghiệm nào do Giảng viên thiết lập.</div>
            </div>

            <div id="studentQuizCards" class="row g-4"></div>
            <h5 class="font-serif mt-5 mb-3">Lịch sử làm bài của tôi</h5>
            <div id="myAttemptsList" class="d-flex flex-column gap-2"></div>
        </div>

        <!-- Student Quiz Taker Loading Screen -->
        <div id="quizLoading" class="text-center py-5" style="display: none;">
            <span class="spinner-border spinner-border-sm text-secondary me-2"></span>
            <span class="text-muted" style="font-weight: 300;">Đang tạo đề và chuẩn bị câu hỏi...</span>
        </div>

        <!-- Student Quiz Wizard (Paginated) -->
        <form id="quizForm" style="display: none;">
            <div id="studentQuizWizard"></div>
        </form>
    }
</div>

<!-- Place Modals outside zen-container at the root level to prevent transform/stacking context layout bugs -->
@if (isLecturerOrAdmin)
{
    <!-- Add/Edit Question Modal -->
    <div class="modal fade" id="questionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" style="background: var(--bg-washi); border: 1px solid var(--border-light); border-radius: 0;">
                <div class="modal-header" style="border-bottom: 1px solid var(--border-light);">
                    <h5 class="modal-title font-serif" id="questionModalTitle">Thêm Câu Hỏi</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="questionForm">
                    <input type="hidden" id="qIdInput" />
                    <div class="modal-body py-4">
                        <div class="mb-3">
                            <label class="text-muted mb-2 small text-uppercase tracking-wider">Nội dung câu hỏi</label>
                            <textarea id="qTextInput" class="form-control" rows="3" required style="border-radius: 0; border: 1px solid var(--border-light); font-size: 0.95rem;"></textarea>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="text-muted mb-2 small text-uppercase tracking-wider">Đáp án A</label>
                                <input type="text" id="qOptAInput" class="input-zen" required style="font-size: 0.9rem;" />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted mb-2 small text-uppercase tracking-wider">Đáp án B</label>
                                <input type="text" id="qOptBInput" class="input-zen" required style="font-size: 0.9rem;" />
                            </div>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="text-muted mb-2 small text-uppercase tracking-wider">Đáp án C</label>
                                <input type="text" id="qOptCInput" class="input-zen" required style="font-size: 0.9rem;" />
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted mb-2 small text-uppercase tracking-wider">Đáp án D</label>
                                <input type="text" id="qOptDInput" class="input-zen" required style="font-size: 0.9rem;" />
                            </div>
                        </div>
                        <div>
                            <label class="text-muted mb-2 small text-uppercase tracking-wider">Đáp án đúng</label>
                            <select id="qCorrectInput" class="form-select" required style="border-radius: 0; border: 1px solid var(--border-light); font-size: 0.95rem;">
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: none;">
                        <button type="button" class="zen-action-link" data-bs-dismiss="modal" style="margin-right: 20px;">Hủy</button>
                        <button type="submit" class="btn-zen primary">Lưu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <!-- Result Modal (For Students) -->
    <div class="modal fade" id="resultModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: var(--bg-washi); border: 1px solid var(--border-light); border-radius: 0;">
                <div class="modal-body text-center py-5 px-4">
                    <div class="hanko-seal mx-auto mb-4" style="width: 64px; height: 64px; font-size: 1.8rem;" id="resultSeal">点</div>
                    <h3 class="font-serif mb-3" id="resultTitle">Kết Quả</h3>
                    <div class="mb-3" style="font-size: 3rem; font-weight: 500; font-family: var(--font-serif);">
                        <span id="resultScore">0</span> / <span id="resultTotal">0</span>
                    </div>
                    <div class="text-muted mb-4" style="font-weight: 300;">
                        Tỷ lệ đúng: <strong id="resultPercent">0</strong>%
                    </div>
                    <div class="d-flex gap-3 justify-content-center">
                        <button type="button" class="btn-zen" id="reviewResultButton">Xem lại bài làm</button>
                        <button class="btn-zen primary" onclick="location.reload()">Quay Lại Danh Sách</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content" style="background: var(--bg-washi); border-radius: 0;">
            <div class="modal-header">
                <h5 class="modal-title font-serif">Chi tiết lượt làm bài</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="reviewModalBody"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="appDialogModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: var(--bg-washi); border: 1px solid var(--border-light); border-radius: 0;">
            <div class="modal-header" style="border-bottom: 1px solid var(--border-light);">
                <h5 class="modal-title font-serif" id="appDialogTitle">Thông báo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body p-4">
                <p id="appDialogMessage" class="mb-0" style="white-space: pre-line;"></p>
                <input type="password" id="appDialogInput" class="input-zen mt-3" style="display: none;" autocomplete="current-password" />
            </div>
            <div class="modal-footer" style="border-top: 1px solid var(--border-light);">
                <button type="button" class="zen-action-link" id="appDialogCancel">Hủy</button>
                <button type="button" class="btn-zen primary" id="appDialogConfirm">Đồng ý</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
(function () {
    const courseCode = '@Model.CourseCode';
    const isLecturerOrAdmin = @(isLecturerOrAdmin ? "true" : "false");
    const antiforgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
    const jsonHeaders = {
        'Content-Type': 'application/json',
        'RequestVerificationToken': antiforgeryToken
    };
    let handleQuizRealtime = () => {};

    function openAppDialog({ title, message, mode = 'notice', confirmText = 'Đồng ý' }) {
        return new Promise(resolve => {
            const element = document.getElementById('appDialogModal');
            const modal = bootstrap.Modal.getOrCreateInstance(element);
            const input = document.getElementById('appDialogInput');
            const cancelButton = document.getElementById('appDialogCancel');
            const confirmButton = document.getElementById('appDialogConfirm');
            let settled = false;

            document.getElementById('appDialogTitle').textContent = title;
            document.getElementById('appDialogMessage').textContent = message;
            confirmButton.textContent = confirmText;
            cancelButton.style.display = mode === 'notice' ? 'none' : '';
            input.style.display = mode === 'prompt' ? '' : 'none';
            input.value = '';

            const finish = value => {
                if (settled) return;
                settled = true;
                modal.hide();
                resolve(value);
            };

            confirmButton.onclick = () => finish(mode === 'prompt' ? input.value : true);
            cancelButton.onclick = () => finish(mode === 'prompt' ? null : false);
            element.addEventListener('hidden.bs.modal', () => {
                if (!settled) {
                    settled = true;
                    resolve(mode === 'prompt' ? null : false);
                }
            }, { once: true });
            element.addEventListener('shown.bs.modal', () => {
                if (mode === 'prompt') input.focus();
            }, { once: true });
            input.onkeydown = event => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    confirmButton.click();
                }
            };
            modal.show();
        });
    }

    const showNotice = message => openAppDialog({ title: 'Thông báo', message, mode: 'notice', confirmText: 'Đóng' });
    const showConfirm = message => openAppDialog({ title: 'Xác nhận', message, mode: 'confirm', confirmText: 'Xác nhận' });
    const showPasswordPrompt = message => openAppDialog({ title: 'Mật khẩu bài thi', message, mode: 'prompt', confirmText: 'Bắt đầu' });

