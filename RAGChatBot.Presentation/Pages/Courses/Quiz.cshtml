        // Generic pagination renderer utility
        function renderPaginationControls(paginationState, containerId, onPageChange) {
            const container = document.getElementById(containerId);
            if (!container) return;
            
            const total = paginationState.totalPages();
            const current = paginationState.currentPage;
            
            if (total <= 1) {
                container.innerHTML = '';
                return;
            }
            
            container.innerHTML = `
                <div class="d-flex justify-content-center align-items-center gap-3 mt-4">
                    <button class="zen-action-link" 
                            ${current === 1 ? 'disabled' : ''} 
                            onclick="triggerPageChange('${containerId}', -1)" style="color: ${current === 1 ? 'var(--text-muted)' : 'var(--text-sumi)'}; opacity: ${current === 1 ? 0.4 : 1}; cursor: ${current === 1 ? 'not-allowed' : 'pointer'};">
                        &larr; Trang trước
                    </button>
                    <span class="small text-muted">Trang <strong>${current}</strong> / ${total}</span>
                    <button class="zen-action-link" 
                            ${current === total ? 'disabled' : ''} 
                            onclick="triggerPageChange('${containerId}', 1)" style="color: ${current === total ? 'var(--text-muted)' : 'var(--text-sumi)'}; opacity: ${current === total ? 0.4 : 1}; cursor: ${current === total ? 'not-allowed' : 'pointer'};">
                        Trang sau &rarr;
                    </button>
                </div>
            `;
        }

        window.triggerPageChange = function (cId, direction) {
            let state;
            let callback;
            if (cId === 'questionBankPagination') {
                state = questionPaginationState;
                callback = renderQuestions;
            } else if (cId === 'quizPagination') {
                state = quizPaginationState;
                callback = renderLecturerQuizzes;
            } else if (cId === 'attemptsPagination') {
                state = attemptPaginationState;
                callback = renderAttempts;
            }

            if (state) {
                if (direction === 1) state.next();
                else state.prev();
                callback();
                renderPaginationControls(state, cId, callback);
            }
        };

        const realtimeRefreshTimers = new Map();
        handleQuizRealtime = function (change) {
            if (!change?.type) return;
            clearTimeout(realtimeRefreshTimers.get(change.type));
            realtimeRefreshTimers.set(change.type, setTimeout(() => {
                if (change.type === 'QuizCatalogChanged') {
                    loadLecturerQuizzes();
                } else if (change.type === 'QuestionBankChanged') {
                    setAiGenerationBusy(false);
                    fetchQuestionBank();
                } else if (change.type === 'AttemptSubmitted') {
                    loadStudentAttempts();
                } else if (change.type === 'QuestionBankGenerationStarted') {
                    setAiGenerationBusy(true);
                } else if (change.type === 'QuestionBankGenerationFailed') {
                    setAiGenerationBusy(false);
                    showNotice('Sinh câu hỏi bằng AI thất bại. Vui lòng kiểm tra tài liệu và thử lại.');
                }
            }, 200));
        };

