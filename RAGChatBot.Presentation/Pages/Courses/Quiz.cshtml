        // Student View Logic
        const studentQuizListPanel = document.getElementById('studentQuizListPanel');
        const studentQuizCards = document.getElementById('studentQuizCards');
        const studentQuizzesLoading = document.getElementById('studentQuizzesLoading');
        const studentQuizzesEmpty = document.getElementById('studentQuizzesEmpty');
        
        const quizLoading = document.getElementById('quizLoading');
        const quizForm = document.getElementById('quizForm');
        const studentQuizWizard = document.getElementById('studentQuizWizard');

        // Quiz State for Student Taker
        let currentQuizId = null;
        let currentAttemptId = null;
        let currentQuizTitle = '';
        let availableQuizzes = [];
        let studentQuestions = [];
        let currentQuestionIndex = 0;
        let studentAnswers = {}; // Map of qId -> selected option
        let attemptExpiresAt = null;
        let quizTimerId = null;
        let isSubmittingQuiz = false;

        function loadStudentQuizCatalog() {
            studentQuizzesEmpty.style.display = 'none';
            if (studentQuizCards.children.length === 0) studentQuizzesLoading.style.display = 'block';
            fetch(`/api/quiz?handler=Quizzes&courseCode=${encodeURIComponent(courseCode)}`)
            .then(res => res.json())
            .then(data => {
                studentQuizzesLoading.style.display = 'none';
                availableQuizzes = data || [];

                if (!data || data.length === 0) {
                    studentQuizCards.innerHTML = '';
                    studentQuizzesEmpty.style.display = 'block';
                    return;
                }

                studentQuizCards.innerHTML = '';
                data.forEach(q => {
                    const col = document.createElement('div');
                    col.className = 'col-md-6 col-lg-4';
                    col.innerHTML = `
                        <div class="zen-list-item h-100" style="background: var(--bg-washi); border: 1px solid var(--border-light); padding: 24px; transition: border-color 0.2s; display: flex; flex-direction: column;" 
                             onmouseover="this.style.borderColor='var(--accent-shu)'" onmouseout="this.style.borderColor='var(--border-light)'">
                            <h5 class="font-serif mb-2" style="font-size: 1.15rem; color: var(--text-sumi);">${escapeHtml(q.title)}</h5>
                            <div class="text-muted small mb-4 flex-grow-1">
                                <div class="mb-1"><i class="fa-solid fa-circle-question me-2"></i>Số lượng: <strong>${q.questionCount} câu hỏi</strong></div>
                                <div class="mb-1"><i class="fa-regular fa-clock me-2"></i>Thời gian: <strong>${q.durationMinutes} phút</strong></div>
                                <div><i class="fa-solid fa-book-open me-2"></i>Nội dung: <strong>${q.documentId ? 'Giới hạn theo tài liệu' : 'Toàn bộ bài giảng'}</strong></div>
                            </div>
                            <div class="small text-muted mb-3">Đã làm ${q.attemptsUsed}/${q.maxAttempts} lần ${q.hasPassword ? ' · cần mật khẩu' : ''}</div>
                            <button type="button" class="btn-zen primary w-100 py-2" ${q.attemptsUsed >= q.maxAttempts ? 'disabled' : ''} onclick="startStudentQuiz('${q.id}', ${q.hasPassword ? 'true' : 'false'})">
                                <i class="fa-solid fa-file-signature me-2"></i>Làm Bài Thi
                            </button>
                        </div>
                    `;
                    studentQuizCards.appendChild(col);
                });
            })
            .catch(err => {
                studentQuizzesLoading.style.display = 'none';
                studentQuizzesEmpty.style.display = 'block';
                console.error('Lỗi tải danh sách bài thi:', err);
            });
        }
        loadStudentQuizCatalog();

        handleQuizRealtime = function (change) {
            if (change?.type === 'QuizCatalogChanged') loadStudentQuizCatalog();
        };

        async function loadMyAttempts() {
            const response = await fetch(`/api/quiz?handler=MyAttempts&courseCode=${encodeURIComponent(courseCode)}`);
            const data = response.ok ? await response.json() : [];
            const container = document.getElementById('myAttemptsList');
            container.innerHTML = data.length === 0 ? '<span class="text-muted">Chưa có lượt làm bài.</span>' : data.map(a => `
                <div class="d-flex justify-content-between align-items-center border-top py-3">
                    <span>${escapeHtml(a.quizTitle)} — lần ${a.attemptNumber}: <strong>${a.score}/${a.totalQuestions}</strong> (${a.percentage}%)</span>
                    <button class="zen-action-link" onclick="viewAttemptDetails('${a.id}', false)">Xem lại</button>
                </div>`).join('');
        }
        loadMyAttempts();

        window.startStudentQuiz = async function (quizId, hasPassword) {
            currentQuizId = quizId;
            currentQuizTitle = availableQuizzes.find(q => q.id === quizId)?.title || 'Bài trắc nghiệm';
            studentAnswers = {};
            currentQuestionIndex = 0;

            let password = null;
            if (hasPassword) {
                password = await showPasswordPrompt('Nhập mật khẩu để bắt đầu lượt làm bài:');
                if (password === null) return;
            }

            studentQuizListPanel.style.display = 'none';
            quizLoading.style.display = 'block';

            fetch('/api/quiz?handler=StartAttempt', {
                method: 'POST',
                headers: jsonHeaders,
                body: JSON.stringify({ quizId, password })
            })
                .then(async res => ({ ok: res.ok, data: await res.json() }))
                .then(({ ok, data }) => {
                    quizLoading.style.display = 'none';
                    if (!ok || !data.questions || data.questions.length === 0) {
                        showNotice(data.error || 'Bài trắc nghiệm này chưa có câu hỏi nào trong ngân hàng đề. Vui lòng liên hệ giảng viên.');
                        studentQuizListPanel.style.display = 'block';
                        return;
                    }

                    currentAttemptId = data.attemptId;
                    attemptExpiresAt = new Date(data.expiresAt);
                    studentQuestions = data.questions;
                    quizForm.style.display = 'block';
                    renderStudentQuestion();
                    startQuizTimer();
                })
                .catch(err => {
                    quizLoading.style.display = 'none';
                    studentQuizListPanel.style.display = 'block';
                    showNotice('Lỗi tải đề thi. Vui lòng tải lại trang.');
                    console.error(err);
                });
        };

        function startQuizTimer() {
            if (quizTimerId) clearInterval(quizTimerId);
            updateQuizTimer();
            quizTimerId = setInterval(updateQuizTimer, 1000);
        }

        function updateQuizTimer() {
            if (!attemptExpiresAt) return;
            const remainingSeconds = Math.max(0, Math.ceil((attemptExpiresAt.getTime() - Date.now()) / 1000));
            const timer = document.getElementById('quizTimer');
            if (timer) {
                const minutes = Math.floor(remainingSeconds / 60).toString().padStart(2, '0');
                const seconds = (remainingSeconds % 60).toString().padStart(2, '0');
                timer.textContent = `${minutes}:${seconds}`;
                timer.classList.toggle('text-danger', remainingSeconds <= 60);
            }
            if (remainingSeconds === 0) {
                clearInterval(quizTimerId);
                quizTimerId = null;
                submitWizardQuiz(true);
            }
        }

        // Render Wizard Question
        function renderStudentQuestion() {
            studentQuizWizard.innerHTML = '';
            
            const q = studentQuestions[currentQuestionIndex];
            const total = studentQuestions.length;
            const progressPercent = Math.round((currentQuestionIndex + 1) * 100 / total);
            const savedAnswer = studentAnswers[q.id] || '';

            const buildOptionRadio = (letter, text) => {
                const isChecked = savedAnswer === letter ? 'checked' : '';
                return `
                    <label class="d-flex align-items-center gap-3 p-3 mb-2" style="cursor: pointer; border: 1px solid var(--border-light); transition: all 0.2s; background: var(--bg-washi);"
                           onmouseover="this.style.borderColor='var(--accent-shu)'" onmouseout="this.style.borderColor='var(--border-light)'">
                        <input type="radio" name="student_q" value="${letter}" ${isChecked} 
                               onchange="saveStudentAnswer('${q.id}', '${letter}')"
                               style="accent-color: var(--accent-shu); width: 18px; height: 18px;" />
                        <span><strong>${letter}.</strong> ${escapeHtml(text)}</span>
                    </label>
                `;
            };

            studentQuizWizard.innerHTML = `
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-accent fw-bold text-uppercase tracking-wider">Đề thi: ${escapeHtml(currentQuizTitle)}</span>
                        <span class="small text-muted"><i class="fa-regular fa-clock me-1"></i><strong id="quizTimer">--:--</strong> · Câu <strong>${currentQuestionIndex + 1}</strong> / ${total}</span>
                    </div>
                    <div class="progress" style="height: 6px; border-radius: 0; background-color: var(--border-light); box-shadow: none;">
                        <div class="progress-bar" role="progressbar" style="width: ${progressPercent}%; background-color: var(--accent-shu);" aria-valuenow="${progressPercent}" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                
                <div class="zen-list-item mb-4" style="background: var(--bg-washi); border: 1px solid var(--border-light); padding: 24px;">
                    <div>
                        <h5 class="font-serif mb-4" style="line-height: 1.5; font-size: 1.15rem; color: var(--text-sumi);">
                            <span class="text-accent me-2">Câu ${currentQuestionIndex + 1}.</span>
                            ${escapeHtml(q.questionText)}
                        </h5>
                        <div class="d-flex flex-column gap-2">
                            ${buildOptionRadio('A', q.optionA)}
                            ${buildOptionRadio('B', q.optionB)}
                            ${buildOptionRadio('C', q.optionC)}
                            ${buildOptionRadio('D', q.optionD)}
                        </div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="zen-action-link" 
                            ${currentQuestionIndex === 0 ? 'disabled' : ''} 
                            onclick="navigateQuestion(-1)" style="color: ${currentQuestionIndex === 0 ? 'var(--text-muted)' : 'var(--text-sumi)'}; opacity: ${currentQuestionIndex === 0 ? 0.4 : 1}; cursor: ${currentQuestionIndex === 0 ? 'not-allowed' : 'pointer'};">
                        &larr; Câu trước
                    </button>
                    
                    ${currentQuestionIndex === total - 1 
                        ? `<button type="button" class="btn-zen primary px-5 py-2" onclick="submitWizardQuiz()">Nộp Bài Thi</button>`
                        : `<button type="button" class="btn-zen px-5 py-2" onclick="navigateQuestion(1)">Câu sau &rarr;</button>`
                    }
                </div>
            `;
            updateQuizTimer();
        }

        window.saveStudentAnswer = function (questionId, selectedLetter) {
            studentAnswers[questionId] = selectedLetter;
        };

        window.navigateQuestion = function (direction) {
            currentQuestionIndex += direction;
            renderStudentQuestion();
        };

        window.submitWizardQuiz = async function (timeExpired = false) {
            if (isSubmittingQuiz) return;
            // Check if all questions are answered
            const total = studentQuestions.length;
            const answeredCount = Object.keys(studentAnswers).length;
            
            if (!timeExpired && answeredCount < total) {
                if (!await showConfirm(`Bạn mới trả lời ${answeredCount} / ${total} câu hỏi. Xác nhận nộp bài thi?`)) {
                    return;
                }
            } else if (!timeExpired) {
                if (!await showConfirm('Xác nhận nộp bài thi?')) return;
            }

            isSubmittingQuiz = true;
            const answersArray = studentQuestions.map(q => ({
                questionId: q.id,
                selectedAnswer: studentAnswers[q.id] || ''
            }));

            try {
                const response = await fetch('/api/quiz?handler=Submit', {
                    method: 'POST',
                    headers: jsonHeaders,
                    body: JSON.stringify({
                        attemptId: currentAttemptId,
                        answers: answersArray
                    })
                });

                const result = await response.json();

                if (result.success) {
                    if (quizTimerId) clearInterval(quizTimerId);
                    quizTimerId = null;
                    document.getElementById('resultScore').textContent = result.score;
                    document.getElementById('resultTotal').textContent = result.totalQuestions;
                    document.getElementById('resultPercent').textContent = result.percentage;
                    document.getElementById('reviewResultButton').onclick = () =>
                        viewAttemptDetails(result.attemptId || currentAttemptId, false);

                    if (result.percentage >= 80) {
                        document.getElementById('resultSeal').textContent = '優';
                        document.getElementById('resultTitle').textContent = 'Xuất Sắc!';
                    } else if (result.percentage >= 50) {
                        document.getElementById('resultSeal').textContent = '良';
                        document.getElementById('resultTitle').textContent = 'Khá Tốt!';
                    } else {
                        document.getElementById('resultSeal').textContent = '再';
                        document.getElementById('resultTitle').textContent = 'Cần Ôn Thêm';
                    }

                    new bootstrap.Modal(document.getElementById('resultModal')).show();
                } else {
                    showNotice(result.error || 'Có lỗi xảy ra khi chấm bài.');
                }
            } catch (err) {
                showNotice('Không thể kết nối tới máy chủ. Vui lòng thử lại.');
                console.error(err);
            } finally {
                isSubmittingQuiz = false;
            }
        };
    }

    const quizConnection = new signalR.HubConnectionBuilder()
        .withUrl('/quizHub')
        .withAutomaticReconnect([0, 2000, 5000, 10000])
        .configureLogging(signalR.LogLevel.Warning)
        .build();

    const joinQuizCourse = () => quizConnection.invoke('JoinCourseGroup', courseCode);
    quizConnection.on('QuizChanged', change => {
        if (change?.courseCode?.toLowerCase() === courseCode.toLowerCase()) {
            handleQuizRealtime(change);
        }
    });
    quizConnection.start()
        .then(joinQuizCourse)
        .catch(error => console.error('SignalR QuizHub connect error:', error.toString()));
    quizConnection.onreconnected(() => joinQuizCourse()
        .catch(error => console.error('SignalR QuizHub rejoin error:', error.toString())));

    function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str || '';
        return div.innerHTML;
    }
})();
</script>
}
