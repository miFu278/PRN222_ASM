@page "/Courses"
@model RAGChatBot.Presentation.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Môn Học";
    var isLecturer = User.IsInRole("Lecturer");
}

<style>
    .zen-course-list {
        margin-top: 40px;
        border-top: 1px solid var(--border-light);
    }
    
    .zen-course-item {
        padding: 40px 0;
        border-bottom: 1px solid var(--border-light);
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        align-items: flex-start;
        opacity: 0; /* GSAP */
        transform: translateY(20px);
        transition: background-color 0.4s ease;
    }

    .zen-course-item:hover {
        background-color: rgba(0,0,0,0.01);
    }
    
    .zen-course-code {
        font-family: var(--font-serif);
        font-size: 1.8rem;
        color: var(--text-sumi);
        min-width: 150px;
    }
    
    .zen-course-details {
        flex: 1;
        min-width: 300px;
    }

    .zen-course-title {
        font-size: 1.4rem;
        font-weight: 500;
        margin-bottom: 15px;
        color: var(--text-sumi);
    }

    .zen-course-desc {
        color: var(--text-muted);
        font-size: 1rem;
        margin-bottom: 20px;
        line-height: 1.8;
    }

    .zen-course-meta {
        font-size: 0.85rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        display: flex;
        gap: 20px;
    }
    
    .zen-course-actions {
        display: flex;
        flex-direction: column;
        gap: 15px;
        min-width: 150px;
        align-items: flex-start;
    }

    .zen-action-link {
        font-size: 0.9rem;
        color: var(--text-sumi);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        position: relative;
        padding-bottom: 4px;
        background: transparent;
        border: none;
        cursor: pointer;
        font-family: var(--font-sans);
    }

    .zen-action-link::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0;
        width: 0%;
        height: 1px;
        background-color: var(--accent-shu);
        transition: width 0.4s ease;
    }

    .zen-action-link:hover::after {
        width: 100%;
    }

    .zen-action-link.danger {
        color: var(--accent-shu);
    }

    .modal-content.zen-modal {
        background: var(--bg-washi);
        border: 1px solid var(--border-light);
        border-radius: 0;
        padding: 20px;
    }
    .modal-header.zen-modal-header {
        border-bottom: 1px solid var(--border-light);
        padding-bottom: 20px;
    }
    .modal-footer.zen-modal-footer {
        border-top: none;
        padding-top: 20px;
    }
</style>

<div class="gsap-fade-up">
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
        <div>
            <div class="text-accent mb-2" style="font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase;">
                Lưu trữ
            </div>
            <h1 class="font-serif m-0" style="font-size: 3rem;">Kho Học Liệu</h1>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <button type="button" class="btn-zen btn-edit-course" data-bs-toggle="modal" data-bs-target="#editCourseModal" data-id="" data-code="" data-name="" data-description="" data-leader-id="">
                Tạo Môn Mới
            </button>
        }
    </div>

    <!-- Search Box -->
    <div class="mb-5">
        <form method="get" class="d-flex align-items-end gap-3">
            <div style="flex: 1; max-width: 600px;">
                <input type="text" asp-for="Search" class="input-zen" placeholder="Tìm kiếm theo mã môn hoặc tên môn..." />
            </div>
            <button type="submit" class="zen-action-link">Tìm kiếm</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a href="/Courses" class="zen-action-link">Hủy</a>
            }
        </form>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4" style="color: #059669; padding: 15px 0; border-bottom: 1px solid #059669;">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4" style="color: var(--accent-shu); padding: 15px 0; border-bottom: 1px solid var(--accent-shu);">
            @TempData["ErrorMessage"]
        </div>
    }

    <div id="courseListContainer">
        @if (!Model.Courses.Any())
        {
            <div class="text-center py-5 mt-5">
                <span class="hanko-seal" style="margin-bottom: 20px;">無</span>
                <h5 class="font-serif text-muted">Trống rỗng.</h5>
            </div>
        }
        else
        {
            <div class="zen-course-list">
                @foreach (var course in Model.Courses)
                {
                    <div class="zen-course-item">
                        <div class="zen-course-code">@course.Code</div>
                        
                        <div class="zen-course-details">
                            <div class="zen-course-title">@course.Name</div>
                            <div class="zen-course-desc">
                                @(string.IsNullOrEmpty(course.Description) ? "Không có mô tả chi tiết." : course.Description)
                            </div>
                            <div class="zen-course-meta">
                                <span>Giảng viên: @course.SubjectLeaderName</span>
                                <span>Cập nhật: @course.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>

                        <div class="zen-course-actions">
                            @if (!User.IsInRole("Admin"))
                            {
                                <a href="/Courses/@course.Code/Documents" class="zen-action-link">
                                    Truy cập tài liệu &rarr;
                                </a>
                                <a href="/Courses/@course.Code/Quiz" class="zen-action-link">
                                    @(isLecturer ? "Ngân hàng câu hỏi & Kết quả" : "Ôn luyện trắc nghiệm") &rarr;
                                </a>
                            }
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <button type="button" class="zen-action-link btn-edit-course" data-bs-toggle="modal" data-bs-target="#editCourseModal" data-id="@course.Id" data-code="@course.Code" data-name="@course.Name" data-description="@course.Description" data-leader-id="@course.SubjectLeaderId">
                                    Chỉnh sửa môn học
                                </button>
                                <form method="post" asp-page-handler="Delete" data-confirm="Xác nhận xóa môn @course.Code?">
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <button type="submit" class="zen-action-link danger">
                                        Xóa môn
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="editCourseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content zen-modal">
                <div class="modal-header zen-modal-header">
                    <h5 class="modal-title font-serif" id="courseModalTitle">Tạo Môn Mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                
                <form method="post" asp-page-handler="Edit">
                    <div class="modal-body py-4">
                        <input type="hidden" id="editModalCourseId" name="Id" />
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-4">
                                <label class="text-muted mb-2" style="font-size: 0.85rem; text-transform: uppercase;">Mã môn</label>
                                <input type="text" id="editModalCourseCode" name="Code" class="input-zen" required />
                            </div>
                            <div class="col-md-8">
                                <label class="text-muted mb-2" style="font-size: 0.85rem; text-transform: uppercase;">Tên môn</label>
                                <input type="text" id="editModalCourseName" name="Name" class="input-zen" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="text-muted mb-2" style="font-size: 0.85rem; text-transform: uppercase;">Giảng viên phụ trách</label>
                            <select id="editModalLeaderSelect" name="SubjectLeaderId" class="form-select" required style="border-radius: 0; border: 1px solid var(--border-light);">
                                <option value="">-- Lựa chọn --</option>
                                @foreach (var lecturer in Model.Lecturers)
                                {
                                    <option value="@lecturer.Id">@(string.IsNullOrEmpty(lecturer.FullName) ? lecturer.Username : lecturer.FullName)</option>
                                }
                            </select>
                        </div>

                        <div class="mb-2">
                            <label class="text-muted mb-2" style="font-size: 0.85rem; text-transform: uppercase;">Mô tả</label>
                            <textarea id="editModalCourseDesc" name="Description" class="form-control" rows="3" style="border: none; border-bottom: 1px solid var(--border-light); border-radius: 0; box-shadow: none;"></textarea>
                        </div>
                    </div>
                    
                    <div class="modal-footer zen-modal-footer">
                        <button type="button" class="zen-action-link" data-bs-dismiss="modal" style="margin-right: 20px;">Hủy bỏ</button>
                        <button type="submit" class="btn-zen" id="courseModalSubmit">Tạo môn</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function applyCourseAnimations() {
                const items = document.querySelectorAll(".zen-course-item");
                if (items.length > 0) {
                    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                    if (prefersReducedMotion) {
                        gsap.set(items, { y: 0, opacity: 1 });
                    } else {
                        // Sử dụng gsap.set thay vì ghi đè transform trực tiếp để bảo vệ cache của GSAP
                        gsap.set(items, { y: 20, opacity: 0 });
                        gsap.to(items, {
                            y: 0,
                            opacity: 1,
                            duration: 1.2,
                            stagger: 0.15,
                            ease: "power2.out",
                            delay: 0.3
                        });
                    }
                }
            }
            applyCourseAnimations();

            var editCourseIdInput = document.getElementById('editModalCourseId');
            if (editCourseIdInput) {
                var editCourseCodeInput = document.getElementById('editModalCourseCode');
                var editCourseNameInput = document.getElementById('editModalCourseName');
                var editCourseLeaderSelect = document.getElementById('editModalLeaderSelect');
                var editCourseDescInput = document.getElementById('editModalCourseDesc');
                var courseModalTitle = document.getElementById('courseModalTitle');
                var courseModalSubmit = document.getElementById('courseModalSubmit');

                // Sử dụng Event Delegation để hoạt động mượt mà cả khi cập nhật DOM động qua SignalR
                document.addEventListener('click', function (e) {
                    var button = e.target.closest('.btn-edit-course');
                    if (button) {
                        var courseId = button.getAttribute('data-id');
                        var isEditingCourse = Boolean(courseId);
                        editCourseIdInput.value = courseId;
                        editCourseCodeInput.value = button.getAttribute('data-code');
                        editCourseNameInput.value = button.getAttribute('data-name');
                        editCourseDescInput.value = button.getAttribute('data-description') || "";
                        editCourseCodeInput.readOnly = isEditingCourse;
                        courseModalTitle.textContent = isEditingCourse ? 'Chỉnh Sửa Môn Học' : 'Tạo Môn Mới';
                        courseModalSubmit.textContent = isEditingCourse ? 'Lưu thay đổi' : 'Tạo môn';
                        
                        var leaderId = button.getAttribute('data-leader-id');
                        if (leaderId) {
                            editCourseLeaderSelect.value = leaderId;
                        } else {
                            editCourseLeaderSelect.value = "";
                        }
                    }
                });
            }

            // Kết nối SignalR tới /courseHub
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/courseHub")
                .withAutomaticReconnect([0, 2000, 5000, 10000])
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            let courseSyncTimer = null;
            connection.on("CourseChanged", function () {
                clearTimeout(courseSyncTimer);
                courseSyncTimer = setTimeout(syncCourseList, 200);
            });

            connection.start().then(function () {
                console.log("SignalR connected to CourseHub");
            }).catch(function (err) {
                console.error("SignalR CourseHub Connect error:", err.toString());
            });

            connection.onreconnected(syncCourseList);

            function syncCourseList() {
                fetch(window.location.href)
                    .then(res => res.text())
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, "text/html");
                        const newContainer = doc.getElementById('courseListContainer');
                        const currentContainer = document.getElementById('courseListContainer');
                        if (newContainer && currentContainer) {
                            currentContainer.innerHTML = newContainer.innerHTML;
                            applyCourseAnimations();
                            if (window.zenInteract) window.zenInteract.refreshScrollTriggers();
                        }
                    })
                    .catch(err => console.error("Lỗi đồng bộ danh sách môn học:", err));
            }
        });
    </script>
}
