@page "/Courses/{CourseCode}/Documents"
@model RAGChatBot.Presentation.Pages.Courses.DocumentsModel
@{
    ViewData["Title"] = $"Quản Lý Tài Liệu - {Model.CourseCode}";
}

<div class="zen-container py-4 gsap-fade-up">
    <!-- Back to Courses -->
    <div class="mb-4">
        <a href="/Courses" class="zen-action-link text-muted small"><i class="fa-solid fa-arrow-left me-2"></i> Trở về</a>
    </div>

    <!-- Hero Header -->
    <div class="zen-hero mb-5">
        <div class="zen-hero-title">
            <div class="text-accent fs-6 text-uppercase fw-bold tracking-wider mb-2">Quản lý tài liệu</div>
            <h2 class="font-serif m-0" style="font-size: 2.5rem;">@Model.CourseCode - @Model.CourseName</h2>
        </div>
        @{
            var isLecturerOrAdmin = User.IsInRole("Lecturer") || User.IsInRole("Admin");
        }
        <div class="zen-hero-desc d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                @if (!string.IsNullOrEmpty(Model.CourseDescription))
                {
                    <p class="text-muted m-0 mb-2">@Model.CourseDescription</p>
                }
                <div class="text-muted small" style="letter-spacing: 0.1em; text-transform: uppercase;">
                    Giám sát: @(Model.SubjectLeaderName ?? "Chưa phân công")
                </div>
            </div>
            <div>
                @if (Model.CanApprove)
                {
                    <form method="post" asp-page-handler="ReindexCourse" class="d-inline" data-confirm="Re-index sẽ tạo lại toàn bộ vector của các tài liệu đã duyệt trong môn học này. Tiếp tục?">
                        <input type="hidden" asp-for="CourseCode" />
                        <button type="submit" class="btn-zen me-2">
                            <i class="fa-solid fa-arrows-rotate me-2"></i>Re-index vectors
                        </button>
                    </form>
                }
                <a href="/Courses/@Model.CourseCode/Quiz" class="btn-zen">
                    <i class="fa-solid fa-circle-question me-2"></i>@(isLecturerOrAdmin ? "Ngân hàng câu hỏi & Kết quả" : "Làm bài trắc nghiệm")
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <div asp-validation-summary="All" class="mb-0"></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mt-5">
        <!-- Document Upload (Lecturer/Admin) -->
        @if (Model.CanUpload)
        {
            <div class="col-lg-4 mb-5 pe-lg-5 zen-list-item">
                <h4 class="font-serif mb-4 pb-2" style="border-bottom: 1px solid var(--text-sumi); display: inline-block;">Tải lên tài liệu</h4>
                
                <form method="post" asp-page-handler="Upload" enctype="multipart/form-data" id="uploadForm">
                    <input type="hidden" asp-for="CourseCode" />
                    
                    <div class="mb-4 mt-2">
                        <input asp-for="Chapter" class="form-inline-zen w-100" placeholder="Tên chương/phần tài liệu" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small text-uppercase tracking-wider">Tệp đính kèm (.pdf, .docx):</label>
                        <input type="file" asp-for="UploadedFile" class="form-inline-zen w-100" accept=".pdf,.docx" required style="padding: 0 !important; cursor: pointer;" />
                        <div class="mt-2 small text-muted" style="font-weight: 300;">
                            Giới hạn: @(Model.CurrentSubscriptionTier == "Premium" ? "50 MB (Premium)" : "5 MB (Free)")
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase tracking-wider">Chiến lược Chunking:</label>
                        <select asp-for="ChunkingStrategy" class="form-inline-zen w-100" style="cursor: pointer;">
                            <option value="Character">Character (theo ký tự)</option>
                            <option value="Word">Word (theo từ)</option>
                            <option value="Paragraph">Paragraph (theo đoạn văn)</option>
                        </select>
                    </div>

                    <div class="row mb-4">
                        <div class="col-6">
                            <label class="form-label text-muted small text-uppercase tracking-wider">Chunk Size:</label>
                            <input type="number" asp-for="ChunkSize" class="form-inline-zen w-100" min="100" max="5000" />
                        </div>
                        <div class="col-6">
                            <label class="form-label text-muted small text-uppercase tracking-wider">Overlap:</label>
                            <input type="number" asp-for="Overlap" class="form-inline-zen w-100" min="0" max="500" />
                        </div>
                    </div>

                    <button type="submit" class="btn-zen magnetic-btn w-100 mt-2" id="uploadBtn">
                        <span class="upload-text">Tải lên hệ thống</span>
                        <span class="upload-spinner d-none">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Đang xử lý...
                        </span>
                    </button>
                </form>
            </div>
        }

        <!-- Document List -->
        <div class="@(Model.CanUpload ? "col-lg-8" : "col-12") mb-5 zen-list-item" id="documentListContainer">
            @if (!Model.Documents.Any())
            {
                <div class="text-center py-5 text-muted">
                    <span class="hanko-seal mb-3 d-block mx-auto" style="opacity: 0.4; width: 48px; height: 48px; font-size: 1.4rem;">無</span>
                    <div style="font-weight: 300;">Chưa có tài liệu nào được tải lên.</div>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-0">
                    @foreach (var doc in Model.Documents)
                    {
                        <div class="doc-card zen-list-item">
                            <!-- Hàng chính của card -->
                            <div class="doc-card-main">
                                <!-- Icon + Tên file + Meta -->
                                <div class="doc-card-info">
                                    <a href="@doc.StoragePath" target="_blank" class="doc-card-name">
                                        <i class="fa-regular @(doc.FileName.EndsWith(".pdf") ? "fa-file-pdf" : "fa-file-word") me-2"></i>@doc.FileName
                                    </a>
                                    <div class="doc-card-meta">
                                        @{
                                            var sizeStr = doc.FileSize >= 1024 * 1024 ? $"{(doc.FileSize / 1024.0 / 1024.0):F2} MB" : $"{(doc.FileSize / 1024.0):F2} KB";
                                        }
                                        <span>@sizeStr</span>
                                        <span class="doc-meta-sep">·</span>
                                        <span>@doc.UploadedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        <span class="doc-meta-sep">·</span>
                                        <span>@doc.UploaderName</span>
                                        @if (!string.IsNullOrEmpty(doc.Chapter))
                                        {
                                            <span class="doc-meta-sep">·</span>
                                            <span class="doc-chapter-badge">@doc.Chapter</span>
                                        }
                                    </div>
                                </div>

                                <!-- Trạng thái + Hành động -->
                                <div class="doc-card-actions">
                                    <!-- Trạng thái -->
                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                        <div class="status-cell" data-id="@doc.Id" data-status="@doc.Status.ToString().ToLower()">
                                            <span class="processing-status">
                                                @if (doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Success)
                                                {
                                                    <span class="status-badge status-processed">Vectorized</span>
                                                }
                                                else if (doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Failed)
                                                {
                                                    <span class="status-badge status-failed" style="background: #dc3545; color: white;">Failed</span>
                                                }
                                                else if (doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Processing)
                                                {
                                                    <span class="status-badge status-processing" style="background: #17a2b8; color: white;">Processing...</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-pending">Pending...</span>
                                                }
                                            </span>
                                        </div>
                                        @if (doc.IsApproved)
                                        {
                                            <span class="status-badge status-processed text-accent">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-pending">Pending</span>
                                        }
                                    </div>

                                    <!-- Nút hành động -->
                                    <div class="d-flex gap-3 align-items-center">
                                        <button type="button" class="zen-action-link btn-view-chunks" data-id="@doc.Id" title="Xem chunks" style="@(doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Success ? "" : "display: none !important;")">
                                            <i class="fa-solid fa-eye"></i>
                                        </button>

                                        @if ((doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Failed || doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Success) && (Model.CanApprove || doc.UploadedBy == Model.CurrentUserId))
                                        {
                                            <form method="post" asp-page-handler="Retry" class="d-inline" data-confirm="Tạo lại vector cho tài liệu này?">
                                                <input type="hidden" name="documentId" value="@doc.Id" />
                                                <button type="submit" class="zen-action-link" style="color: #007bff; background: none; border: none; padding: 0;" title="@(doc.Status == RAGChatBot.Domain.Enums.DocumentStatus.Success ? "Re-index vector" : "Thử lại")">
                                                    <i class="fa-solid fa-rotate-right"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (!doc.IsApproved && Model.CanApprove)
                                        {
                                            <form method="post" asp-page-handler="Approve" class="d-inline">
                                                <input type="hidden" name="documentId" value="@doc.Id" />
                                                <button type="submit" class="zen-action-link" style="color: #28a745; background: none; border: none; padding: 0;" title="Duyệt">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            </form>
                                        }

                                        @if (Model.CanDelete || doc.UploadedBy == Model.CurrentUserId)
                                        {
                                        <form method="post" asp-page-handler="Delete" class="d-inline" data-confirm="Bạn có chắc chắn muốn xóa tài liệu này?">
                                                <input type="hidden" name="documentId" value="@doc.Id" />
                                                <button type="submit" class="zen-action-link danger" style="background: none; border: none; padding: 0;" title="Xóa">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Chunks expandable row -->
                            <div class="chunks-row" id="chunks-row-@doc.Id" style="display: none;">
                                <div class="chunks-inner">
                                    <h6 class="font-serif text-muted mb-3">Dữ liệu Vector (Chunks)</h6>
                                    <div class="chunks-container" id="chunks-container-@doc.Id">
                                        <div class="small text-muted"><span class="spinner-border spinner-border-sm text-secondary me-2"></span> Đang tải...</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        document.getElementById('uploadForm')?.addEventListener('submit', function() {
            const btn = document.getElementById('uploadBtn');
            btn.setAttribute('disabled', 'disabled');
            btn.querySelector('.upload-text').classList.add('d-none');
            btn.querySelector('.upload-spinner').classList.remove('d-none');
        });

        document.addEventListener('DOMContentLoaded', function() {
            var courseCode = '@Model.CourseCode';

            // Xem Chunks
            function attachChunkEvents() {
                document.querySelectorAll('.btn-view-chunks').forEach(btn => {
                    // Tránh gắn sự kiện nhiều lần
                    if (btn.hasAttribute('data-event-attached')) return;
                    btn.setAttribute('data-event-attached', 'true');
                    
                    btn.addEventListener('click', function() {
                        const docId = this.getAttribute('data-id');
                        const row = document.getElementById('chunks-row-' + docId);
                        const container = document.getElementById('chunks-container-' + docId);
                        
                        if (row.style.display === 'none') {
                            row.style.display = 'block';
                            this.innerHTML = '<i class="fa-solid fa-eye-slash"></i>';
                            
                            // Fetch chunks
                            fetch(`?handler=Chunks&id=${docId}`)
                                .then(res => res.json())
                                .then(data => {
                                    if (data.length === 0) {
                                        container.innerHTML = '<p class="text-muted small">Không tìm thấy phân mảnh.</p>';
                                        return;
                                    }
                                    
                                    let html = '<div class="d-flex flex-column gap-3">';
                                    data.forEach(chunk => {
                                        html += `
                                            <div>
                                                <span class="badge bg-secondary mb-1">#${chunk.chunkIndex}</span>
                                                <div class="text-muted small" style="white-space: pre-line; line-height: 1.6;">
                                                    ${chunk.content}
                                                </div>
                                            </div>
                                        `;
                                    });
                                    html += '</div>';
                                    container.innerHTML = html;
                                })
                                .catch(err => {
                                    container.innerHTML = '<div class="text-danger small">Lỗi khi tải dữ liệu</div>';
                                });
                        } else {
                            row.style.display = 'none';
                            this.innerHTML = '<i class="fa-solid fa-eye"></i>';
                        }
                    });
                });
            }

            attachChunkEvents(); // Gắn sự kiện lần đầu

            // SignalR Connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/documentHub")
                .withAutomaticReconnect([0, 2000, 5000, 10000])
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            let documentSyncTimer = null;
            function scheduleDocumentSync() {
                clearTimeout(documentSyncTimer);
                documentSyncTimer = setTimeout(syncDocumentStatuses, 200);
            }

            connection.on("DocumentChanged", function (change) {
                if (change?.courseCode?.toLowerCase() === courseCode.toLowerCase()) {
                    scheduleDocumentSync();
                }
            });

            connection.start().then(function () {
                connection.invoke("JoinCourseGroup", courseCode).catch(function (err) {
                    console.error("SignalR Join error:", err.toString());
                });
            }).catch(function (err) {
                console.error("SignalR Connect error:", err.toString());
            });

            connection.onreconnected(function () {
                connection.invoke("JoinCourseGroup", courseCode)
                    .then(scheduleDocumentSync)
                    .catch(err => console.error("SignalR Rejoin error:", err.toString()));
            });

            function syncDocumentStatuses() {
                fetch(`?handler=Status`)
                    .then(response => response.json())
                    .then(data => {
                        var currentDocs = document.querySelectorAll('.status-cell');
                        
                        // Nếu số lượng file khác nhau (Thêm/Xóa) HOẶC có người vừa Approve -> load HTML thay thế DOM (SPA)
                        let needHtmlReload = (currentDocs.length !== data.length);
                        
                        if (!needHtmlReload) {
                            data.forEach(item => {
                                var cell = document.querySelector(`.status-cell[data-id="${item.id}"]`);
                                if (cell) {
                                    var approvalBadge = cell.querySelector('.status-badge:not(.status-processed):not(.status-pending)') || cell.lastElementChild;
                                    if (item.isApproved && approvalBadge && approvalBadge.textContent.includes('Pending')) {
                                         needHtmlReload = true; 
                                    }
                                }
                            });
                        }

                        if (needHtmlReload) {
                            // Tải HTML của component document list và thay thế mượt mà
                            fetch(window.location.href)
                                .then(res => res.text())
                                .then(html => {
                                    const parser = new DOMParser();
                                    const doc = parser.parseFromString(html, "text/html");
                                    const newContainer = doc.getElementById('documentListContainer');
                                    const currentContainer = document.getElementById('documentListContainer');
                                    
                                    if (newContainer && currentContainer) {
                                        currentContainer.innerHTML = newContainer.innerHTML;
                                        attachChunkEvents(); // Gắn lại event do DOM mới
                                    }
                                });
                            return;
                        }

                        // Nếu chỉ là update trạng thái -> Cập nhật DOM trực tiếp để không mất trạng thái xem chunks
                        // Nếu có liên quan đến Retry button (từ Failed sang Pending hoặc ngược lại), thì cờ needHtmlReload đã tự được set true ở trên nếu ta check thêm, 
                        // Nhưng để đơn giản, chỉ cần DOM có sẵn ta cập nhật HTML badge. Nút xem chunks được toggle.
                        data.forEach(item => {
                            var cell = document.querySelector(`.status-cell[data-id="${item.id}"]`);
                            if (cell) {
                                var oldStatus = cell.getAttribute('data-status');
                                if (oldStatus !== item.status) {
                                    // Nếu trạng thái cũ hoặc mới là failed -> cần reload để update nút Retry
                                    if (oldStatus === 'failed' || item.status === 'failed') {
                                        window.location.reload();
                                        return;
                                    }

                                    cell.setAttribute('data-status', item.status);
                                    var processingStatusHtml = '';
                                    if (item.status === 'success') {
                                        processingStatusHtml = '<span class="status-badge status-processed">Vectorized</span>';
                                        var chunkBtn = document.querySelector(`.btn-view-chunks[data-id="${item.id}"]`);
                                        if (chunkBtn) chunkBtn.style.setProperty('display', 'inline-block', 'important');
                                    } else if (item.status === 'failed') {
                                        processingStatusHtml = '<span class="status-badge status-failed" style="background: #dc3545; color: white;">Failed</span>';
                                    } else if (item.status === 'processing') {
                                        processingStatusHtml = '<span class="status-badge status-processing" style="background: #17a2b8; color: white;">Processing...</span>';
                                    } else {
                                        processingStatusHtml = '<span class="status-badge status-pending">Pending...</span>';
                                    }
                                    cell.querySelector('.processing-status').innerHTML = processingStatusHtml;
                                }
                            }
                        });
                    })
                    .catch(err => console.error("Sync error: ", err));
            }
        });
    </script>
}
