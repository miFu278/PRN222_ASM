@page "/Subscription/Checkout"
@model RAGChatBot.Presentation.Pages.Subscription.CheckoutModel
@{
    ViewData["Title"] = "Thanh Toán VNPay";
}

<div class="zen-container">
    <div class="zen-hero" style="min-height: auto; margin-bottom: 60px;">
        <div class="zen-hero-title gsap-fade-up">
            <span class="text-accent">悟 THANH TOÁN AN TOÀN</span>
            <h1>Nâng Cấp <i>Premium</i></h1>
        </div>
        <div class="zen-hero-desc gsap-fade-up">
            Thanh toán an toàn qua cổng VNPay. Sau khi hoàn tất, bạn sẽ được nâng cấp lên gói Premium với đầy đủ quyền lợi.
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="mb-5" style="padding: 20px 0; border-bottom: 1px solid var(--accent-shu); color: var(--accent-shu); font-weight: 500; font-size: 1.1rem;">
            <i class="fa-solid fa-circle-exclamation me-2"></i> @Model.ErrorMessage
        </div>
    }

    <div class="gsap-fade-up" style="border-top: 1px solid var(--border-light); padding-top: 40px;">
        <div class="row">
            <div class="col-lg-6" style="padding-right: 40px; border-right: 1px solid var(--border-light);">
                <div style="font-family: var(--font-serif); font-size: 1.8rem; margin-bottom: 24px;">Chi tiết đơn hàng</div>
                <div style="display: flex; justify-content: space-between; padding: 16px 0; border-bottom: 1px solid var(--border-light);">
                    <span style="font-weight: 300;">Gói Premium (30 ngày)</span>
                    <span style="font-weight: 500;">199.000đ</span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 16px 0; border-bottom: 1px solid var(--border-light);">
                    <span style="font-weight: 300;">Phương thức thanh toán</span>
                    <span style="font-weight: 500;">VNPay QR / ATM / Visa</span>
                </div>
                <div style="display: flex; justify-content: space-between; padding: 16px 0; margin-bottom: 20px;">
                    <span style="font-family: var(--font-serif); font-size: 1.3rem;">Tổng cộng</span>
                    <span style="font-family: var(--font-serif); font-size: 1.5rem; color: var(--accent-shu);">199.000đ</span>
                </div>
            </div>

            <div class="col-lg-6 d-flex flex-column align-items-center justify-content-center mt-4 mt-lg-0" style="padding-left: 40px;">
                <div style="text-align: center; margin-bottom: 30px;">
                    <i class="fa-solid fa-shield-halved" style="font-size: 3rem; color: var(--accent-shu); margin-bottom: 16px;"></i>
                    <div style="font-family: var(--font-serif); font-size: 1.3rem; margin-bottom: 8px;">Thanh toán an toàn</div>
                    <div style="font-weight: 300; color: var(--text-muted); font-size: 0.95rem;">
                        Bạn sẽ được chuyển đến cổng thanh toán VNPay để hoàn tất giao dịch.
                    </div>
                </div>

                <form method="post" style="width: 100%;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-zen primary w-100 d-flex justify-content-center align-items-center magnetic-btn" style="padding: 16px 28px; font-size: 1.1rem; gap: 12px;">
                        <i class="fa-solid fa-credit-card"></i>
                        <span>Thanh Toán Qua VNPay</span>
                    </button>
                </form>

                <a href="/Subscription" class="mt-3" style="color: var(--text-muted); font-weight: 300; text-decoration: none; font-size: 0.9rem;">
                    <i class="fa-solid fa-arrow-left me-1"></i> Quay lại trang gói dịch vụ
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof window.zenInteract !== 'undefined') {
                window.zenInteract.initPageReveal();
                window.zenInteract.initMagneticButtons();
            }
        });
    </script>
}
