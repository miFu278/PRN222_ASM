@page "/Subscription/Checkout"
@model RAGChatBot.Presentation.Pages.Subscription.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán mô phỏng";
}

<style>
    .zen-checkout-container {
        max-width: 600px;
        margin: 0 auto;
        padding-top: 20px;
    }

    .zen-hero {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        margin-bottom: 40px;
        gap: 30px;
    }

    .zen-hero-title {
        flex: 1;
        min-width: 300px;
        position: relative;
    }

    .zen-hero-title h1 {
        font-size: 2.5rem;
        font-weight: 300;
        line-height: 1.2;
        letter-spacing: -0.02em;
    }
    
    .zen-hero-title .text-accent {
        font-size: 0.85rem;
        font-family: var(--font-sans);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 10px;
        font-weight: 500;
    }

    .zen-hero-desc {
        flex: 1;
        min-width: 300px;
        padding-top: 10px;
        font-size: 1rem;
        color: var(--text-muted) !important;
        position: relative;
    }

    .zen-hero-desc::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 40px;
        height: 1px;
        background-color: var(--text-sumi);
    }

    .checkout-card {
        border: 1px solid var(--border-light);
        padding: 40px 30px;
        background-color: transparent;
        margin-top: 30px;
    }

    .alert-zen-warning {
        background-color: rgba(191, 42, 35, 0.05);
        border: 1px solid rgba(191, 42, 35, 0.2);
        color: var(--accent-shu);
        padding: 15px 20px;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 30px;
        font-weight: 300;
    }

    .form-group-zen {
        margin-bottom: 25px;
    }

    .form-group-zen label {
        display: block;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 8px;
        font-weight: 500;
    }
</style>

<div class="zen-checkout-container gsap-fade-up">
    <!-- Hero Header -->
    <div class="zen-hero">
        <div class="zen-hero-title">
            <div class="text-accent">Thanh toán an toàn</div>
            <h1 class="font-serif m-0">Nâng Gói Premium</h1>
        </div>
        <div class="zen-hero-desc">
            <p>
                Giao dịch của bạn đang được mã hóa an toàn. 
                Bạn đang chuẩn bị đăng ký gói cước Premium <b>(199.000đ/tháng)</b>.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="mb-4" style="color: var(--accent-shu); padding: 15px 0; border-bottom: 1px solid var(--accent-shu); font-weight: 500;">
            <i class="fa-solid fa-circle-exclamation me-2"></i> @Model.ErrorMessage
        </div>
    }

    <!-- Checkout Simulated Card Form -->
    <div class="checkout-card">
        <!-- Warning notification -->
        <div class="alert-zen-warning">
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <strong>Môi trường thử nghiệm:</strong> Bạn có thể nhập thông tin bất kỳ vào các ô bên dưới để hoàn tất việc thanh toán mô phỏng.
        </div>

        <form method="post">
            <div class="form-group-zen">
                <label for="CardHolderName">Tên in trên thẻ</label>
                <input type="text" asp-for="CardHolderName" class="input-zen" placeholder="NGUYEN VAN A" required />
            </div>

            <div class="form-group-zen">
                <label for="CardNumber">Số thẻ tín dụng</label>
                <div style="position: relative; display: flex; align-items: center;">
                    <span style="position: absolute; left: 0; color: var(--text-muted); font-size: 1.1rem; opacity: 0.7;">
                        <i class="fa-solid fa-credit-card"></i>
                    </span>
                    <input type="text" asp-for="CardNumber" class="input-zen" placeholder="4123 4567 8901 2345" 
                           style="padding-left: 30px !important;" required pattern="\d{4}\s?\d{4}\s?\d{4}\s?\d{4}" 
                           title="Vui lòng nhập 16 số thẻ" />
                </div>
            </div>

            <div class="row">
                <div class="col-6">
                    <div class="form-group-zen">
                        <label for="ExpiryDate">Ngày hết hạn</label>
                        <input type="text" asp-for="ExpiryDate" class="input-zen" placeholder="MM/YY" required pattern="\d{2}/\d{2}" title="Định dạng MM/YY" />
                    </div>
                </div>
                <div class="col-6">
                    <div class="form-group-zen">
                        <label for="Cvv">Mã bảo mật CVV/CVC</label>
                        <input type="password" asp-for="Cvv" class="input-zen" placeholder="123" required pattern="\d{3,4}" title="3 hoặc 4 chữ số CVV" />
                    </div>
                </div>
            </div>

            <button type="submit" class="btn-zen w-100 mt-4 py-3 magnetic-btn" style="border-color: var(--accent-shu); color: var(--accent-shu);">
                <i class="fa-solid fa-lock me-2"></i> Xác nhận thanh toán 199.000đ
            </button>
            
            <div class="text-center mt-4">
                <a href="/Subscription" class="zen-action-link text-muted small"><i class="fa-solid fa-arrow-left me-2"></i> Quay lại bảng giá</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof window.zenInteract !== 'undefined') {
                window.zenInteract.initPageReveal();
                window.zenInteract.initMagneticButtons();
            }

            // Optional auto formatting of card number
            const cardInput = document.getElementById('CardNumber');
            if (cardInput) {
                cardInput.addEventListener('input', function (e) {
                    let value = e.target.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
                    let matches = value.match(/\d{4,16}/g);
                    let match = matches && matches[0] || '';
                    let parts = [];

                    for (let i = 0, len = match.length; i < len; i += 4) {
                        parts.push(match.substring(i, i + 4));
                    }

                    if (parts.length > 0) {
                        e.target.value = parts.join(' ');
                    } else {
                        e.target.value = value;
                    }
                });
            }
        });
    </script>
}
