@page "/"
@model RAGChatBot.Presentation.Pages.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="zen-chat-container">
    <!-- Zen Hero Section -->
    <div class="zen-hero">
        <div class="zen-hero-title gsap-fade-up">
            <span class="text-accent">悟 TRÍ TUỆ NHÂN TẠO TĨNH LẶNG</span>
            <h1>Khám Phá Tri Thức Qua Góc Nhìn <i>Nhân Loại</i>.</h1>
        </div>
        <div class="zen-hero-desc gsap-fade-up">
            Hệ thống trợ lý học tập thông minh ứng dụng kiến trúc RAG. Giảng viên chia sẻ tài liệu, AI tự động thấu hiểu và cùng sinh viên giải đáp mọi thắc mắc trong không gian trong trẻo, thanh lịch.
        </div>
    </div>

    <!-- Cấu trúc Flexbox ngăn kéo và chat chính -->
    <div class="zen-chat-layout">
        <!-- Ngăn kéo Lịch sử (Left Drawer) -->
        <aside class="zen-chat-drawer gsap-fade-up">
            <div class="zen-chat-drawer-inner">
                <div class="zen-drawer-title">
                    <span>Lịch Sử Chat</span>
                    <button class="zen-drawer-close" title="Đóng lịch sử"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <div class="mb-2 px-2">
                    <button class="btn-zen w-100" id="newThreadBtn" style="padding: 8px 12px; font-size: 0.85rem;">
                        <i class="fa-solid fa-plus me-2"></i>Cuộc trò chuyện mới
                    </button>
                </div>
                <div class="zen-threads-list" id="threadsList">
                    <div class="text-center py-3 text-muted small" id="threadsLoading">
                        <span class="spinner-border spinner-border-sm me-1"></span> Đang tải...
                    </div>
                </div>
            </div>
        </aside>

        <!-- Khung chat chính (Right Main Area) -->
        <div class="zen-chat-main-area">
            <!-- Nút mở Lịch sử -->
            <button class="zen-drawer-toggle magnetic-btn gsap-fade-up" title="Lịch sử trò chuyện">
                <i class="fa-solid fa-bars-staggered"></i>
            </button>

            <!-- Chat Messages Display -->
            <div class="zen-chat-messages gsap-fade-up" id="chatMessages" data-lenis-prevent></div>

            <!-- Loading Skeleton (Washi Ink dots) ẩn mặc định -->
            <div class="zen-washi-skeleton" id="washiSkeleton">
                <div class="washi-ink-dot"></div>
                <div class="washi-ink-dot"></div>
                <div class="washi-ink-dot"></div>
            </div>

            <!-- Bộ đếm Credit còn lại -->
            <div class="zen-credit-counter gsap-fade-up">
                <i class="fa-solid fa-bolt"></i> <span id="creditDisplay">Đang tải...</span>
            </div>

            <!-- Khu vực nhập liệu Chat -->
            <div class="zen-input-area gsap-fade-up">
                <div class="zen-input-wrapper">
                    <div class="flex-grow-1">
                        <input type="text" class="input-zen" placeholder="Hãy đặt câu hỏi về nội dung bài giảng hoặc tài liệu môn học..." id="chatInputField" autocomplete="off" />
                    </div>
                    <button class="zen-send-btn magnetic-btn" id="sendChatBtn" title="Gửi tin nhắn">
                        <i class="fa-solid fa-paper-plane" id="sendIcon"></i>
                    </button>
                </div>
            </div>

            <!-- Gợi ý câu hỏi -->
            <div class="zen-suggestions gsap-fade-up" id="zenSuggestions">
                <div class="zen-suggestion-item" data-question="Phân tích kiến trúc hệ thống RAG trong bài giảng">
                    <div>
                        <span class="small text-muted d-block mb-1" style="letter-spacing: 0.1em;">GỢI Ý CÂU HỎI</span>
                        <span class="text-sumi" style="font-size: 1.15rem; font-weight: 500;">Phân tích kiến trúc hệ thống RAG trong bài giảng</span>
                    </div>
                    <i class="fa-solid fa-arrow-right text-sumi"></i>
                </div>

                <div class="zen-suggestion-item" data-question="Các phương pháp tối ưu hóa Vector Database">
                    <div>
                        <span class="small text-muted d-block mb-1" style="letter-spacing: 0.1em;">GỢI Ý CÂU HỎI</span>
                        <span class="text-sumi" style="font-size: 1.15rem; font-weight: 500;">Các phương pháp tối ưu hóa Vector Database</span>
                    </div>
                    <i class="fa-solid fa-arrow-right text-sumi"></i>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const inputField = document.getElementById('chatInputField');
    const sendBtn = document.getElementById('sendChatBtn');
    const chatMessages = document.getElementById('chatMessages');
    const suggestions = document.getElementById('zenSuggestions');
    const sendIcon = document.getElementById('sendIcon');
    const washiSkeleton = document.getElementById('washiSkeleton');
    const threadsList = document.getElementById('threadsList');
    const threadsLoading = document.getElementById('threadsLoading');
    const creditDisplay = document.getElementById('creditDisplay');
    const newThreadBtn = document.getElementById('newThreadBtn');
    let isLoading = false;
    let activeThreadId = null;

    // ── Format markdown (giữ nguyên logic cũ) ──
    function formatMarkdown(text) {
        if (!text) return '';
        return text
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.*?)\*/g, '<em>$1</em>')
            .replace(/`(.*?)`/g, '<code style="background: rgba(0,0,0,0.05); padding: 2px 4px; border-radius: 4px;">$1</code>')
            .replace(/\n/g, '<br>');
    }

    function appendMessage(role, text) {
        const div = document.createElement('div');
        div.className = role === 'user' ? 'zen-msg zen-msg-user' : 'zen-msg zen-msg-bot';
        const bubble = document.createElement('div');
        bubble.className = 'zen-msg-bubble';
        if (role === 'bot' || role === 'assistant') {
            bubble.innerHTML = formatMarkdown(text);
        } else {
            bubble.textContent = text;
        }
        div.appendChild(bubble);
        chatMessages.appendChild(div);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function appendTyping() {
        if (washiSkeleton) {
            washiSkeleton.style.display = 'flex';
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }
    }

    function removeTyping() {
        if (washiSkeleton) washiSkeleton.style.display = 'none';
    }

    function setLoading(state) {
        isLoading = state;
        sendBtn.disabled = state;
        inputField.disabled = state;
        sendIcon.className = state ? 'fa-solid fa-spinner fa-spin' : 'fa-solid fa-paper-plane';
    }

    // ── Load threads từ API thực tế ──
    async function loadThreads() {
        try {
            const res = await fetch('/api/chat/threads');
            const threads = await res.json();
            threadsList.innerHTML = '';

            if (!threads || threads.length === 0) {
                threadsList.innerHTML = '<div class="text-center py-3 text-muted small" style="font-weight:300;">Chưa có lịch sử chat.</div>';
                return;
            }

            threads.forEach(t => {
                const item = document.createElement('div');
                item.className = 'zen-thread-item';
                item.dataset.threadId = t.id;
                item.innerHTML = `
                    <span><i class="fa-regular fa-comment thread-icon"></i> ${escapeHtml(t.title)}</span>
                    <i class="fa-solid fa-angle-right small text-muted"></i>
                `;
                item.addEventListener('click', () => loadThread(t.id, t.title));
                threadsList.appendChild(item);
            });

            // GSAP animation
            if (typeof gsap !== 'undefined') {
                gsap.fromTo('.zen-thread-item',
                    { opacity: 0, x: -20 },
                    { opacity: 1, x: 0, duration: 0.4, stagger: 0.05, ease: 'power2.out' }
                );
            }
        } catch (err) {
            threadsList.innerHTML = '<div class="text-center py-3 text-muted small">Lỗi tải lịch sử.</div>';
            console.error('Load threads error:', err);
        }
    }

    // ── Load tin nhắn của thread ──
    async function loadThread(threadId, title) {
        activeThreadId = threadId;
        chatMessages.innerHTML = '';
        suggestions.style.display = 'none';
        setLoading(true);

        // Highlight active thread
        document.querySelectorAll('.zen-thread-item').forEach(el => {
            el.classList.toggle('active', el.dataset.threadId === threadId);
        });

        if (window.zenInteract) window.zenInteract.showToast('Đang mở: ' + title);

        try {
            const res = await fetch(`/api/chat/threads?handler=Messages&threadId=${threadId}`);
            const messages = await res.json();

            if (Array.isArray(messages)) {
                messages.forEach(m => appendMessage(m.role, m.content));
            }
        } catch (err) {
            appendMessage('bot', 'Không thể tải lịch sử chat. Vui lòng thử lại.');
            console.error(err);
        } finally {
            setLoading(false);
            inputField.focus();
        }
    }

    // ── Gửi tin nhắn với threadId ──
    async function sendMessage() {
        const text = inputField.value.trim();
        if (!text || isLoading) return;

        suggestions.style.display = 'none';
        appendMessage('user', text);
        inputField.value = '';
        setLoading(true);
        appendTyping();

        try {
            const body = { message: text };
            if (activeThreadId) body.threadId = activeThreadId;

            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            removeTyping();

            if (response.ok) {
                const data = await response.json();
                appendMessage('bot', data.reply ?? data.message ?? 'Không có phản hồi.');

                // Cập nhật threadId từ response để duy trì luồng
                if (data.threadId) activeThreadId = data.threadId;

                // Cập nhật credit counter
                if (data.remaining !== undefined) {
                    creditDisplay.textContent = `${data.remaining} lượt hỏi còn lại hôm nay`;
                }

                if (data.outOfCredits) {
                    creditDisplay.textContent = '0 lượt — Hãy nâng cấp Premium!';
                    creditDisplay.style.color = 'var(--accent-shu)';
                }

                // Reload danh sách thread (vì có thể có thread mới)
                loadThreads();
            } else {
                appendMessage('bot', 'Xin lỗi, đã xảy ra lỗi khi xử lý yêu cầu. Vui lòng thử lại.');
            }
        } catch (err) {
            removeTyping();
            appendMessage('bot', 'Không thể kết nối đến máy chủ. Vui lòng kiểm tra kết nối mạng.');
        } finally {
            setLoading(false);
            inputField.focus();
        }
    }

    function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str || '';
        return div.innerHTML;
    }

    // ── Cuộc trò chuyện mới ──
    newThreadBtn.addEventListener('click', function () {
        activeThreadId = null;
        chatMessages.innerHTML = '';
        suggestions.style.display = '';
        document.querySelectorAll('.zen-thread-item').forEach(el => el.classList.remove('active'));
        inputField.focus();
        if (window.zenInteract) window.zenInteract.showToast('Bắt đầu cuộc trò chuyện mới.');
    });

    // Enter key handler
    inputField.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // Send button click handler
    sendBtn.addEventListener('click', function (e) {
        e.preventDefault();
        sendMessage();
    });

    // Suggestion click handlers
    document.querySelectorAll('.zen-suggestion-item').forEach(function (item) {
        item.addEventListener('click', function () {
            inputField.value = item.dataset.question;
            sendMessage();
        });
    });

    // ── Khởi tạo ──
    document.addEventListener("DOMContentLoaded", function () {
        if (window.zenInteract) {
            window.zenInteract.initMagneticButtons();
            window.zenInteract.initChatDrawer();
            window.zenInteract.initWashiSkeleton();
            window.zenInteract.init3DTilt();
        }
        loadThreads();
    });
})();
</script>
}
