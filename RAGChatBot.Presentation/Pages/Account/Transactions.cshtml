@page "/Account/Transactions"
@model RAGChatBot.Presentation.Pages.Account.TransactionsModel
@using RAGChatBot.Domain.Constants
@{
    ViewData["Title"] = "Lịch Sử Giao Dịch";
}

<div class="zen-container py-5 gsap-fade-up">
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <div class="text-accent mb-2" style="font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase;">
                Tài khoản của bạn
            </div>
            <h1 class="font-serif m-0" style="font-size: 3rem;">Lịch Sử Giao Dịch</h1>
        </div>
        <div class="text-muted" style="font-weight: 300;">
            <i class="fa-solid fa-receipt me-1"></i> Tổng: @Model.Transactions.Count giao dịch
        </div>
    </div>

    @if (Model.Transactions.Count == 0)
    {
        <div class="text-center py-5" style="border-top: 1px solid var(--border-light);">
            <i class="fa-solid fa-receipt mb-3" style="font-size: 2.5rem; color: var(--text-muted);"></i>
            <div class="font-serif mb-2" style="font-size: 1.4rem;">Bạn chưa có giao dịch nào</div>
            <p class="text-muted mb-4" style="font-weight: 300;">Các lần thanh toán Premium của bạn sẽ xuất hiện tại đây.</p>
            <a asp-page="/Subscription/Index" class="btn-zen primary magnetic-btn">Xem Gói Dịch Vụ</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-zen w-100">
                <thead>
                    <tr>
                        <th>Mã đơn hàng</th>
                        <th>Số tiền</th>
                        <th>Loại giao dịch</th>
                        <th>Mã giao dịch PayOS</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Ngày thanh toán</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in Model.Transactions)
                    {
                        <tr>
                            <td style="font-family: monospace; font-size: 0.85rem;">@transaction.OrderId</td>
                            <td style="font-weight: 500; white-space: nowrap;">@transaction.Amount.ToString("N0")đ</td>
                            <td>
                                @(transaction.Type == PaymentTransactionTypes.PremiumSubscription
                                    ? "Nâng cấp Premium"
                                    : transaction.Type)
                            </td>
                            <td class="text-muted" style="font-size: 0.85rem;">@(transaction.TransactionNo ?? "-")</td>
                            <td>
                                @if (string.Equals(transaction.Status, "Success", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="status-badge" style="color: #2d6a4f;">
                                        <span class="d-inline-block rounded-circle" style="width: 6px; height: 6px; background-color: #2d6a4f; margin-right: 8px;"></span>
                                        Thành công
                                    </span>
                                }
                                else if (string.Equals(transaction.Status, "Pending", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="status-badge" style="color: var(--text-muted);">
                                        <span class="d-inline-block rounded-circle" style="width: 6px; height: 6px; background-color: var(--text-muted); margin-right: 8px;"></span>
                                        Đang chờ
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge" style="color: var(--accent-shu);">
                                        <span class="d-inline-block rounded-circle" style="width: 6px; height: 6px; background-color: var(--accent-shu); margin-right: 8px;"></span>
                                        Thất bại
                                    </span>
                                }
                            </td>
                            <td class="text-muted" style="font-size: 0.85rem; white-space: nowrap;">@transaction.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-muted" style="font-size: 0.85rem; white-space: nowrap;">@(transaction.PaidAt.HasValue ? transaction.PaidAt.Value.AddHours(7).ToString("dd/MM/yyyy HH:mm") : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
